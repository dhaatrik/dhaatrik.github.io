---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
    (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// ⚡ Bolt: Optimize reading time calculation by using raw body instead of full AST rendering
const postsWithReadingTime = posts.map((post: any) => {
    // `post.body` contains the raw uncompiled markdown string (available in Astro 5 glob loader)
    const body = post.body || '';
    return {
        ...post,
        readingTime: `${getReadingTime(body)} min read`,
    };
});
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <Header />
        <main id="main-content" tabindex="-1" class="layout-container grow py-8">
            <section class="mx-auto max-w-4xl">
                <div
                    class="mb-2 flex flex-col items-start justify-between gap-4 md:flex-row md:items-center"
                >
                    <h1
                        class="text-4xl leading-tight font-bold tracking-tight text-slate-900 md:text-5xl dark:text-white"
                    >
                        Mission <span class="text-slate-400 dark:text-slate-600">Logs</span>
                    </h1>
                    <div class="flex flex-wrap items-center gap-6">
                        <!-- Git Contribution Velocity Matrix -->
                        <div class="hidden sm:flex flex-col items-end gap-1 font-mono text-[9px] text-slate-400 dark:text-slate-600 select-none">
                            <div class="text-[8px] uppercase tracking-wider text-slate-400 dark:text-slate-500">EXECUTION_VELOCITY // ACTIVE</div>
                            <div class="grid grid-flow-col gap-0.5" id="contrib-matrix">
                                {Array.from({ length: 14 }).map((_, col) => (
                                    <div class="grid gap-0.5">
                                        {Array.from({ length: 7 }).map((_, row) => {
                                            const val = (col * 7 + row) % 3 === 0 || (col * 3 + row * 2) % 5 === 0;
                                            const intensity = val ? ((col * 2 + row) % 3 === 0 ? 'bg-(--accent)' : 'bg-(--accent)/40') : 'bg-slate-200 dark:bg-slate-800';
                                            return <div class="w-1.5 h-1.5 rounded-xs bg-slate-200 dark:bg-slate-800" class:list={[intensity]} />;
                                        })}
                                    </div>
                                ))}
                            </div>
                        </div>
                        <a
                            href="/rss.xml"
                            class="magnetic-target flex items-center gap-2 rounded border border-(--accent)/20 bg-(--accent)/10 px-3 py-1.5 font-mono text-xs tracking-widest text-(--accent) transition-colors hover:bg-(--accent)/20"
                        >
                            <span
                                class="h-1.5 w-1.5 animate-pulse rounded-full bg-(--accent) shadow-[0_0_8px_var(--accent)]"
                            ></span>
                            [ RAW FEED // RSS ]
                        </a>
                    </div>
                </div>
                <p
                    class="mb-6 max-w-2xl font-mono text-sm leading-relaxed text-slate-500 dark:text-slate-400"
                >
                    Deep-dives into First-Principles engineering, startup architecture, and the
                    pursuit of Delta-v.
                </p>

                <!-- Subsystem Domain Tabs -->
                <div class="mb-10 flex flex-wrap gap-2.5 font-mono text-xs select-none">
                    <button data-filter="all" class="filter-tab px-3 py-1.5 border border-(--accent) bg-(--accent)/10 text-(--accent) rounded cursor-pointer transition-all hover:bg-(--accent)/20">[ ALL ]</button>
                    <button data-filter="ai_orchestration" class="filter-tab px-3 py-1.5 border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 rounded cursor-pointer transition-all hover:border-(--accent)/35 hover:text-(--accent)/80 hover:bg-(--accent)/5">[ AI_ORCHESTRATION ]</button>
                    <button data-filter="flight_dynamics" class="filter-tab px-3 py-1.5 border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 rounded cursor-pointer transition-all hover:border-(--accent)/35 hover:text-(--accent)/80 hover:bg-(--accent)/5">[ FLIGHT_DYNAMICS ]</button>
                    <button data-filter="agtech" class="filter-tab px-3 py-1.5 border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 rounded cursor-pointer transition-all hover:border-(--accent)/35 hover:text-(--accent)/80 hover:bg-(--accent)/5">[ AGTECH ]</button>
                </div>

                <!-- Terminal-Style Search Bar -->
                <div class="mb-10 font-mono">
                    <label for="search-logs" class="sr-only">Search Mission Logs</label>
                    <div class="group relative flex items-center">
                        <span
                            class="pointer-events-none absolute left-4 text-slate-400 transition-colors select-none group-focus-within:text-(--accent) dark:text-slate-500"
                            >~ $ grep -i</span
                        >
                        <input
                            type="search"
                            id="search-logs"
                            placeholder='"Search archives..."'
                            aria-controls="logs-grid"
                            class="w-full rounded-md border border-slate-200 bg-slate-100 py-3 pr-4 pl-32 text-sm text-slate-900 transition-all placeholder:text-slate-400 focus:border-(--accent)/50 focus:ring-1 focus:ring-(--accent)/50 focus:outline-none dark:border-slate-800 dark:bg-[#151a22] dark:text-white dark:placeholder:text-slate-600"
                        />
                    </div>
                    <div id="search-announcer" class="sr-only" aria-live="polite"></div>
                </div>

                <div class="relative p-6 border border-slate-200 dark:border-slate-800 rounded-xl bg-slate-500/5 backdrop-blur-xs">
                    <!-- High-Science Blueprint Framing Calibration Marks -->
                    <div class="absolute top-0 left-0 -translate-x-1.5 -translate-y-1.5 font-mono text-xs text-slate-400 dark:text-slate-600 select-none pointer-events-none">+</div>
                    <div class="absolute top-0 right-0 translate-x-1.5 -translate-y-1.5 font-mono text-xs text-slate-400 dark:text-slate-600 select-none pointer-events-none">+</div>
                    <div class="absolute bottom-0 left-0 -translate-x-1.5 translate-y-1.5 font-mono text-xs text-slate-400 dark:text-slate-600 select-none pointer-events-none">+</div>
                    <div class="absolute bottom-0 right-0 translate-x-1.5 translate-y-1.5 font-mono text-xs text-slate-400 dark:text-slate-600 select-none pointer-events-none">+</div>
                    
                    <div class="absolute -top-3 left-4 bg-(--bg-main) px-2 font-mono text-[9px] text-(--accent) tracking-widest uppercase">
                        [ SYS.LOG_MATRIX // ACTIVE ]
                    </div>
                    <div class="absolute -bottom-3 right-4 bg-(--bg-main) px-2 font-mono text-[9px] text-slate-400 dark:text-slate-600 tracking-widest uppercase">
                        REF_GRID: 50.84.11
                    </div>

                    <div class="grid gap-8 md:grid-cols-2" id="logs-grid">
                        {
                            postsWithReadingTime.map((post: any, i: number) => (
                                <a
                                    href={`/blog/${post.id}/`}
                                    data-astro-prefetch="hover"
                                    data-tags={post.data.tags ? post.data.tags.join(',') : ''}
                                    class:list={[
                                        'bento-card blog-post-card group relative block overflow-hidden transition-all active:scale-[0.99]',
                                        {
                                            'md:col-span-2 md:grid md:grid-cols-2 md:items-center md:gap-8':
                                                i === 0,
                                            'content-visibility-auto-post-card':
                                                i >= 2,
                                        },
                                    ]}
                                >
                                    {post.data.heroImage ? (
                                        <div
                                            class:list={[
                                                'bento-card-inner',
                                                i !== 0 ? 'mb-4' : 'h-full',
                                            ]}
                                        >
                                            {/* ⚡ Bolt: Optimize LCP by eager loading the first image (above the fold) with high priority */}
                                            <Image
                                                width={720}
                                                height={360}
                                                src={post.data.heroImage}
                                                alt=""
                                                class:list={[
                                                    'w-full object-cover transition-transform duration-300 group-hover:scale-105 group-focus-visible:scale-105',
                                                    i === 0 ? 'h-full min-h-[300px]' : 'h-48',
                                                ]}
                                                loading={i === 0 ? 'eager' : 'lazy'}
                                                fetchpriority={i === 0 ? 'high' : 'auto'}
                                            />
                                        </div>
                                    ) : (
                                        <div
                                            class:list={[
                                                'bento-card-inner relative flex items-center justify-center overflow-hidden bg-slate-100 dark:bg-slate-900',
                                                i !== 0 ? 'mb-4 h-48' : 'h-full min-h-[300px]',
                                            ]}
                                        >
                                            <div class="bg-grid-motif absolute inset-0 opacity-20 dark:opacity-50" />
                                            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,var(--accent-glow)_0%,transparent_70%)] opacity-50 dark:opacity-100" />
                                            <div class="absolute inset-0 m-4 rounded-lg border border-(--accent)/20" />
                                            <span class="z-10 font-mono text-7xl font-bold text-(--accent)/80 drop-shadow-lg">
                                                {post.data.title.charAt(0).toUpperCase()}
                                            </span>
                                        </div>
                                    )}
                                    <div
                                        class:list={[
                                            'flex flex-col justify-center',
                                            i === 0 ? 'md:p-2' : '',
                                        ]}
                                    >
                                        <div class="mb-3 font-mono text-[10px] tracking-widest text-(--accent)">
                                            LOG_
                                            {String(postsWithReadingTime.length - i).padStart(3, '0')}
                                        </div>
                                        <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-(--text-secondary)">
                                            <FormattedDate
                                                date={post.data.pubDate}
                                                format="technical"
                                            />
                                            {post.readingTime && (
                                                <>
                                                    <span
                                                        aria-hidden="true"
                                                        class="text-slate-300 dark:text-slate-700"
                                                    >
                                                        |
                                                    </span>
                                                    <span class="font-mono text-xs">
                                                        {post.readingTime}
                                                    </span>
                                                </>
                                            )}
                                            {post.data.tags && post.data.tags.length > 0 && (
                                                <>
                                                    <span
                                                        aria-hidden="true"
                                                        class="text-slate-300 dark:text-slate-700"
                                                    >
                                                        |
                                                    </span>
                                                    <span class="rounded bg-(--accent)/10 px-2 py-0.5 text-[10px] font-bold tracking-widest text-(--accent) uppercase">
                                                        {post.data.tags[0]}
                                                    </span>
                                                </>
                                            )}
                                        </div>
                                        <h2
                                            class:list={[
                                                'font-bold tracking-tight text-balance text-slate-900 transition-colors group-hover:text-(--accent) group-focus-visible:text-(--accent) dark:text-white',
                                                i === 0 ? 'text-3xl' : 'text-xl',
                                            ]}
                                        >
                                            {post.data.title}
                                        </h2>
                                        <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                            {post.data.description}
                                        </p>
                                        <div class="mt-4 h-6 overflow-hidden">
                                            <span class="inline-block -translate-x-4 text-sm font-bold text-(--accent) opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                                                Read Transmission &rarr;
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Empty State UI -->
                <div id="search-empty-state" class="hidden py-20 text-center" aria-hidden="true">
                    <div
                        class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-slate-100 text-slate-400 dark:bg-slate-800 dark:text-slate-500"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
                            ></path></svg
                        >
                    </div>
                    <h3 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">
                        No transmissions found
                    </h3>
                    <p class="mx-auto max-w-sm text-sm text-slate-500 dark:text-slate-400">
                        Try adjusting your search parameters to find what you're looking for.
                    </p>
                </div>
            </section>
        </main>
        <Footer />

        <script>
            // Client-side filtering logic with state retention & hotkey focus
            let searchAbortController: AbortController | null = null;
            let replaceStateTimeout: number | undefined;

            const setupSearch = () => {
                const searchInput = document.getElementById('search-logs') as HTMLInputElement;
                const cards = document.querySelectorAll('.blog-post-card');
                const emptyState = document.getElementById('search-empty-state');
                const announcer = document.getElementById('search-announcer');
                const tabs = document.querySelectorAll('.filter-tab');

                if (!searchInput) return;

                // Abort any existing search listeners
                if (searchAbortController) {
                    searchAbortController.abort();
                }
                searchAbortController = new AbortController();
                const { signal } = searchAbortController;

                let activeTag = 'all';

                // Function to perform combined filtering
                const filterPosts = () => {
                    const term = searchInput.value.toLowerCase();
                    let visibleCount = 0;

                    cards.forEach((card) => {
                        const htmlCard = card as HTMLElement;
                        const cardTags = htmlCard.dataset.tags?.toLowerCase().split(',') || [];
                        const text = htmlCard.textContent?.toLowerCase() || '';

                        const matchesSearch = text.includes(term);
                        const matchesTag = activeTag === 'all' || cardTags.includes(activeTag);

                        if (matchesSearch && matchesTag) {
                            htmlCard.style.display = '';
                            visibleCount++;
                        } else {
                            htmlCard.style.display = 'none';
                        }
                    });

                    if (emptyState) {
                        if (visibleCount === 0) {
                            emptyState.classList.remove('hidden');
                            emptyState.setAttribute('aria-hidden', 'false');
                        } else {
                            emptyState.classList.add('hidden');
                            emptyState.setAttribute('aria-hidden', 'true');
                        }
                    }

                    if (announcer) {
                        announcer.textContent = term || activeTag !== 'all'
                            ? `Found ${visibleCount} transmission${visibleCount === 1 ? '' : 's'}.`
                            : '';
                    }
                };

                const updateSearchState = (term: string, tag: string) => {
                    sessionStorage.setItem('blog-search-term', term);
                    sessionStorage.setItem('blog-search-tag', tag);

                    clearTimeout(replaceStateTimeout);
                    replaceStateTimeout = setTimeout(() => {
                        const url = new URL(window.location.href);
                        if (term) {
                            url.searchParams.set('q', term);
                        } else {
                            url.searchParams.delete('q');
                        }
                        if (tag && tag !== 'all') {
                            url.searchParams.set('tag', tag);
                        } else {
                            url.searchParams.delete('tag');
                        }
                        window.history.replaceState(null, '', url.pathname + url.search);
                    }, 300) as any;
                };

                // Check for URL query parameter first, then sessionStorage, then default to empty
                const urlParams = new URLSearchParams(window.location.search);
                const queryParam = urlParams.get('q');
                const sessionSearch = sessionStorage.getItem('blog-search-term');
                const initialTerm = queryParam !== null ? queryParam : (sessionSearch || '');

                const tagParam = urlParams.get('tag');
                const sessionTag = sessionStorage.getItem('blog-search-tag');
                const initialTag = tagParam !== null ? tagParam : (sessionTag || 'all');

                activeTag = initialTag;
                if (initialTerm) {
                    searchInput.value = initialTerm;
                }

                // Setup tabs active state on load
                tabs.forEach((t) => {
                    const htmlT = t as HTMLElement;
                    if (htmlT.dataset.filter === activeTag) {
                        htmlT.className = 'filter-tab px-3 py-1.5 border border-(--accent) bg-(--accent)/10 text-(--accent) rounded cursor-pointer transition-all hover:bg-(--accent)/20';
                    } else {
                        htmlT.className = 'filter-tab px-3 py-1.5 border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 rounded cursor-pointer transition-all hover:border-(--accent)/35 hover:text-(--accent)/80 hover:bg-(--accent)/5';
                    }
                });

                filterPosts();

                // Search Input event listener
                searchInput.addEventListener('input', (e) => {
                    const term = (e.target as HTMLInputElement).value;
                    filterPosts();
                    updateSearchState(term, activeTag);
                }, { signal });

                // Tabs event listener
                tabs.forEach((tab) => {
                    tab.addEventListener('click', (e) => {
                        const clickedTag = (e.currentTarget as HTMLElement).dataset.filter || 'all';
                        activeTag = clickedTag;

                        // Update tabs styles
                        tabs.forEach((t) => {
                            const htmlT = t as HTMLElement;
                            if (htmlT.dataset.filter === activeTag) {
                                htmlT.className = 'filter-tab px-3 py-1.5 border border-(--accent) bg-(--accent)/10 text-(--accent) rounded cursor-pointer transition-all hover:bg-(--accent)/20';
                            } else {
                                htmlT.className = 'filter-tab px-3 py-1.5 border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 rounded cursor-pointer transition-all hover:border-(--accent)/35 hover:text-(--accent)/80 hover:bg-(--accent)/5';
                            }
                        });

                        filterPosts();
                        updateSearchState(searchInput.value, activeTag);
                    }, { signal });
                });

                // Global Forward Slash / Hotkey Listener
                const handleHotkey = (e: KeyboardEvent) => {
                    // Ignore if typing in another input/textarea
                    if (document.activeElement && ['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
                        return;
                    }
                    if (e.key === '/') {
                        e.preventDefault();
                        searchInput.focus();
                        searchInput.placeholder = '[ SYSTEM CAPTURE ACTIVE ]';
                    }
                };

                window.addEventListener('keydown', handleHotkey, { signal });

                searchInput.addEventListener('blur', () => {
                    searchInput.placeholder = '"Search archives..."';
                }, { signal });
            };

            // Run strictly on Astro page navigation / page load
            document.addEventListener('astro:page-load', setupSearch);

            // Cleanup event listeners and timeouts when navigating away
            document.addEventListener('astro:before-preparation', () => {
                if (searchAbortController) {
                    searchAbortController.abort();
                    searchAbortController = null;
                }
                clearTimeout(replaceStateTimeout);
            });
        </script>
    </body>
</html>
