---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Compute reading time for each post via the remark plugin
const postsWithReadingTime = await Promise.all(
    posts.map(async (post) => {
        const { remarkPluginFrontmatter } = await render(post);
        return {
            ...post,
            readingTime: remarkPluginFrontmatter.readingTime as string | undefined,
        };
    })
);
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body class="flex min-h-screen flex-col pt-24">
        <Header />
        <main class="layout-container flex-grow py-8">
            <section class="mx-auto max-w-4xl">
                <h1
                    class="mb-10 text-4xl leading-tight font-bold text-slate-900 md:text-5xl dark:text-white"
                >
                    Blog
                </h1>
                <div class="grid gap-8 md:grid-cols-2">
                    {
                        postsWithReadingTime.map((post, i) => (
                            <a
                                href={`/blog/${post.id}/`}
                                class:list={[
                                    'bento-card group block overflow-hidden',
                                    { 'md:col-span-2': i === 0 },
                                ]}
                            >
                                {post.data.heroImage && (
                                    <div class="bento-card-inner mb-4">
                                        {/* ⚡ Bolt: Optimize LCP by eager loading the first image (above the fold) with high priority */}
                                        <Image
                                            width={720}
                                            height={360}
                                            src={post.data.heroImage}
                                            alt={post.data.title}
                                            class="w-full object-cover transition-transform duration-300 group-hover:scale-105 group-focus-visible:scale-105"
                                            loading={i === 0 ? 'eager' : 'lazy'}
                                            fetchpriority={i === 0 ? 'high' : 'auto'}
                                        />
                                    </div>
                                )}
                                <div class="mb-2 flex items-center gap-3 text-sm text-slate-500 dark:text-[var(--text-secondary)]">
                                    <FormattedDate date={post.data.pubDate} />
                                    {post.readingTime && (
                                        <>
                                            <span aria-hidden="true">·</span>
                                            <span>{post.readingTime}</span>
                                        </>
                                    )}
                                </div>
                                <h2
                                    class:list={[
                                        'font-bold text-slate-900 transition-colors group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white',
                                        i === 0 ? 'text-2xl' : 'text-xl',
                                    ]}
                                >
                                    {post.data.title}
                                </h2>
                                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                                    {post.data.description}
                                </p>
                            </a>
                        ))
                    }
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>
