---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { resolvePrevNext } from '../../utils/seriesNavigation';

export async function getStaticPaths() {
    const posts = await getCollection('blog');

    return posts.map((post) => {
        const { prevPost, nextPost, isSeriesNav } = resolvePrevNext(post, posts);

        return {
            params: { slug: post.id },
            props: {
                post,
                prevPost,
                nextPost,
                isSeriesNav,
            },
        };
    });
}

interface Props {
    post: CollectionEntry<'blog'>;
    prevPost: CollectionEntry<'blog'> | null;
    nextPost: CollectionEntry<'blog'> | null;
    isSeriesNav: boolean;
}

const { post, prevPost, nextPost, isSeriesNav } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPost
    {...post.data}
    id={post.id}
    headings={headings}
    prevPost={prevPost}
    nextPost={nextPost}
    isSeriesNav={isSeriesNav}
    rawContent={post.body}
>
    <Content />
</BlogPost>