                            opacity="0.7"></path>

                        <!-- Dish Rim Connectors -->
                        <line x1="45" y1="85" x2="45" y2="88" stroke="currentColor" stroke-width="1"
                        ></line>
                        <line
                            x1="155"
                            y1="85"
                            x2="155"
                            y2="88"
                            stroke="currentColor"
                            stroke-width="1"></line>

                        <!-- Sub-reflectors & Struts -->
