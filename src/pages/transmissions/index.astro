                        <circle
                            cx="100"
                            cy="50"
                            r="3"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"></circle>
                        <circle cx="100" cy="50" r="1" fill="currentColor"></circle>

                        <!-- Radiating Signal Waves -->
                        <path
                            d="M 85,32 A 20,20 0 0,1 115,32"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="0.8"
                            stroke-dasharray="2 1"></path>
                        <path
                            d="M 70,18 A 40,40 0 0,1 130,18"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"
                            stroke-dasharray="3 2"></path>
                        <path
                            d="M 55,4 A 60,60 0 0,1 145,4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.2"
                            stroke-dasharray="4 3"
                            opacity="0.8"></path>

                        <!-- Mounting bracket & pedestal -->
                        <path
                            d="M 80,140 L 100,123 L 120,140"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.2"></path>
                        <path
                            d="M 75,147 C 75,142 125,142 125,147"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"></path>

                        <!-- Focus Ray Indicators -->
                        <line
                            x1="60"
                            y1="65"
                            x2="100"
                            y2="50"
                            stroke="currentColor"
                            stroke-width="0.4"
                            stroke-dasharray="1 3"
                            opacity="0.5"></line>
                        <line
                            x1="140"
                            y1="65"
                            x2="100"
                            y2="50"
                            stroke="currentColor"
                            stroke-width="0.4"
                            stroke-dasharray="1 3"
                            opacity="0.5"></line>
                    </g>

                    <!-- Callout line -->
                    <line
                        x1="100"
                        y1="85"
                        x2="135"
                        y2="65"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="1 1"
                        opacity="0.7"></line>
                    <circle cx="135" cy="65" r="1" fill="currentColor"></circle>
                    <text
