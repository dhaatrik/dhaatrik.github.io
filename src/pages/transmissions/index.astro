                    <text
                        x="25"
                        y="170"
                        font-family="monospace"
                        font-size="6"
                        fill="currentColor"
                        opacity="0.6">SYS.TELEMETRY_LINK // V2.0</text
                    >
                    <text
                        x="25"
                        y="178"
                        font-family="monospace"
                        font-size="5"
                        fill="currentColor"
                        opacity="0.4">DHAATRIK.LOGS.BROADCAST</text
                    >
                </svg>
            </div>
            <section class="layout-container mx-auto">
                <div
                    class="mb-2 flex flex-col items-start justify-between gap-4 md:flex-row md:items-center"
                >
                    <h1
                        class="text-4xl leading-tight font-bold tracking-tight text-slate-900 md:text-5xl dark:text-white"
                    >
                        Mission <span class="text-slate-400 dark:text-slate-600">Logs</span>
                    </h1>
                    <a
                        href="/rss.xml"
                        class="magnetic-target flex items-center gap-2 rounded border border-(--accent)/20 bg-(--accent)/10 px-3 py-1.5 font-mono text-xs tracking-widest text-(--accent) transition-colors hover:bg-(--accent)/20"
                    >
                        <span
                            class="h-1.5 w-1.5 animate-pulse rounded-full bg-(--accent) shadow-[0_0_8px_var(--accent)]"
                        ></span>
                        [ RAW FEED // RSS ]
                    </a>
                </div>
                <p
                    class="mb-6 max-w-2xl font-mono text-sm leading-relaxed text-slate-500 dark:text-slate-400"
                >
                    Deep-dives into First-Principles engineering, startup architecture, and the
                    pursuit of Delta-v.
                </p>

                <!-- Subsystem Domain Tabs -->
                <div class="mb-10 flex flex-wrap gap-2.5 font-mono text-xs select-none">
                    <button
                        data-filter="all"
                        aria-pressed="true"
                        class="filter-tab active cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ ALL ]</button
                    >
                    <button
                        data-filter="ai_orchestration"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ AI_ORCHESTRATION ]</button
                    >
                    <button
                        data-filter="flight_dynamics"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ FLIGHT_DYNAMICS ]</button
                    >
                    <button
                        data-filter="aerospace"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ AEROSPACE ]</button
                    >
                    <button
                        data-filter="agtech"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ AGTECH ]</button
                    >
                    <button
                        data-filter="vellor"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ VELLOR ]</button
                    >
                    <button
                        data-filter="deltav-lab"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ DELTAV_LAB ]</button
                    >
                    <button
                        data-filter="fueldrop"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ FUELDROP ]</button
                    >
                    <button
                        data-filter="the-infinite-intelligence"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ INFINITE_INTELLIGENCE ]</button
                    >
                    <button
                        data-filter="pedagogy"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ PEDAGOGY ]</button
                    >
                    <button
                        data-filter="youtube"
                        aria-pressed="false"
                        class="filter-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 dark:hover:bg-[#1c232e] dark:focus-visible:ring-offset-(--bg-main) [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)] [&.active]:hover:bg-(--accent)/20"
                        >[ YOUTUBE ]</button
                    >
                </div>

                <!-- Terminal-Style Search Bar -->
                <div class="mb-10 font-mono">
                    <label for="search-logs" class="sr-only">Search Mission Logs</label>
                    <div class="group relative flex items-center">
                        <span
                            aria-hidden="true"
                            class="pointer-events-none absolute left-4 hidden text-slate-400 transition-colors select-none group-focus-within:text-(--accent) sm:inline dark:text-slate-500"
                            >~ $ grep -i</span
                        >
                        <span
                            aria-hidden="true"
                            class="pointer-events-none absolute left-4 text-slate-400 transition-colors select-none group-focus-within:text-(--accent) sm:hidden dark:text-slate-500"
                            >$ grep</span
                        >
                        <input
                            type="search"
                            id="search-logs"
                            placeholder='"Search archives..."'
                            aria-controls="logs-grid"
                            class="w-full rounded-md border border-slate-200 bg-slate-100 py-3 pr-4 pl-20 text-sm text-slate-900 transition-all placeholder:text-slate-400 focus:border-(--accent)/50 focus:ring-1 focus:ring-(--accent)/50 focus:outline-none sm:pl-32 dark:border-slate-800 dark:bg-[#151a22] dark:text-white dark:placeholder:text-slate-600"
                        />
                    </div>
                    <p class="mt-2 text-[11px] text-slate-400 select-none dark:text-slate-500">
                        Press <kbd
                            class="inline-flex items-center justify-center rounded border border-slate-300 bg-slate-200/60 px-1.5 py-0.5 font-mono text-[10px] font-semibold text-slate-500 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-400"
                            >/</kbd
                        > to search
                    </p>
                    <div id="search-announcer" class="sr-only" aria-live="polite"></div>
                </div>

                <div
                    class="relative rounded-xl border border-slate-200 bg-slate-500/5 p-4 sm:p-6 dark:border-slate-800"
                >
                    <!-- High-Science Blueprint Framing Calibration Marks -->
                    <div
                        class="pointer-events-none absolute top-0 left-0 -translate-x-1.5 -translate-y-1.5 font-mono text-xs text-slate-400 select-none dark:text-slate-600"
                    >
                        +
                    </div>
                    <div
                        class="pointer-events-none absolute top-0 right-0 translate-x-1.5 -translate-y-1.5 font-mono text-xs text-slate-400 select-none dark:text-slate-600"
                    >
                        +
                    </div>
                    <div
                        class="pointer-events-none absolute bottom-0 left-0 -translate-x-1.5 translate-y-1.5 font-mono text-xs text-slate-400 select-none dark:text-slate-600"
                    >
                        +
                    </div>
                    <div
                        class="pointer-events-none absolute right-0 bottom-0 translate-x-1.5 translate-y-1.5 font-mono text-xs text-slate-400 select-none dark:text-slate-600"
                    >
                        +
                    </div>

                    <div
                        class="absolute -top-3 left-4 bg-(--bg-main) px-2 font-mono text-[9px] tracking-widest text-(--accent) uppercase"
                    >
                        [ SYS.LOG_MATRIX // ACTIVE ]
                    </div>
                    <div
                        class="absolute right-4 -bottom-3 bg-(--bg-main) px-2 font-mono text-[9px] tracking-widest text-slate-400 uppercase dark:text-slate-600"
                    >
                        REF_GRID: 50.84.11
                    </div>

                    <div class="grid gap-8 md:grid-cols-2" id="logs-grid">
                        {
                            postsWithReadingTime.map((post: any, i: number) => (
                                <a
                                    href={`/transmissions/${post.id}/`}
                                    data-astro-prefetch="hover"
                                    data-tags={post.data.tags ? post.data.tags.join(',') : ''}
                                    class:list={[
                                        'bento-card blog-post-card group relative block overflow-hidden transition-all active:scale-[0.99]',
                                        {
                                            'md:col-span-2 md:grid md:grid-cols-2 md:items-center md:gap-8':
                                                i === 0,
                                            'content-visibility-auto-post-card': i >= 2,
                                        },
                                    ]}
                                >
                                    {post.data.heroImage ? (
                                        <div
                                            class:list={[
                                                'bento-card-inner',
                                                i !== 0 ? 'mb-4' : 'mb-4 md:mb-0 md:h-full',
                                            ]}
                                        >
                                            {/* ⚡ Bolt: Optimize LCP by eager loading the first image (above the fold) with high priority */}
                                            <Image
                                                width={720}
                                                height={360}
                                                src={post.data.heroImage}
                                                alt=""
                                                class:list={[
                                                    'w-full object-cover transition-transform duration-300 group-hover:scale-105 group-focus-visible:scale-105',
                                                    i === 0
                                                        ? 'h-48 md:h-full md:min-h-[300px]'
                                                        : 'h-48',
                                                ]}
                                                loading={i === 0 ? 'eager' : 'lazy'}
                                                fetchpriority={i === 0 ? 'high' : 'auto'}
                                            />
                                        </div>
                                    ) : (
                                        <div
                                            class:list={[
                                                'bento-card-inner relative flex items-center justify-center overflow-hidden bg-slate-100 dark:bg-slate-900',
                                                i !== 0
                                                    ? 'mb-4 h-48'
                                                    : 'mb-4 h-48 md:mb-0 md:h-full md:min-h-[300px]',
                                            ]}
                                        >
                                            <div class="bg-grid-motif absolute inset-0 opacity-20 dark:opacity-50" />
                                            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,var(--accent-glow)_0%,transparent_70%)] opacity-50 dark:opacity-100" />
                                            <div class="absolute inset-0 m-4 rounded-lg border border-(--accent)/20" />
                                            <span class="z-10 font-mono text-7xl font-bold text-(--accent)/80 drop-shadow-lg">
                                                {post.data.title.charAt(0).toUpperCase()}
                                            </span>
                                        </div>
                                    )}
                                    <div
                                        class:list={[
                                            'flex flex-col justify-center',
                                            i === 0 ? 'md:p-2' : '',
                                        ]}
                                    >
                                        <div class="mb-3 font-mono text-[10px] tracking-widest text-(--accent)">
                                            LOG_
                                            {String(postsWithReadingTime.length - i).padStart(
                                                3,
                                                '0'
                                            )}
                                        </div>
                                        <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-(--text-secondary)">
                                            <FormattedDate
                                                date={post.data.pubDate}
                                                format="technical"
                                            />
                                            {post.readingTime && (
                                                <>
                                                    <span
                                                        aria-hidden="true"
                                                        class="text-slate-300 dark:text-slate-700"
                                                    >
                                                        |
                                                    </span>
                                                    <span class="font-mono text-xs">
                                                        {post.readingTime}
                                                    </span>
                                                </>
                                            )}
                                            {post.data.tags && post.data.tags.length > 0 && (
                                                <>
                                                    <span
                                                        aria-hidden="true"
                                                        class="text-slate-300 dark:text-slate-700"
                                                    >
                                                        |
                                                    </span>
                                                    <span class="rounded bg-(--accent)/10 px-2 py-0.5 text-[10px] font-bold tracking-widest text-(--accent) uppercase">
                                                        {post.data.tags[0]}
                                                    </span>
                                                </>
                                            )}
                                        </div>
                                        <h2
                                            class:list={[
                                                'font-bold tracking-tight text-balance text-slate-900 transition-colors group-hover:text-(--accent) group-focus-visible:text-(--accent) dark:text-white',
                                                i === 0 ? 'text-2xl sm:text-3xl' : 'text-xl',
                                            ]}
                                        >
                                            {post.data.title}
                                        </h2>
                                        <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                            {post.data.description}
                                        </p>
                                        <div class="mt-4 h-6 overflow-hidden">
                                            <span class="inline-block -translate-x-4 text-sm font-bold text-(--accent) opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                                                Read Transmission &rarr;
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Empty State UI -->
                <div id="search-empty-state" class="hidden py-20 text-center" aria-hidden="true">
                    <div
                        class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-slate-100 text-slate-400 dark:bg-slate-800 dark:text-slate-500"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
                            ></path></svg
                        >
                    </div>
                    <h3 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">
                        No transmissions found
                    </h3>
                    <p class="mx-auto max-w-sm text-sm text-slate-500 dark:text-slate-400">
                        Try adjusting your search parameters to find what you're looking for.
                    </p>
                    <button
                        id="clear-filters-btn"
                        aria-label="Clear all search filters"
                        class="mt-4 cursor-pointer rounded-md bg-(--accent) px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-600 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:focus-visible:ring-offset-(--bg-main)"
                    >
                        Clear Filters
                    </button>
                </div>
            </section>
        </main>
        <Footer />

        <script>
            // Client-side filtering logic with state retention & hotkey focus
            let searchAbortController: AbortController | null = null;
            let replaceStateTimeout: number | undefined;
            let reticleRafId: number | null = null;

            const setupSearch = () => {
                const searchInput = document.getElementById('search-logs') as HTMLInputElement;
                const cards = document.getElementsByClassName('blog-post-card');
                const emptyState = document.getElementById('search-empty-state');
                const announcer = document.getElementById('search-announcer');
                const tabs = document.getElementsByClassName('filter-tab');

                if (!searchInput) return;

                // Abort any existing search listeners
                if (searchAbortController) {
                    searchAbortController.abort();
                }
                searchAbortController = new AbortController();
                const { signal } = searchAbortController;

                // ⚡ Bolt: Cache expensive DOM text extraction to avoid redundant parsing on every keystroke
                const cachedCardsData = Array.from(cards).map((card) => {
                    const htmlCard = card as HTMLElement;
                    const titleElement = htmlCard.querySelector('h2');
                    const descElement = htmlCard.querySelector('p');
                    return {
                        element: htmlCard,
                        titleElement,
                        descElement,
                        originalTitleHTML: titleElement ? titleElement.innerHTML : '',
                        originalDescHTML: descElement ? descElement.innerHTML : '',
                        tags: htmlCard.dataset.tags?.toLowerCase().split(',') || [],
                        text: htmlCard.textContent?.toLowerCase() || '',
                    };
                });

                let activeTag = 'all';

                const highlightQuery = (term: string) => {
                    const hasHighlightAPI = typeof CSS !== 'undefined' && (CSS as any).highlights;

                    if (hasHighlightAPI) {
                        (CSS as any).highlights.delete('search-match');
                    } else {
                        // Reset fallback elements
                        cachedCardsData.forEach(({ titleElement, descElement, originalTitleHTML, originalDescHTML }) => {
                            if (titleElement) titleElement.innerHTML = originalTitleHTML;
                            if (descElement) descElement.innerHTML = originalDescHTML;
                        });
                    }

                    if (!term) return;

                    const words = term.split(/\s+/).filter(Boolean);
                    if (words.length === 0) return;

                    const visibleCards = cachedCardsData.filter(({ element }) => element.style.display !== 'none');

                    if (hasHighlightAPI) {
                        const ranges: Range[] = [];
                        visibleCards.forEach(({ titleElement, descElement }) => {
                            [titleElement, descElement].forEach(el => {
                                if (!el) return;
                                const walk = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
                                let node: Node | null;
                                while (node = walk.nextNode()) {
                                    const textContent = node.textContent?.toLowerCase() || '';
                                    words.forEach(word => {
                                        let startPos = 0;
                                        while ((startPos = textContent.indexOf(word.toLowerCase(), startPos)) !== -1) {
                                            const range = new Range();
                                            range.setStart(node as Node, startPos);
                                            range.setEnd(node as Node, startPos + word.length);
                                            ranges.push(range);
                                            startPos += word.length;
                                        }
                                    });
                                }
                            });
                        });

                        if (ranges.length > 0) {
                            const searchHighlight = new (window as any).Highlight(...ranges);
                            (CSS as any).highlights.set('search-match', searchHighlight);
                        }
                    } else {
                        // Fallback for browsers that do not support the Custom Highlight API
                        visibleCards.forEach(({ titleElement, descElement }) => {
                            [titleElement, descElement].forEach(el => {
                                if (!el) return;
                                const walk = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
                                const textNodes: Node[] = [];
                                let node: Node | null;
                                while (node = walk.nextNode()) {
                                    textNodes.push(node);
                                }

                                textNodes.forEach(textNode => {
                                    const text = textNode.textContent || '';
                                    const escapedWords = words.map(w => w.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&'));
                                    const regex = new RegExp(`(${escapedWords.join('|')})`, 'gi');

                                    if (regex.test(text)) {
                                        const tempSpan = document.createElement('span');
                                        tempSpan.innerHTML = text.replace(regex, '<mark class="search-match-fallback">$1</mark>');

                                        const parent = textNode.parentNode;
                                        if (parent) {
                                            while (tempSpan.firstChild) {
                                                parent.insertBefore(tempSpan.firstChild, textNode);
                                            }
                                            parent.removeChild(textNode);
                                        }
                                    }
                                });
                            });
                        });
                    }
                };

                // Function to perform combined filtering
                const filterPosts = () => {
                    const term = searchInput.value.toLowerCase();
                    let visibleCount = 0;

                    cachedCardsData.forEach(({ element, tags, text }) => {
                        const matchesSearch = text.includes(term);
                        const matchesTag = activeTag === 'all' || tags.includes(activeTag);

                        if (matchesSearch && matchesTag) {
                            element.style.display = '';
                            visibleCount++;
                        } else {
                            element.style.display = 'none';
                        }
                    });

                    // Update highlights
                    highlightQuery(term);

                    if (emptyState) {
                        if (visibleCount === 0) {
                            emptyState.classList.remove('hidden');
                            emptyState.setAttribute('aria-hidden', 'false');
                        } else {
                            emptyState.classList.add('hidden');
                            emptyState.setAttribute('aria-hidden', 'true');
                        }
                    }

                    if (announcer) {
                        announcer.textContent =
                            term || activeTag !== 'all'
                                ? `Found ${visibleCount} transmission${visibleCount === 1 ? '' : 's'}.`
                                : '';
                    }
                };

                const updateSearchState = (term: string, tag: string) => {
                    sessionStorage.setItem('blog-search-term', term);
                    sessionStorage.setItem('blog-search-tag', tag);

                    clearTimeout(replaceStateTimeout);
                    replaceStateTimeout = setTimeout(() => {
                        const url = new URL(window.location.href);
                        if (term) {
                            url.searchParams.set('q', term);
                        } else {
                            url.searchParams.delete('q');
                        }
                        if (tag && tag !== 'all') {
                            url.searchParams.set('tag', tag);
                        } else {
                            url.searchParams.delete('tag');
                        }
                        window.history.replaceState(null, '', url.pathname + url.search);
                    }, 300) as any;
                };

                // Check for URL query parameter first, then sessionStorage, then default to empty
                const urlParams = new URLSearchParams(window.location.search);
                const queryParam = urlParams.get('q');
                const sessionSearch = sessionStorage.getItem('blog-search-term');
                const initialTerm = queryParam !== null ? queryParam : sessionSearch || '';

                const tagParam = urlParams.get('tag');
                const sessionTag = sessionStorage.getItem('blog-search-tag');
                const initialTag = tagParam !== null ? tagParam : sessionTag || 'all';

                activeTag = initialTag;
                if (initialTerm) {
                    searchInput.value = initialTerm;
                }

                // Setup tabs active state on load
                Array.from(tabs).forEach((t) => {
                    const htmlT = t as HTMLElement;
                    if (htmlT.dataset.filter === activeTag) {
                        htmlT.classList.add('active');
                        htmlT.setAttribute('aria-pressed', 'true');
                    } else {
                        htmlT.classList.remove('active');
                        htmlT.setAttribute('aria-pressed', 'false');
                    }
                });

                filterPosts();

                // ⚡ Bolt: Debounce search input to prevent redundant layout recalcs on every keystroke
                const debounce = (fn: Function, ms = 200) => {
                    let timeoutId: ReturnType<typeof setTimeout>;
                    return function (this: any, ...args: any[]) {
                        clearTimeout(timeoutId);
                        timeoutId = setTimeout(() => fn.apply(this, args), ms);
                    };
                };

                const handleSearchInput = debounce((e: Event) => {
                    const term = (e.target as HTMLInputElement).value;
                    filterPosts();
                    updateSearchState(term, activeTag);
                }, 150);

                // Search Input event listener
                searchInput.addEventListener('input', handleSearchInput, { signal });

                // Tabs event listener
                Array.from(tabs).forEach((tab) => {
                    tab.addEventListener(
                        'click',
                        (e) => {
                            const clickedTag =
                                (e.currentTarget as HTMLElement).dataset.filter || 'all';
                            activeTag = clickedTag;

                            // Update tabs styles
                            Array.from(tabs).forEach((t) => {
                                const htmlT = t as HTMLElement;
                                if (htmlT.dataset.filter === activeTag) {
                                    htmlT.classList.add('active');
                                    htmlT.setAttribute('aria-pressed', 'true');
                                } else {
                                    htmlT.classList.remove('active');
                                    htmlT.setAttribute('aria-pressed', 'false');
                                }
                            });

                            filterPosts();
                            updateSearchState(searchInput.value, activeTag);
                        },
                        { signal }
                    );
                });

                // Clear Filters event listener
                const clearFiltersBtn = document.getElementById('clear-filters-btn');
                if (clearFiltersBtn) {
                    clearFiltersBtn.addEventListener(
                        'click',
                        () => {
                            searchInput.value = '';
                            activeTag = 'all';

                            // Update tabs styles
                            Array.from(tabs).forEach((t) => {
                                const htmlT = t as HTMLElement;
                                if (htmlT.dataset.filter === activeTag) {
                                    htmlT.classList.add('active');
                                    htmlT.setAttribute('aria-pressed', 'true');
                                } else {
                                    htmlT.classList.remove('active');
                                    htmlT.setAttribute('aria-pressed', 'false');
                                }
                            });

                            filterPosts();
                            updateSearchState('', 'all');
                            searchInput.focus();
                        },
                        { signal }
                    );
                }

                // Bind dynamic view-transition-names to clicked card components
                Array.from(cards).forEach((card) => {
                    card.addEventListener(
                        'click',
                        () => {
                            const titleEl = card.querySelector('h2') as HTMLElement | null;
                            const imgEl = card.querySelector(
                                'img, .bento-card-inner'
                            ) as HTMLElement | null;
                            if (titleEl) {
                                titleEl.style.setProperty(
                                    'view-transition-name',
                                    'active-post-title'
                                );
                            }
                            if (imgEl) {
                                imgEl.style.setProperty('view-transition-name', 'active-post-img');
                            }
                        },
                        { signal }
                    );
                });

                // Global Forward Slash / Hotkey Listener
                const handleHotkey = (e: KeyboardEvent) => {
                    // Ignore if typing in another input/textarea
                    if (
                        document.activeElement &&
                        ['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)
                    ) {
                        return;
                    }
                    if (e.key === '/') {
                        e.preventDefault();
                        searchInput.focus();
                        searchInput.placeholder = '[ SYSTEM CAPTURE ACTIVE ]';
                    }
                };

                window.addEventListener('keydown', handleHotkey, { signal });

                searchInput.addEventListener(
                    'blur',
                    () => {
                        searchInput.placeholder = '"Search archives..."';
                    },
                    { signal }
                );

                // Kinetic Satellite Dish Mouse Tracking Parallax
                const reticle = document.getElementById('reticle-bg');
                let mouseX = 0;
                let mouseY = 0;

                const updateReticleParallax = () => {
                    const x = (mouseX - window.innerWidth / 2) / (window.innerWidth / 2);
                    const y = (mouseY - window.innerHeight / 2) / (window.innerHeight / 2);

                    const moveX = x * 8; // max 8px
                    const moveY = y * 8; // max 8px
                    const rotate = x * 5; // max 5deg

                    if (reticle) {
                        reticle.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) rotate(${rotate}deg)`;
                    }
                    reticleRafId = null;
                };

                const handleReticleParallax = (e: MouseEvent) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;
                    if (!reticleRafId) {
                        reticleRafId = window.requestAnimationFrame(updateReticleParallax);
                    }
                };

                window.addEventListener('mousemove', handleReticleParallax, { signal });
            };

            // Run strictly on Astro page navigation / page load
            document.addEventListener('astro:page-load', setupSearch);

            // Cleanup event listeners and timeouts when navigating away
            document.addEventListener('astro:before-preparation', () => {
                if (searchAbortController) {
                    searchAbortController.abort();
                    searchAbortController = null;
                }
                clearTimeout(replaceStateTimeout);
                if (reticleRafId) {
                    window.cancelAnimationFrame(reticleRafId);
                    reticleRafId = null;
                }
                if (typeof CSS !== 'undefined' && (CSS as any).highlights) {
                    (CSS as any).highlights.delete('search-match');
                }
            });
        </script>
    </body>
</html>
