                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 9"
                        opacity="0.15"></path>

                    <!-- Concentric dashed calibration circles -->
                    <circle
                        cx="100"
                        cy="100"
                        r="90"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="2 8"
                        opacity="0.4"></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="80"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="3 3"></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="60"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="6 6"></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="30"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 3"
                        opacity="0.5"></circle>

                    <!-- Calibration axes -->
                    <line
                        x1="10"
                        y1="100"
                        x2="190"
                        y2="100"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="2 4"></line>
                    <line
                        x1="100"
                        y1="10"
                        x2="100"
                        y2="190"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="2 4"></line>

                    <!-- Compass Ticks -->
                    <line x1="100" y1="10" x2="100" y2="15" stroke="currentColor" stroke-width="1"
                    ></line>
                    <line x1="100" y1="185" x2="100" y2="190" stroke="currentColor" stroke-width="1"
                    ></line>
                    <line x1="10" y1="100" x2="15" y2="100" stroke="currentColor" stroke-width="1"
                    ></line>
                    <line x1="185" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="1"
                    ></line>

                    <!-- Outer diamond projection bounds -->
                    <path
                        d="M 100 20 L 180 100 L 100 180 L 20 100 Z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 5"></path>

                    <!-- Tilted Group (Rotate by -30deg for dynamic directional aim) -->
                    <g transform="rotate(-30 100 100)">
                        <!-- Parabolic Reflector Dish -->
                        <path
                            d="M 45,85 Q 100,135 155,85"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.6"></path>
                        <path
                            d="M 45,88 Q 100,138 155,88"
                            fill="none"
                            stroke="currentColor"
