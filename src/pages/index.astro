---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body class="pt-24">
        <Header />
        <main id="main-content" class="layout-container space-y-24">
            <!-- Hero Section: The Boring Section -->
            <section class="mt-12 max-w-3xl">
                <h1
                    class="mb-6 text-4xl leading-tight font-bold text-slate-900 md:text-5xl lg:text-6xl dark:text-white"
                >
                    Hey! I'm Dhaatrik. <br />
                    <span
                        class="mt-2 block text-2xl font-medium text-slate-500 md:text-3xl dark:text-[var(--text-secondary)]"
                        >First-Principles Thinker.</span
                    >
                </h1>
                <p
                    class="mb-8 text-lg leading-relaxed text-slate-600 md:text-xl dark:text-[var(--text-secondary)]"
                >
                    I'm a 26-year-old entrepreneur and developer from India, building the next
                    generation of tech-driven solutions. I believe that best products come from
                    understanding the absolute fundamentals.
                </p>
                <div class="flex gap-4">
                    <a
                        href="/about"
                        class="rounded-lg bg-[var(--accent)] px-6 py-3 font-medium text-white transition-all hover:shadow-[0_0_20px_var(--accent-glow)] focus-visible:shadow-[0_0_20px_var(--accent-glow)]"
                    >
                        Read My Journey
                    </a>
                    <a
                        href="mailto:dhaatrikchowdhury@gmail.com"
                        class="rounded-lg border border-slate-200 bg-slate-100 px-6 py-3 font-medium text-slate-900 transition-all hover:bg-slate-200 focus-visible:bg-slate-200 dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:focus-visible:bg-white/10"
                    >
                        Let's Chat
                    </a>
                </div>
            </section>

            <!-- Projects Section: The Pretty-Good Stuffs -->
            <section class="mb-16">
                <div class="mb-10">
                    <h2 class="mb-2 text-3xl font-bold text-slate-900 dark:text-white">
                        The Pretty-Good (Cool) Stuffs
                    </h2>
                    <p class="text-slate-600 dark:text-[var(--text-secondary)]">
                        Things I'm building, hacking on, and turning into reality.
                    </p>
                </div>

                <div class="bento-grid">
                    {
                        projects.map((project) => (
                            <article class="bento-card group flex flex-col justify-between">
                                <div>
                                    <div class="mb-4 flex items-start justify-between">
                                        <h3 class="text-2xl font-bold text-slate-900 transition-colors group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white">
                                            {project.data.title}
                                        </h3>
                                        {project.data.githubUrl && (
                                            <a
                                                href={project.data.githubUrl}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label="View Project on GitHub"
                                                class="text-slate-400 transition-colors hover:text-slate-900 focus-visible:text-slate-900 dark:text-[var(--text-secondary)] dark:hover:text-white dark:focus-visible:text-white"
                                            >
                                                <span class="sr-only">GitHub</span>
                                                <svg
                                                    viewBox="0 0 16 16"
                                                    aria-hidden="true"
                                                    width="24"
                                                    height="24"
                                                >
                                                    <path
                                                        fill="currentColor"
                                                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                                                    />
                                                </svg>
                                            </a>
                                        )}
                                    </div>
                                    <p class="mb-6 text-sm leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                                        {project.data.description}
                                    </p>
                                </div>

                                {project.data.progress && (
                                    <div class="mt-4 border-t border-slate-200 pt-4 dark:border-white/5">
                                        <span class="text-xs font-semibold tracking-wider text-[var(--accent)] uppercase">
                                            Current Progress
                                        </span>
                                        <p class="mt-1 text-sm font-medium text-slate-600 dark:text-[var(--text-secondary)]">
                                            {project.data.progress}
                                        </p>
                                    </div>
                                )}
                            </article>
                        ))
                    }
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>
