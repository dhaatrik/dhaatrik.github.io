---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import { techGroups, type TechIcon } from '../data/techStack';
import { getReadingTime } from '../utils/readingTime';
import { getPainLevelLabel, parseTelemetry } from '../data/status';

type ProjectEntry = CollectionEntry<'projects'>;
type BlogEntry = CollectionEntry<'blog'>;

// ⚡ Bolt: Fetch collections concurrently to reduce total wait time during SSG
const [projects, posts] = await Promise.all([
    getCollection('projects').then((raw: CollectionEntry<'projects'>[]) =>
        raw
            .sort(
                (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
                    a.data.order - b.data.order
            )
            .slice(0, 4)
    ),
    getCollection('blog').then((raw: CollectionEntry<'blog'>[]) =>
        raw
            .sort(
                (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
                    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
            )
            .slice(0, 3)
    ),
]);

// Premium Founder Lineup
const lineupNames = ['React', 'TypeScript', 'Python', 'TensorFlow'];
const premiumLineup = lineupNames
    .map((name) => {
        for (const group of Object.values(techGroups)) {
            const found = group.find((tech) => tech.name === name);
            if (found) return found;
        }
        return null;
    })
    .filter((t): t is TechIcon => t !== null);

// FAQ and WebSite JSON-LD schemas for AEO/GEO
const faqSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
        {
            '@type': 'Question',
            name: 'Who is Dhaatrik Chowdhury?',
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'Dhaatrik Chowdhury is an Entrepreneur and AI Engineer from India with approximately 9 years of experience tutoring students in physics and mathematics. He has guided roughly 200 students across school classrooms, coaching centers, one-on-one mentoring, and online sessions. He is the founder of DBS Classes, a free YouTube channel for physics and mathematics education.',
            },
        },
        {
            '@type': 'Question',
            name: 'What is DBS Classes?',
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'DBS Classes stands for "Dhaatu Bhaiyaa\'s Classes" — a free YouTube channel for physics and mathematics education founded on October 31, 2022 by Dhaatrik Chowdhury. "Dhaatu" is his nickname and "Bhaiyaa" is the Hindi word for big brother. The channel produced 20 educational video lessons covering topics like dimensional analysis, trigonometry, and kinematics.',
            },
        },
        {
            '@type': 'Question',
            name: "What is Dhaatrik's teaching philosophy?",
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'Dhaatrik\'s teaching philosophy is built on first-principles thinking, using everyday observations (kitchen thermodynamics, bus wheel mechanics, open-sky optics) to make physics and mathematics intuitive. His core axiom is: "Education Is Not Free BUT KNOWLEDGE IS FREE" — shared with zero terms and conditions. He uses a sibling-centric tutoring model where students are treated as younger siblings rather than subordinates.',
            },
        },
        {
            '@type': 'Question',
            name: 'What projects has Dhaatrik built?',
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'Dhaatrik has built several notable projects: DeltaV Lab (real-time orbital mechanics simulation), Vellor (free MIT-licensed offline tutoring-management PWA with client-side encrypted storage), FuelDrop (high-concurrency fuel delivery platform), and The Infinite Intelligence (multi-agent AI debate system). He works with React, TypeScript, Python, and TensorFlow.',
            },
        },
    ],
}).replace(/</g, '\\u003c');

const webSiteSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Dhaatrik Chowdhury',
    url: 'https://dhaatrik.github.io',
    description:
        'Honest engineering transmissions from Dhaatrik Chowdhury — mission logs of what was built, what broke, and what was learned.',
    author: {
        '@type': 'Person',
        name: 'Dhaatrik Chowdhury',
    },
}).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={SITE_TITLE}
            description={SITE_DESCRIPTION}
            keywords={[
                'Dhaatrik Chowdhury',
                'AI Engineer',
                'engineering diary',
                'mission logs',
                'DBS Classes',
                'physics tutor',
                'first-principles teaching',
                'India',
            ]}
        />
        <!-- FAQ Structured Data for AEO/GEO -->
        <script is:inline type="application/ld+json" set:html={faqSchema} />
        <!-- WebSite Structured Data -->
        <script is:inline type="application/ld+json" set:html={webSiteSchema} />
    </head>
    <body class="bg-grid-motif relative pt-24">
        <Header />
        <main
            id="main-content"
            tabindex="-1"
            class="flex flex-col gap-(--section-gap-mobile) py-(--section-gap-mobile) md:gap-(--section-gap-desktop) md:py-(--section-gap-desktop)"
        >
            <!-- Hero Section: The Boring Section -->
            <section
                id="hero-section"
                class="layout-container relative flex min-h-[60vh] w-full flex-col justify-center overflow-hidden pt-24 pb-36 md:pt-32 md:pb-32"
            >
                <!-- Parallax Background Element -->
                <div class="parallax-hero-bg blueprint-reveal flex items-center justify-center">
                    <div
                        class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-25 select-none dark:opacity-20"
                    >
                        <img
                            src="/logo_dark.svg"
                            alt=""
                            class="h-[75%] w-[75%] max-w-[750px] object-contain dark:hidden"
                            loading="eager"
                            fetchpriority="high"
                        />
                        <img
                            src="/logo_light.svg"
                            alt=""
                            class="hidden h-[75%] w-[75%] max-w-[750px] object-contain dark:block"
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>
                    <svg
                        viewBox="0 0 1000 1000"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        class="h-[140%] w-[140%] max-w-none text-slate-400 opacity-40 dark:text-slate-500"
                        aria-hidden="true"
                    >
                        <!-- Concentric circles -->
                        <circle cx="500" cy="500" r="150" stroke-dasharray="4 8"></circle>
                        <circle cx="500" cy="500" r="280"></circle>
                        <circle cx="500" cy="500" r="400" stroke-dasharray="16 16"></circle>
                        <!-- Diagonal axis lines -->
                        <line x1="100" y1="100" x2="900" y2="900" stroke-dasharray="2 4"></line>
                        <line x1="900" y1="100" x2="100" y2="900" stroke-dasharray="2 4"></line>
                        <!-- Horizontal & Vertical lines -->
                        <line x1="500" y1="0" x2="500" y2="1000"></line>
                        <line x1="0" y1="500" x2="1000" y2="500"></line>
                    </svg>
                </div>
                <div class="relative z-10 flex w-full max-w-3xl flex-col justify-center">
                    <div
                        class="reveal-on-scroll mb-4 inline-flex w-fit items-center gap-2 rounded-full border border-green-500/30 bg-green-500/10 px-3 py-1 text-xs font-medium text-green-600 sm:text-sm dark:border-green-400/30 dark:bg-green-400/10 dark:text-green-400"
                        data-last-updated="2026-06-18"
                    >
                        <span class="relative flex h-2 w-2 shrink-0">
                            <span
                                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75 dark:bg-green-400"
                            ></span>
                            <span
                                class="relative inline-flex h-2 w-2 rounded-full bg-green-500 dark:bg-green-400"
                            ></span>
                        </span>
                        FOCUS: RELEASE_V4.0 // CONFIDENCE: MAXIMUM // STATUS: ONLINE
                    </div>
                    <h1
                        class="type-display reveal-on-scroll mb-6 text-slate-900 dark:text-white"
                        data-reveal-delay="100"
                    >
                        <span id="dynamic-greeting">Hey!</span> Buddy. <br />
                        <span
                            id="identity-rotator"
                            role="status"
                            aria-label="Dhaatrik's professional identity"
                            aria-live="off"
                            class="mt-2 block min-h-[1.5em] bg-linear-to-r from-blue-600 to-purple-500 bg-clip-text font-mono text-2xl font-bold text-transparent md:text-3xl dark:from-blue-400 dark:to-purple-400"
                            data-identities='["First-Principles Thinker.", "AI Systems Architect.", "Physics Tutor to 200+ Students.", "Aerospace Enthusiast.", "Open-Source Builder."]'
                            >First-Principles Thinker.</span
                        >
                    </h1>
                    <script is:inline>
                        const hour = new Date().getHours();
                        let greeting = 'Good evening,';
                        if (hour < 12) greeting = 'Good morning,';
                        else if (hour < 18) greeting = 'Good afternoon,';
                        const el = document.getElementById('dynamic-greeting');
                        if (el) el.innerText = greeting;
                    </script>
                    <p
                        class="type-body-lg reveal-on-scroll mb-8 text-slate-600 dark:text-(--text-secondary)"
                        data-reveal-delay="200"
                    >
                        I'm Dhaatrik Chowdhury — just a human from India, building stuffs, and this
                        site is my honest engineering diary. Not a polished portfolio. A log of what
                        I shipped, what broke, and what I wish I'd known sooner. I build from first
                        principles because shortcuts always come back to bite you.
                    </p>

                    <!-- CTA Hierarchy -->
                    <div
                        class="reveal-on-scroll flex flex-wrap items-center gap-6"
                        data-reveal-delay="300"
                    >
                        <a
                            href="/personnel"
                            data-astro-prefetch="hover"
                            class="magnetic-target group transition-spring inline-flex items-center gap-2 rounded-full bg-(--accent-button-bg) px-6 py-2.5 font-medium text-white shadow-[0_0_15px_rgba(59,130,246,0.4)] hover:shadow-[0_0_25px_rgba(59,130,246,0.6)] focus-visible:scale-105 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:focus-visible:ring-offset-(--bg-main)"
                        >
                            Read My Story
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="transition-transform group-hover:translate-x-1"
                                aria-hidden="true"
                            >
                                <path d="M5 12h14"></path>
                                <path d="m12 5 7 7-7 7"></path>
                            </svg>
                        </a>

                        <div class="flex items-center gap-3">
                            <!-- X/Twitter Link -->
                            <a
                                href="https://x.com/dhaatrik"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="magnetic-target group transition-spring flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 hover:border-(--accent) hover:text-(--accent) dark:border-white/10 dark:bg-white/5 dark:text-slate-400 dark:hover:border-white/20 dark:hover:text-white"
                                aria-label="Follow on X (Twitter) (opens in a new tab)"
                                title="Follow on X"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                    width="14"
                                    height="14"
                                    fill="currentColor"
                                    ><path
                                        d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"
                                    ></path></svg
                                >
                            </a>
                            <!-- GitHub Link -->
                            <a
                                href="https://github.com/dhaatrik"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="magnetic-target group transition-spring flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 hover:border-(--accent) hover:text-(--accent) dark:border-white/10 dark:bg-white/5 dark:text-slate-400 dark:hover:border-white/20 dark:hover:text-white"
                                aria-label="View GitHub (opens in a new tab)"
                                title="View GitHub"
                            >
                                <svg
                                    viewBox="0 0 16 16"
                                    aria-hidden="true"
                                    width="16"
                                    height="16"
                                    fill="currentColor"
                                    ><path
                                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                                    ></path></svg
                                >
                            </a>
                            <!-- LinkedIn Link -->
                            <a
                                href="https://linkedin.com/in/dhaatrik"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="magnetic-target group transition-spring flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 hover:border-(--accent) hover:text-(--accent) dark:border-white/10 dark:bg-white/5 dark:text-slate-400 dark:hover:border-white/20 dark:hover:text-white"
                                aria-label="View LinkedIn (opens in a new tab)"
                                title="View LinkedIn"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                    width="14"
                                    height="14"
                                    fill="currentColor"
                                    ><path
                                        d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                                    ></path></svg
                                >
                            </a>
                        </div>
                    </div>

                    <!-- Built With Badges -->
                    <div
                        class="reveal-on-scroll mt-8 flex flex-col items-start gap-3 opacity-80"
                        data-reveal-delay="400"
                    >
                        <span
                            class="text-xs font-semibold tracking-wider text-slate-500 uppercase dark:text-slate-400"
                        >
                            Building primarily with:
                        </span>
                        <div class="flex flex-wrap items-center gap-3">
                            {
                                premiumLineup.map((tech) => (
                                    <img
                                        src={tech.src}
                                        alt={tech.name}
                                        title={tech.name}
                                        class="h-6 rounded-sm opacity-80 transition-opacity hover:opacity-100 dark:opacity-70 dark:hover:opacity-100"
                                        loading="eager"
                                        fetchpriority="high"
                                    />
                                ))
                            }
                        </div>
                    </div>
                </div>

                <!-- Scroll Telemetry Indicator -->
                <div
                    class="scroll-telemetry-container pointer-events-none fixed right-0 bottom-4 left-0 z-20 flex flex-col items-center gap-2 select-none md:bottom-6"
                >
                    <div
                        class="flex items-center gap-2 rounded-full border border-(--accent)/15 bg-slate-950/5 px-3.5 py-1.5 shadow-[0_0_15px_var(--accent-glow)] backdrop-blur-md dark:border-white/10 dark:bg-white/5"
                    >
                        <span class="relative flex h-1.5 w-1.5">
                            <span
                                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-(--accent) opacity-70"
                            ></span>
                            <span
                                class="relative inline-flex h-1.5 w-1.5 rounded-full bg-(--accent)"
                            ></span>
                        </span>
                        <span
                            id="scroll-telemetry-text"
                            class="font-mono text-[9px] font-bold tracking-widest text-slate-500 uppercase dark:text-slate-400"
                        >
                            SCROLL TO INITIATE
                        </span>
                    </div>
                    <div class="flex flex-col items-center opacity-85">
                        <div class="mb-1 h-4 w-px bg-linear-to-b from-(--accent)/40 to-transparent">
                        </div>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="9"
                            height="9"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="telemetry-pulse text-(--accent)"
                        >
                            <path d="M6 9l6 6 6-6"></path>
                        </svg>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="9"
                            height="9"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="telemetry-pulse -mt-1 text-(--accent)"
                            style="animation-delay: 0.3s;"
                        >
                            <path d="M6 9l6 6 6-6"></path>
                        </svg>
                    </div>
                </div>
                <div class="scroll-cue" aria-hidden="true">
                    <span class="scroll-cue-line"></span>
                    <span class="scroll-cue-label">scroll</span>
                </div>
            </section>

            <!-- Projects Section: Featured Engineering -->
            <section
                id="projects"
                class="layout-container content-visibility-auto-projects mb-0 pb-16"
            >
                <div class="reveal-on-scroll mb-10">
                    <h2 class="mb-2 text-3xl font-bold text-slate-900 dark:text-white">
                        Featured Engineering
                    </h2>
                    <p class="text-slate-600 dark:text-(--text-secondary)">
                        Things I'm building, abandoning, or still fixing at 2 AM.
                    </p>
                </div>

                <div class="bento-grid perspective-1000 reveal-stagger">
                    <!-- Current Focus Bento Card -->
                    <article
                        class="bento-card group bento-card-project relative flex cursor-pointer flex-col justify-between overflow-hidden transition-all duration-300 focus-within:shadow-[0_0_20px_var(--accent-glow)] hover:-translate-y-1 hover:shadow-[0_0_20px_var(--accent-glow)]"
                        data-popover-target="project-popover-currently-exploring"
                        role="button"
                        tabindex="0"
                        aria-expanded="false"
                        aria-controls="project-popover-currently-exploring"
                    >
                        <div class="hologram-overlay"></div>
                        <div class="relative z-10 flex h-full flex-col justify-between" data-tilt-z>
                            <div>
                                <div
                                    class="mb-4 flex min-w-0 items-center justify-between gap-4 border-b border-slate-200/50 pb-2 font-mono text-[9px] text-slate-400 dark:border-white/5 dark:text-slate-500"
                                >
                                    <div class="flex min-w-0 items-center gap-1.5">
                                        <span
                                            class="h-1.5 w-1.5 shrink-0 animate-pulse rounded-full bg-green-500"
                                        ></span>
                                        <span class="truncate"
                                            >STATUS: RESEARCH_ACTIVE // CORE: AGRI_BIO_TECH</span
                                        >
                                    </div>
                                    <span
                                        class="shrink-0 font-bold whitespace-nowrap text-(--accent)"
                                        >[ CORE ]</span
                                    >
                                </div>
                                <div class="mb-4 flex items-start justify-between">
                                    <h3
                                        class="text-2xl font-bold text-slate-900 transition-colors dark:text-white"
                                    >
                                        Currently Exploring
                                    </h3>
                                </div>
                                <p
                                    class="mb-6 text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                                >
                                    Investigating agricultural systems from first principles—soil
                                    chemistry, plant biology, and biotech (90%)—while allocating
                                    time to quantum mechanics, rocketry, and Behçet's Syndrome
                                    literature.
                                </p>
                            </div>
                            <div
                                class="flex items-center justify-between border-t border-slate-200/50 pt-4 font-mono text-[9px] text-slate-400 dark:border-white/5 dark:text-slate-500"
                            >
                                <span class="truncate">PROGRESS: ACTIVE_EXPLORATION</span>
                                <span class="text-xs transition-transform group-hover:translate-x-1"
                                    >→</span
                                >
                            </div>
                        </div>
                    </article>

                    {/* Currently Exploring popover details popup */}
                    <div
                        popover
                        id="project-popover-currently-exploring"
                        aria-labelledby="project-popover-title-currently-exploring"
                        class="premium-glass m-auto max-h-[85vh] w-[calc(100%-2rem)] max-w-xl rounded-2xl p-0 md:w-full"
                    >
                        <div
                            class="relative z-10 flex items-start justify-between border-b border-slate-100 p-5 sm:p-6 dark:border-white/5"
                        >
                            <div class="flex min-w-0 flex-col gap-1 pr-4">
                                <div class="flex flex-wrap items-center gap-2">
                                    <h3
                                        id="project-popover-title-currently-exploring"
                                        class="text-lg font-bold text-slate-900 sm:text-xl dark:text-white"
                                    >
                                        Currently Exploring
                                    </h3>
                                    <span
                                        class="inline-flex shrink-0 items-center rounded-full border border-(--accent)/35 bg-(--accent)/5 px-2 py-0.5 font-mono text-[9px] font-bold tracking-wider whitespace-nowrap text-(--accent) uppercase sm:text-[10px]"
                                    >
                                        EXPLORATION
                                    </span>
                                </div>
                                <p
                                    class="font-mono text-[9px] tracking-wider text-slate-400 uppercase sm:text-xs dark:text-slate-500"
                                >
                                    STATUS: RESEARCH_ACTIVE // CORE: AGRI_BIO_TECH
                                </p>
                            </div>
                            <button
                                aria-label="Close project description"
                                popovertarget="project-popover-currently-exploring"
                                popovertargetaction="hide"
                                class="mt-0.5 shrink-0 cursor-pointer rounded-sm p-1 text-slate-500 transition-colors hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none sm:mt-1 dark:hover:text-white dark:focus-visible:ring-offset-(--bg-main)"
                            >
                                <svg
                                    width="24"
                                    height="24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M18 6L6 18M6 6l12 12"></path>
                                </svg>
                            </button>
                        </div>

                        <div class="relative z-10 grow space-y-6 overflow-y-auto p-5 sm:p-6">
                            <div class="space-y-3">
                                <h4
                                    class="font-mono text-[10px] font-bold tracking-wider text-slate-400 uppercase dark:text-slate-500"
                                >
                                    // CURRENT ALLOCATION
                                </h4>
                                <p
                                    class="text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                                >
                                    Right now, my research time is divided into two distinct paths:
                                    90% is focused on demystifying agricultural science from first
                                    principles, and the remaining 10% is split between quantum
                                    mechanics, rocket propulsion chemistry, and offline AI-driven
                                    medical literature analysis.
                                </p>
                            </div>

                            <div
                                class="space-y-3 border-t border-slate-100 pt-4 dark:border-white/5"
                            >
                                <h4
                                    class="font-mono text-[10px] font-bold tracking-wider text-slate-400 uppercase dark:text-slate-500"
