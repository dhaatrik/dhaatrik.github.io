---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
import katex from 'katex';
import 'katex/dist/katex.min.css';

import { techGroups } from '../data/techStack';

// Library Tracking Data
const booksRead = 7;
const booksGoal = 52;
const readingProgress = Math.min(Math.round((booksRead / booksGoal) * 100), 100);

// Pre-render rocket equation using KaTeX
const rocketEquationHtml = katex.renderToString('\\Delta v = v_e \\ln \\frac{m_0}{m_f}', {
    displayMode: true,
    throwOnError: false,
});
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`About | ${SITE_TITLE}`}
            description="Learn more about Dhaatrik's journey and tech stack."
        />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <Header />
        <main
            id="main-content"
            tabindex="-1"
            class="relative flex grow flex-col gap-12 overflow-x-hidden py-12 md:gap-20 md:py-20"
        >
            <div
                id="reticle-bg"
                class="pointer-events-none absolute top-32 right-0 -z-10 text-slate-900 opacity-5 transition-transform duration-300 ease-out dark:text-white"
            >
                <svg
                    width="400"
                    height="400"
                    viewBox="0 0 200 200"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        d="M100 100 m-80,0 a80,80 0 1,0 160,0 a80,80 0 1,0 -160,0 M100 100 m-60,0 a60,60 0 1,0 120,0 a60,60 0 1,0 -120,0 M100 100 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 M20 100 h160 M100 20 v160"
                    ></path>
                </svg>
            </div>

            <section class="layout-container">
                <div
                    class="mb-16 flex flex-col items-center gap-8 md:flex-row-reverse md:items-start"
                >
                    <div
                        class="relative mx-auto w-full max-w-[260px] shrink-0 p-3 sm:max-w-[320px] md:mx-0 md:w-[320px]"
                    >
                        {/* Clinical blueprint borders and target marks */}
                        <div
                            class="pointer-events-none absolute inset-0 border border-dashed border-slate-200 dark:border-white/10"
                        >
                            {/* Corner target marks '+' */}
                            <span
                                class="absolute -top-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >
                            <span
                                class="absolute -top-1.5 -right-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >
                            <span
                                class="absolute -bottom-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >
                            <span
                                class="absolute -right-1.5 -bottom-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >

                            {/* Absolute layout text arrays along borders */}
                            <span
                                class="absolute top-1 left-2 font-mono text-[9px] font-bold tracking-widest text-slate-400 uppercase dark:text-slate-500"
                                >SPECIMEN_REF: 01</span
                            >
                            <span
                                class="absolute right-2 bottom-1 font-mono text-[9px] font-bold tracking-widest text-slate-400 uppercase dark:text-slate-500"
                                >DATA.CAP // 100%</span
                            >
                        </div>

                        <div
                            class="relative overflow-hidden rounded-lg bg-slate-100 dark:bg-black/40"
                        >
                            {/* Technical grid overlay */}
                            <div
                                class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(rgba(0,0,0,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.08)_1px,transparent_1px)] bg-size-[10px_10px] opacity-50 dark:bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)]"
                            >
                            </div>

                            <img
                                src="/me.jpeg"
                                alt="Dhaatrik"
                                loading="eager"
                                fetchpriority="high"
                                class="aspect-square w-full object-cover grayscale transition-all duration-500 hover:grayscale-0"
                            />
                        </div>
                    </div>
                    <div class="w-full md:w-[calc(100%-352px)]">
                        <h1
                            class="mb-2 text-4xl leading-tight font-bold tracking-tight text-balance text-slate-900 md:text-5xl dark:text-white"
                        >
                            About Dhaatrik
                        </h1>

                        <div
                            class="space-y-6 text-lg leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                        >
                            <p>
                                Dhaatrik Chowdhury is an engineer and entrepreneur driven by a
                                relentless curiosity for how the universe operates. He builds
                                robust, data-sovereign systems by stripping complex problems down to
                                their fundamental truths.
                            </p>

                            <div
                                class="mt-8 border-l-2 border-(--accent) pl-4 font-mono text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                            >
                                <div
                                    class="mb-2 text-xs font-bold tracking-wider text-slate-400 uppercase dark:text-slate-500"
                                >
                                    // OPERATIONAL PHILOSOPHY
                                </div>
                                <p>
                                    He chooses not to reinvent the wheel or build foundation models
                                    from scratch, but acts as an execution engine leveraging AI to
                                    build functional, data-sovereign systems.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="layout-container relative z-10">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div>
                                <h2
                                    class="mb-4 flex items-center gap-2 text-2xl font-bold tracking-tight text-slate-900 dark:text-white"
                                >
                                    <svg
                                        class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)"
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><rect x="4" y="4" width="16" height="16" rx="2" ry="2"
                                        ></rect><rect x="9" y="9" width="6" height="6"></rect><line
                                            x1="9"
                                            y1="1"
                                            x2="9"
                                            y2="4"></line><line x1="15" y1="1" x2="15" y2="4"
                                        ></line><line x1="9" y1="20" x2="9" y2="23"></line><line
                                            x1="15"
                                            y1="20"
                                            x2="15"
                                            y2="23"></line><line x1="20" y1="9" x2="23" y2="9"
                                        ></line><line x1="20" y1="14" x2="23" y2="14"></line><line
                                            x1="1"
                                            y1="9"
                                            x2="4"
                                            y2="9"></line><line x1="1" y1="14" x2="4" y2="14"
                                        ></line></svg
                                    >
                                    <span
                                        class="cypher-text"
                                        data-original="What Dhaatrik is Building"
                                        >What Dhaatrik is Building</span
                                    >
                                </h2>
                                <p
                                    class="leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                                >
                                    He is currently focused on the agriculture domain, working to
                                    integrate AI into the core fundamentals of farming to solve
                                    real-world problems. He also loves building tools for the
                                    community, like <a
                                        href="https://github.com/dhaatrik"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        aria-label="View Vellor on GitHub (opens in a new tab)"
                                        class="font-medium text-(--accent) decoration-dashed underline-offset-4 hover:underline focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:focus-visible:ring-offset-(--bg-main)"
                                        >Vellor</a
                                    >, an offline-first tool for independent educators.
                                </p>
                            </div>

                            <div class="mt-8 space-y-3">
                                <div
                                    class="flex items-center justify-between border-b border-slate-200/50 pb-2 font-mono text-[9px] tracking-wider dark:border-white/5"
                                >
                                    <span class="text-slate-400 uppercase dark:text-slate-500"
                                        >// ACTIVE FOCUS NODE</span
                                    >
                                    <span class="font-bold text-(--accent)">[ STATUS ]</span>
                                </div>
                                <ul
                                    class="space-y-2.5 font-mono text-[11px] text-slate-600 dark:text-(--text-secondary)"
                                >
                                    <li class="flex items-center justify-between">
                                        <span class="flex items-center gap-2">
                                            <span
                                                class="h-1.5 w-1.5 animate-pulse rounded-full bg-green-500"
                                            ></span>
                                            Agritech AI Solutions
                                        </span>
                                        <span class="font-bold text-green-600 dark:text-green-400"
                                            >[ R&D_ACTIVE ]</span
                                        >
                                    </li>
                                    <li class="flex items-center justify-between">
                                        <span class="flex items-center gap-2">
                                            <span class="h-1.5 w-1.5 rounded-full bg-blue-500"
                                            ></span>
                                            Vellor Protocol
                                        </span>
                                        <span class="font-bold text-(--accent)">[ LOCAL_CORE ]</span
                                        >
                                    </li>
                                    <li class="flex items-center justify-between">
                                        <span class="flex items-center gap-2">
                                            <span
                                                class="h-1.5 w-1.5 rounded-full bg-slate-400 dark:bg-slate-500"
                                            ></span>
                                            Data-Sovereign Tooling
                                        </span>
                                        <span class="font-bold text-slate-500 dark:text-slate-400"
                                            >[ DEPLOYED ]</span
                                        >
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div
                            class="pointer-events-none absolute bottom-4 left-1/2 -translate-x-1/2 text-2xl whitespace-nowrap text-slate-900 opacity-5 blur-[0.5px] transition-opacity duration-500 select-none group-hover:opacity-15 sm:text-3xl dark:text-white"
                            set:html={rocketEquationHtml}
                        />
                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div>
                                <h2
                                    class="mb-4 flex items-center gap-2 text-2xl font-bold tracking-tight text-slate-900 dark:text-white"
                                >
                                    <svg
                                        class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)"
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><path
                                            d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
                                        ></path><path
                                            d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
                                        ></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"
                                        ></path><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"
                                        ></path></svg
                                    >
                                    <span
                                        class="cypher-text"
                                        data-original="What Dhaatrik is Learning"
                                        >What Dhaatrik is Learning</span
                                    >
                                </h2>
                                <p
                                    class="leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                                >
                                    His curiosity pulls him toward the intricacies of reality. Right
                                    now, that means diving deep into the math of rocket engineering,
                                    the weirdness of quantum mechanics, and the fascinating depths
                                    of human psychology.
                                </p>
                            </div>

                            <div
                                class="mt-8 space-y-3.5 font-mono text-[11px] text-slate-600 dark:text-(--text-secondary)"
                            >
                                <div
                                    class="flex items-center justify-between border-b border-slate-200/50 pb-2 font-mono text-[9px] tracking-wider dark:border-white/5"
                                >
                                    <span class="text-slate-400 uppercase dark:text-slate-500"
                                        >// RESEARCH NODES</span
                                    >
                                    <span class="font-bold text-(--accent)">[ DEPTH ]</span>
                                </div>
                                <div class="space-y-3">
                                    <div>
                                        <div class="mb-1 flex justify-between text-[10px]">
                                            <span>Rocket Physics & Math</span>
                                            <span class="font-bold text-(--accent)">75%</span>
                                        </div>
                                        <div
                                            class="h-1 overflow-hidden rounded-full bg-slate-200 dark:bg-white/10"
                                        >
                                            <div
                                                class="h-full rounded-full bg-linear-to-r from-blue-500 to-indigo-500"
                                                style="width: 75%"
                                            >
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="mb-1 flex justify-between text-[10px]">
                                            <span>Quantum Mechanics</span>
                                            <span class="font-bold text-(--accent)">45%</span>
                                        </div>
                                        <div
                                            class="h-1 overflow-hidden rounded-full bg-slate-200 dark:bg-white/10"
                                        >
                                            <div
                                                class="h-full rounded-full bg-linear-to-r from-blue-500 to-indigo-500"
                                                style="width: 45%"
                                            >
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="mb-1 flex justify-between text-[10px]">
                                            <span>Cognitive Psychology</span>
                                            <span class="font-bold text-(--accent)">60%</span>
                                        </div>
                                        <div
                                            class="h-1 overflow-hidden rounded-full bg-slate-200 dark:bg-white/10"
                                        >
                                            <div
                                                class="h-full rounded-full bg-linear-to-r from-blue-500 to-indigo-500"
                                                style="width: 60%"
                                            >
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="layout-container relative">
                <h2
                    class="mb-6 text-3xl font-bold tracking-tight text-balance text-slate-900 dark:text-white"
                >
                    Current Trajectory
                </h2>

                <div class="bento-card group relative overflow-hidden p-0">
                    {/* Background abstract radar pattern */}
                    <div
                        class="pointer-events-none absolute inset-0 opacity-20 transition-opacity duration-500 group-hover:opacity-40"
                        style="background-image: radial-gradient(circle at 100% 0%, var(--accent-glow) 0%, transparent 50%);"
                    >
                    </div>

                    <div class="relative z-10 grid grid-cols-1 md:grid-cols-[1fr_2.5fr]">
                        {/* Left sidebar - Telemetry/Status */}
                        <div
                            class="flex flex-col justify-between border-b border-slate-100 bg-slate-50/50 p-6 md:border-r md:border-b-0 md:p-8 dark:border-white/5 dark:bg-black/20"
                        >
                            <div>
                                <div
                                    class="mb-6 inline-flex items-center gap-2 rounded-full border border-(--accent)/20 bg-(--accent)/10 px-3 py-1 font-mono text-[10px] font-bold tracking-widest text-(--accent) uppercase shadow-sm"
                                >
                                    <span
                                        class="h-1.5 w-1.5 animate-pulse rounded-full bg-(--accent)"
                                    ></span>
                                    Telemetry Active
                                </div>
                                <h3
                                    class="mb-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-white"
                                >
                                    Q1 2025
                                </h3>
                                <p class="font-mono text-xs text-slate-500 dark:text-slate-400">
                                    STATUS: Post-Flight Analysis
                                </p>
                            </div>

                            <div class="mt-6 md:mt-12">
                                <div
                                    class="mb-1 text-[9px] font-bold tracking-widest text-slate-400 uppercase md:mb-2 md:text-[10px] dark:text-slate-500"
                                >
                                    Focus Node
                                </div>
                                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 md:block">
                                    <div
                                        class="font-mono text-base font-bold text-(--accent) md:text-lg"
                                    >
                                        FuelDrop
                                    </div>
                                    <div class="text-[11px] text-slate-500 md:mt-1 md:text-xs">
                                        Logistics / Ag-Tech
                                    </div>
                                </div>
                            </div>
                        </div>

                        {/* Right content - Mission Log */}
                        <div class="flex flex-col justify-center p-6 md:p-8">
                            <div class="mb-6 flex items-start justify-between">
                                <h4
                                    class="flex items-center gap-2 text-xl font-bold text-slate-900 dark:text-white"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-slate-400"
                                        ><path
                                            d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                        ></path></svg
                                    >
                                    A Note on the Journey
                                </h4>
                                <span
                                    class="rounded border border-(--accent)/20 bg-(--accent)/10 px-2 py-1 font-mono text-[10px] text-(--accent) shadow-sm"
                                    >LOG_ENTRY: 402</span
                                >
                            </div>

                            <div
                                class="space-y-5 text-sm leading-relaxed text-slate-600 md:text-base dark:text-(--text-secondary)"
                            >
                                <p>
                                    <strong class="font-medium text-slate-900 dark:text-white"
                                        >FuelDrop</strong
                                    > was more than just a codebase; it was his primary startup focus
                                    during the first quarter of 2025. He will soon be sharing a comprehensive
                                    deep-dive article detailing the entire lifecycle of this venture.
                                </p>
                                <div class="my-4 border-l-2 border-(--accent) py-1 pl-4">
                                    <p
                                        class="font-medium text-slate-700 italic dark:text-slate-300"
                                    >
                                        "Knowledge kept secret is knowledge wasted."
                                    </p>
                                </div>
                                <p>
                                    He will be pulling back the curtain on the raw reality of
                                    building an on-demand logistics startup, the "hard-knock"
                                    lessons learned, and the technical breakdowns.
                                    <span
                                        class="cypher-text ml-1 cursor-crosshair font-bold text-(--accent) underline decoration-dashed underline-offset-4"
                                        data-original="Stay tuned.">Stay tuned.</span
                                    >
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="layout-container">
                <h2
                    class="mb-6 text-3xl font-bold tracking-tight text-balance text-slate-900 dark:text-white"
                >
                    Signal & Metrics
                </h2>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    {/* 1. The "52-Book Trajectory" Library Card */}
                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div class="relative z-10">
                            <div class="mb-4 flex items-start justify-between">
                                <h3
                                    class="flex items-center gap-2 text-lg font-bold text-slate-900 dark:text-white"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-(--accent)"
                                        ><path
                                            d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
                                        ></path></svg
                                    >
                                    Library Trajectory
                                </h3>
                                <span class="font-mono text-xs text-(--text-secondary)"
                                    >2026 Goal</span
                                >
                            </div>
                            <div class="mb-6">
                                <div class="mb-3 flex justify-between text-sm">
                                    <span class="text-slate-600 dark:text-slate-400"
                                        >Books Read</span
                                    >
                                    <span class="font-mono text-(--accent)"
                                        >{booksRead} / {booksGoal}</span
                                    >
                                </div>
                                <div class="grid w-full max-w-xs grid-cols-13 gap-1.5">
                                    {
                                        Array.from({ length: booksGoal }).map((_, index) => {
                                            const isRead = index < booksRead;
                                            return (
                                                <div
                                                    class={`aspect-square w-full rounded-[2px] transition-all duration-500 ${
                                                        isRead
                                                            ? 'border border-(--accent) bg-(--accent) shadow-[0_0_8px_var(--accent)]'
                                                            : 'border border-slate-200 bg-transparent dark:border-white/5'
                                                    }`}
                                                    title={`Book ${index + 1}: ${isRead ? 'Completed' : 'Pending'}`}
                                                />
                                            );
                                        })
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="relative z-10 mt-4 space-y-3">
                            <div
                                class="rounded-lg border border-slate-100 bg-slate-50 p-3 transition-colors group-hover:border-(--accent)/30 dark:border-white/5 dark:bg-black/20"
                            >
                                <span
                                    class="mb-1 block text-xs tracking-wider text-slate-500 uppercase dark:text-slate-400"
                                    >Currently Reading</span
                                >
                                <div class="flex items-center">
                                    <span
                                        class="truncate text-sm font-medium text-slate-900 dark:text-white"
                                        >Elon Musk - Ashlee Vance</span
                                    >
                                </div>
                            </div>
                            <button
                                popovertarget="books-popover"
                                aria-expanded="false"
                                aria-controls="books-popover"
                                class="magnetic-target flex w-full items-center justify-center rounded-lg bg-slate-900 py-2 text-center text-sm font-bold text-white shadow-sm transition-all hover:bg-slate-800 hover:shadow-[0_0_15px_var(--accent-glow)] focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200 dark:focus-visible:ring-offset-(--bg-main)"
                            >
                                Recommended Books
                            </button>
                        </div>
                    </div>

                    {/* 6. Monthly Insights Terminal Snippet */}
                    <div
                        class="bento-card flex h-full flex-col overflow-hidden border-[#333] bg-[#1e1e1e] p-0 text-left dark:border-[#333] dark:bg-[#1e1e1e]"
                    >
                        <div
                            class="flex items-center gap-2 border-b border-[#111] bg-[#2d2d2d] px-4 py-2"
                        >
                            <div class="flex gap-1.5">
                                <div class="h-3 w-3 rounded-full bg-[#ff5f56]"></div>
                                <div class="h-3 w-3 rounded-full bg-[#ffbd2e]"></div>
                                <div class="h-3 w-3 rounded-full bg-[#27c93f]"></div>
                            </div>
                            <span class="ml-2 font-mono text-xs text-[#888]">bash</span>
