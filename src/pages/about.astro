---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TechMarquee from '../components/TechMarquee.astro';
import { SITE_TITLE } from '../consts';

import { techGroups } from '../data/techStack';
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <BaseHead
            title={`About | ${SITE_TITLE}`}
            description="Learn more about Dhaatrik's journey and tech stack."
        />
        {/* ⚡ Bolt: Preconnect to external image origin for faster badge loading */}
        <link rel="preconnect" href="https://img.shields.io" crossorigin />
        <link rel="dns-prefetch" href="https://img.shields.io" />
    </head>
    <body class="flex min-h-screen flex-col pt-24">
        <Header />
        <main id="main-content" class="layout-container flex-grow space-y-20 py-8">
            <section class="max-w-3xl">
                <h1
                    class="mb-6 text-4xl leading-tight font-bold text-slate-900 md:text-5xl dark:text-white"
                >
                    About Me
                </h1>
                <div
                    class="space-y-6 text-lg leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]"
                >
                    <p>
                        Think of me as your friendly neighborhood dev-brother—always down to help,
                        learn, or just talk shop. I'm deeply curious about the "how" and "why" of
                        the universe.
                    </p>

                    <h2 class="mt-8 mb-4 text-2xl font-bold text-slate-900 dark:text-white">
                        What I'm Building
                    </h2>
                    <p>
                        I'm currently focused on the agriculture domain, working to integrate AI
                        into the core fundamentals of farming to solve real-world problems. I also
                        love building tools for the community, like <strong>Vellor</strong>, an
                        offline-first tool for independent educators.
                    </p>

                    <h2 class="mt-8 mb-4 text-2xl font-bold text-slate-900 dark:text-white">
                        What I'm Learning
                    </h2>
                    <p>
                        My curiosity pulls me toward the intricacies of reality. Right now, that
                        means diving deep into the math of rocket engineering, the weirdness of
                        quantum mechanics, and the fascinating depths of human psychology.
                    </p>
                </div>
            </section>

            <section class="bento-card relative max-w-4xl overflow-hidden">
                <div class="relative z-10">
                    <h2 class="mb-4 text-2xl font-bold text-[var(--accent)]">
                        A Note on the Journey: Q1 2025 & Beyond
                    </h2>
                    <p
                        class="mb-4 leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]"
                    >
                        FuelDrop was more than just a codebase; it was my primary startup focus
                        during the first quarter of 2025. I'll soon be sharing a comprehensive
                        deep-dive article detailing the entire lifecycle of this venture.
                    </p>
                    <p class="leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                        I'm a firm believer that <strong
                            >"knowledge kept secret is knowledge wasted"</strong
                        >. I'll be pulling back the curtain on the raw reality of building an
                        on-demand logistics startup, the "hard-knock" lessons learned, and the
                        technical breakdowns. Stay tuned.
                    </p>
                </div>
            </section>

            <section class="max-w-5xl">
                <h2 class="mb-8 text-3xl font-bold text-slate-900 dark:text-white">
                    My Tech Stack
                </h2>
                <TechMarquee techGroups={techGroups} />
            </section>
        </main>
        <Footer />
    </body>
</html>
