---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TechMarquee from '../components/TechMarquee.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';

import { techGroups } from '../data/techStack';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`About | ${SITE_TITLE}`}
            description="Learn more about Dhaatrik's journey and tech stack."
        />
        {/* ⚡ Bolt: Preconnect to external image origin for faster badge loading */}
        <link rel="preconnect" href="https://img.shields.io" crossorigin />
        <link rel="dns-prefetch" href="https://img.shields.io" />
    </head>
    <body class="flex min-h-screen flex-col bg-grid-motif pt-24 relative">
        <Header />
        <main id="main-content" class="layout-container flex-grow space-y-20 py-8 relative">
             <div class="absolute right-0 top-32 -z-10 opacity-5 pointer-events-none text-slate-900 dark:text-white">
                <svg width="400" height="400" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <path fill="none" stroke="currentColor" stroke-width="1" d="M100 100 m-80,0 a80,80 0 1,0 160,0 a80,80 0 1,0 -160,0 M100 100 m-60,0 a60,60 0 1,0 120,0 a60,60 0 1,0 -120,0 M100 100 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 M20 100 h160 M100 20 v160" />
                </svg>
             </div>

            <section class="max-w-4xl">
                <div class="mb-16 flex flex-col items-center gap-8 md:flex-row md:items-start">
                    <div class="w-full shrink-0 md:w-1/3">
                        <img src="/me.jpeg" alt="Dhaatrik" class="aspect-square w-full rounded-2xl border border-slate-200 object-cover shadow-xl transition-all duration-500 hover:grayscale-0 dark:border-white/10 grayscale" />
                    </div>
                    <div class="w-full md:w-2/3">
                        <h1 class="mb-2 text-4xl leading-tight font-bold text-slate-900 md:text-5xl dark:text-white">
                            About Me
                        </h1>
                        <span class="mb-6 block text-sm font-mono text-[var(--accent)]">Current Status: Q2 2026</span>
                        
                        <div class="space-y-6 text-lg leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                            <p>
                                I’m Dhaatrik, an engineer and entrepreneur driven by a relentless curiosity for how the universe operates. I build robust, data-sovereign systems by stripping complex problems down to their fundamental truths.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 relative z-10">
                    <div class="bg-slate-100 dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/5">
                        <h2 class="flex items-center gap-2 mb-4 text-2xl font-bold text-slate-900 dark:text-white">
                            <svg class="w-6 h-6 text-slate-500 dark:text-[var(--text-secondary)]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
                            <span class="cypher-text" data-original="What I'm Building">What I'm Building</span>
                        </h2>
                        <p class="leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                            I'm currently focused on the agriculture domain, working to integrate AI
                            into the core fundamentals of farming to solve real-world problems. I also
                            love building tools for the community, like <a href="https://github.com/dhaatrik" target="_blank" rel="noopener noreferrer" class="text-[var(--accent)] hover:underline decoration-dashed underline-offset-4">Vellor</a>, an
                            offline-first tool for independent educators.
                        </p>
                    </div>

                    <div class="bg-slate-100 dark:bg-white/5 p-6 rounded-2xl border border-slate-200 dark:border-white/5 relative overflow-hidden group">
                        <div class="absolute right-0 bottom-4 opacity-5 pointer-events-none select-none text-4xl sm:text-5xl font-serif text-slate-900 dark:text-white whitespace-nowrap blur-[1px] group-hover:opacity-10 transition-opacity duration-500">
                            Δv = v<sub>e</sub> ln(m<sub>0</sub> / m<sub>f</sub>)
                        </div>
                        <h2 class="flex items-center gap-2 mb-4 text-2xl font-bold text-slate-900 dark:text-white relative z-10">
                            <svg class="w-6 h-6 text-slate-500 dark:text-[var(--text-secondary)]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path></svg>
                            <span class="cypher-text" data-original="What I'm Learning">What I'm Learning</span>
                        </h2>
                        <p class="leading-relaxed text-slate-600 dark:text-[var(--text-secondary)] relative z-10">
                            My curiosity pulls me toward the intricacies of reality. Right now, that
                            means diving deep into the math of rocket engineering, the weirdness of
                            quantum mechanics, and the fascinating depths of human psychology.
                        </p>
                    </div>
                </div>
            </section>

            <section class="max-w-4xl relative overflow-hidden mb-20">
                <h2 class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">Current Trajectory</h2>
                <div class="border-l-2 border-[var(--accent)] pl-6 ml-2 space-y-8">
                    <div class="relative">
                        <div class="absolute -left-[31px] top-1.5 h-3 w-3 rounded-full bg-[var(--accent)] ring-4 ring-[var(--bg-body)] dark:ring-[#111111]"></div>
                        <h3 class="mb-2 text-xl font-bold text-[var(--accent)]">
                            A Note on the Journey: Q1 2025 & Beyond
                        </h3>
                        <p class="mb-4 leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                            <a href="#" class="text-[var(--accent)] hover:underline decoration-dashed underline-offset-4">FuelDrop</a> was more than just a codebase; it was my primary startup focus
                            during the first quarter of 2025. I'll soon be sharing a comprehensive
                            deep-dive article detailing the entire lifecycle of this venture.
                        </p>
                        <p class="leading-relaxed text-slate-600 dark:text-[var(--text-secondary)]">
                            I'm a firm believer that <strong>"knowledge kept secret is knowledge wasted"</strong>. I'll be pulling back the curtain on the raw reality of building an
                            on-demand logistics startup, the "hard-knock" lessons learned, and the
                            technical breakdowns. Stay tuned.
                        </p>
                    </div>
                </div>
            </section>
            
            <section class="max-w-5xl mb-20">
                <h2 class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">Signal & Metrics</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    
                    {/* 1. The "52-Book Trajectory" Library Card */}
                    <div class="bento-card p-6 flex flex-col justify-between group relative overflow-hidden">
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">
                                <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)]"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>
                                    Library Trajectory
                                </h3>
                                <span class="text-xs font-mono text-[var(--text-secondary)]">2026 Goal</span>
                            </div>
                            <div class="mb-4">
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600 dark:text-slate-400">Books Read</span>
                                    <span class="font-mono text-[var(--accent)]">14 / 52</span>
                                </div>
                                <div class="h-2 w-full bg-slate-200 dark:bg-white/5 rounded-full overflow-hidden">
                                    <div class="h-full bg-[var(--accent)] rounded-full" style="width: 27%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 p-3 bg-slate-50 dark:bg-black/20 rounded-lg border border-slate-100 dark:border-white/5 relative z-10 transition-colors group-hover:border-[var(--accent)]/30">
                            <span class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400 block mb-1">Currently Reading</span>
                            <div class="flex justify-between items-center">
                                <span class="text-sm font-medium text-slate-900 dark:text-white">Zero to One - Peter Thiel</span>
                                <a href="#" class="text-[var(--accent)] hover:text-opacity-80 transition-opacity">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    {/* 2. "Signal-to-Noise" Activity Tracker */}
                    <div class="bento-card p-6">
                        <div class="flex justify-between items-start mb-6">
                            <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)]"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
                                Signal-to-Noise
                            </h3>
                            <span class="text-xs font-mono text-[var(--text-secondary)]">Deep Work</span>
                        </div>
                        <div class="grid grid-cols-7 gap-2">
                            {Array.from({ length: 28 }).map((_, i) => {
                                const opacities = ['opacity-20', 'opacity-40', 'opacity-60', 'opacity-80', 'opacity-100'];
                                const rand = Math.random();
                                const opacity = rand > 0.3 ? (rand > 0.7 ? opacities[4] : opacities[3]) : opacities[1];
                                return (
                                    <div class={`aspect-square rounded-[4px] bg-[var(--accent)] ${opacity} hover:scale-110 transition-transform cursor-pointer`} title="Deep Work Hours"></div>
                                );
                            })}
                        </div>
                    </div>

                    {/* 3. The "Base of Operations" Radar Map */}
                    <div class="bento-card p-6 relative overflow-hidden min-h-[220px]">
                        <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 relative z-10">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)]"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
                            Base of Operations
                        </h3>
                        <div class="mt-2 text-sm text-slate-600 dark:text-slate-400 relative z-10">Kolkata, IN</div>
                        
                        {/* Map SVG abstract */}
                        <div class="absolute -bottom-8 -right-8 w-64 h-64 opacity-20 pointer-events-none text-slate-500 dark:text-white">
                            <svg viewBox="0 0 100 100" class="w-full h-full fill-current">
                                <path d="M30,10 L70,10 L80,50 L50,90 L20,60 Z" opacity="0.5"/>
                                <line x1="0" y1="20" x2="100" y2="20" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="0" y1="40" x2="100" y2="40" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="0" y1="60" x2="100" y2="60" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="0" y1="80" x2="100" y2="80" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="20" y1="0" x2="20" y2="100" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="40" y1="0" x2="40" y2="100" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="60" y1="0" x2="60" y2="100" stroke="currentColor" stroke-width="0.5"/>
                                <line x1="80" y1="0" x2="80" y2="100" stroke="currentColor" stroke-width="0.5"/>
                            </svg>
                        </div>
                        {/* Radar Dot (Kolkata approx relative position) */}
                        <div class="absolute bottom-[35%] right-[40%]">
                            <div class="relative flex h-3 w-3">
                              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                              <span class="relative inline-flex rounded-full h-3 w-3 bg-cyan-500 shadow-[0_0_8px_rgba(6,182,212,0.8)]"></span>
                            </div>
                        </div>
                    </div>

                    {/* 6. Monthly Insights Terminal Snippet */}
                    <div class="bento-card bg-[#1e1e1e] border-[#333] dark:bg-[#1e1e1e] dark:border-[#333] p-0 flex flex-col overflow-hidden text-left h-full">
                        <div class="bg-[#2d2d2d] px-4 py-2 flex items-center gap-2 border-b border-[#111]">
                            <div class="flex gap-1.5">
                                <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                                <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                                <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
                            </div>
                            <span class="text-[#888] text-xs font-mono ml-2">bash</span>
                        </div>
                        <div class="p-4 font-mono text-sm flex-grow">
                            <div class="text-[#50fa7b] mb-2">$ cat /logs/may-reflection.txt</div>
                            <div class="text-[#f8f8f2] leading-relaxed">
                                <span class="text-[#bd93f9]">"</span>Optimization is a trap if you haven't nailed the fundamentals first. Build robust, scale later.<span class="text-[#bd93f9]">"</span>
                            </div>
                            <div class="text-[#50fa7b] mt-2 animate-pulse">_</div>
                        </div>
                    </div>
                </div>
            </section>

            {/* 7. GitHub "Always Building" Heatmap Integration */}
            <section class="max-w-5xl mb-20">
                <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)]"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                    Always Building
                </h2>
                <div class="bento-card p-4 md:p-6 overflow-x-auto bg-slate-50 dark:bg-[var(--bg-card)]">
                    <img src="https://ghchart.rshah.org/3b82f6/dhaatrik" alt="Dhaatrik's Github Chart" class="w-full min-w-[700px] select-none pointer-events-none opacity-80 hover:opacity-100 transition-opacity" />
                </div>
            </section>

            {/* 8. Interactive Terminal Contact CTA */}
            <section class="max-w-5xl mb-12">
                <div class="bento-card bg-[#0d1117] border-[#30363d] dark:bg-[#0d1117] dark:border-[#30363d] overflow-hidden p-8 md:p-12 flex flex-col items-center text-center relative group">
                    <div class="absolute inset-0 bg-grid-motif opacity-10 pointer-events-none"></div>
                    <div class="relative z-10 w-full max-w-2xl">
                        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-mono">> Let's Connect</h2>
                        <p class="text-slate-400 mb-8 font-mono text-sm md:text-base leading-relaxed">
                            Want to discuss multi-agent orchestration, rocket kinematics, or the future of ag-tech?
                        </p>
                        
                        <form id="terminal-contact" class="flex flex-col sm:flex-row gap-2 items-center bg-black/50 border border-[#30363d] rounded-lg p-2 focus-within:border-[var(--accent)] transition-colors w-full shadow-inner">
                            <span class="text-[var(--accent)] font-mono pl-3 font-bold select-none shrink-0">~ $</span>
                            <input type="text" id="terminal-input" placeholder="Type your message here and hit Enter..." class="bg-transparent border-none outline-none text-green-400 font-mono flex-grow p-2 w-full placeholder-slate-600 text-sm md:text-base" autocomplete="off" />
                        </form>
                        <div id="terminal-status" class="h-6 mt-4 text-center font-mono text-xs md:text-sm text-slate-400 opacity-0 transition-opacity duration-300"></div>
                    </div>
                </div>
            </section>

            <section class="max-w-5xl">
                <h2 class="mb-8 text-3xl font-bold text-slate-900 dark:text-white">
                    My Tech Stack
                </h2>
                <TechMarquee techGroups={techGroups} />
            </section>
        </main>
        <Footer />
        <script>
            // Scramble / Cypher Text Hover Effects
            const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*";
            const cypherElements = document.querySelectorAll('.cypher-text');
            
            cypherElements.forEach(element => {
                element.addEventListener('mouseenter', event => {
                    let iterations = 0;
                    const originalText = event.target.dataset.original;
                    const length = originalText.length;
                    
                    clearInterval(event.target.cypherInterval);
                    
                    event.target.cypherInterval = setInterval(() => {
                        event.target.innerText = originalText.split("")
                            .map((letter, index) => {
                                if(index < iterations) return originalText[index];
                                return letters[Math.floor(Math.random() * 42)];
                            })
                            .join("");
                        
                        if(iterations >= length) clearInterval(event.target.cypherInterval);
                        iterations += 1 / 3;
                    }, 30);
                });
            });

            // Interactive Terminal Contact CTA
            const terminalForm = document.getElementById('terminal-contact');
            const terminalInput = document.getElementById('terminal-input');
            const terminalStatus = document.getElementById('terminal-status');

            if(terminalForm && terminalInput && terminalStatus) {
                terminalForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    const message = terminalInput.value.trim();
                    if(!message) return;
                    
                    terminalStatus.innerText = "Initiating secure channel to Dhaatrik...";
                    terminalStatus.style.opacity = "1";
                    terminalInput.disabled = true;
                    
                    setTimeout(() => {
                        window.location.href = `mailto:hello@dhaatrik.com?subject=Incoming Transmission&body=${encodeURIComponent(message)}`;
                        terminalStatus.innerText = "Transmission sent.";
                        setTimeout(() => {
                            terminalInput.disabled = false;
                            terminalInput.value = "";
                            terminalStatus.style.opacity = "0";
                        }, 3000);
                    }, 1200);
                });
            }

            // The "Offline-First" Easter Egg
            window.addEventListener('offline', () => {
                const toast = document.createElement('div');
                toast.className = "fixed bottom-6 right-6 bg-slate-900 border border-[var(--accent)] text-white p-4 rounded-lg shadow-2xl z-50 font-mono text-sm max-w-sm translate-y-10 opacity-0 transition-all duration-300";
                toast.innerHTML = `<span class="text-[var(--accent)] font-bold">Vellor Protocol Engaged:</span> You are offline, but this data remains accessible.`;
                document.body.appendChild(toast);
                
                // Animate in
                setTimeout(() => {
                    toast.classList.remove('translate-y-10', 'opacity-0');
                }, 100);
                
                // Remove after 6 seconds
                setTimeout(() => {
                    toast.classList.add('translate-y-10', 'opacity-0');
                    setTimeout(() => toast.remove(), 300);
                }, 6000);
            });
        </script>
    </body>
</html>
