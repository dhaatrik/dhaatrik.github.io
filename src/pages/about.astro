---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
import katex from 'katex';
import 'katex/dist/katex.min.css';

import { techGroups } from '../data/techStack';

// Library Tracking Data
const booksRead = 7;
const booksGoal = 52;
const readingProgress = Math.min(Math.round((booksRead / booksGoal) * 100), 100);

// Pre-render rocket equation using KaTeX
const rocketEquationHtml = katex.renderToString('\\Delta v = v_e \\ln \\frac{m_0}{m_f}', {
    displayMode: true,
    throwOnError: false
});

---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`About | ${SITE_TITLE}`}
            description="Learn more about Dhaatrik's journey and tech stack."
        />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <Header />
        <main
            id="main-content"
            tabindex="-1"
            class="layout-container relative grow space-y-20 py-8"
        >
            <div
                id="reticle-bg"
                class="pointer-events-none absolute top-32 right-0 -z-10 text-slate-900 opacity-5 transition-transform duration-300 ease-out dark:text-white"
            >
                <svg
                    width="400"
                    height="400"
                    viewBox="0 0 200 200"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        d="M100 100 m-80,0 a80,80 0 1,0 160,0 a80,80 0 1,0 -160,0 M100 100 m-60,0 a60,60 0 1,0 120,0 a60,60 0 1,0 -120,0 M100 100 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 M20 100 h160 M100 20 v160"
                    ></path>
                </svg>
            </div>

            <section class="max-w-4xl">
                <div class="mb-16 flex flex-col items-center gap-8 md:flex-row md:items-start">
                    <div class="relative w-full shrink-0 p-4 md:w-1/3">
                        {/* Clinical blueprint borders and target marks */}
                        <div class="absolute inset-0 border border-dashed border-slate-200 dark:border-white/10 pointer-events-none">
                            {/* Corner target marks '+' */}
                            <span class="absolute -top-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            <span class="absolute -top-1.5 -right-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            <span class="absolute -bottom-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            <span class="absolute -bottom-1.5 -right-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            
                            {/* Absolute layout text arrays along borders */}
                            <span class="absolute top-1 left-2 font-mono text-[9px] font-bold tracking-widest text-slate-400 dark:text-slate-500 uppercase">SPECIMEN_REF: 01</span>
                            <span class="absolute bottom-1 right-2 font-mono text-[9px] font-bold tracking-widest text-slate-400 dark:text-slate-500 uppercase">DATA.CAP // 100%</span>
                        </div>
                        
                        <div class="relative overflow-hidden rounded-lg bg-slate-100 dark:bg-black/40">
                            {/* Technical grid overlay */}
                            <div class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(rgba(0,0,0,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.08)_1px,transparent_1px)] bg-[size:10px_10px] dark:bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] opacity-50"></div>
                            
                            <img
                                src="/me.jpeg"
                                alt="Dhaatrik"
                                loading="eager"
                                fetchpriority="high"
                                class="aspect-square w-full object-cover grayscale transition-all duration-500 hover:grayscale-0"
                            />
                        </div>
                    </div>
                    <div class="w-full md:w-2/3">
                        <h1
                            class="mb-2 text-4xl leading-tight font-bold text-slate-900 md:text-5xl text-balance tracking-tight dark:text-white"
                        >
                            About Me
                        </h1>


                        <div
                            class="space-y-6 text-lg leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                        >
                            <p>
                                I’m Dhaatrik, an engineer and entrepreneur driven by a relentless
                                curiosity for how the universe operates. I build robust,
                                data-sovereign systems by stripping complex problems down to their
                                fundamental truths.
                            </p>
                            
                            <div class="mt-8 border-l-2 border-(--accent) pl-4 font-mono text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                <div class="mb-2 text-xs font-bold tracking-wider text-slate-400 dark:text-slate-500 uppercase">
                                    // OPERATIONAL PHILOSOPHY
                                </div>
                                <p>
                                    I choose not to reinvent the wheel or build foundation models from scratch, but act as an execution engine leveraging AI to build functional, data-sovereign systems.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="relative z-10 mb-20 max-w-5xl">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div class="relative z-10">
                            <h2
                                class="mb-4 flex items-center gap-2 text-2xl font-bold text-slate-900 text-balance tracking-tight dark:text-white"
                            >
                                <svg
                                    class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)"
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><rect x="4" y="4" width="16" height="16" rx="2" ry="2"
                                    ></rect><rect x="9" y="9" width="6" height="6"></rect><line
                                        x1="9"
                                        y1="1"
                                        x2="9"
                                        y2="4"></line><line x1="15" y1="1" x2="15" y2="4"
                                    ></line><line x1="9" y1="20" x2="9" y2="23"></line><line
                                        x1="15"
                                        y1="20"
                                        x2="15"
                                        y2="23"></line><line x1="20" y1="9" x2="23" y2="9"
                                    ></line><line x1="20" y1="14" x2="23" y2="14"></line><line
                                        x1="1"
                                        y1="9"
                                        x2="4"
                                        y2="9"></line><line x1="1" y1="14" x2="4" y2="14"
                                    ></line></svg
                                >
                                <span class="cypher-text" data-original="What I'm Building"
                                    >What I'm Building</span
                                >
                            </h2>
                            <p class="leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                I'm currently focused on the agriculture domain, working to
                                integrate AI into the core fundamentals of farming to solve
                                real-world problems. I also love building tools for the community,
                                like <a
                                    href="https://github.com/dhaatrik"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-(--accent) decoration-dashed underline-offset-4 hover:underline"
                                    >Vellor</a
                                >, an offline-first tool for independent educators.
                            </p>
                        </div>
                    </div>

                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div
                            class="pointer-events-none absolute bottom-4 left-1/2 -translate-x-1/2 text-2xl whitespace-nowrap text-slate-900 opacity-5 blur-[0.5px] transition-opacity duration-500 select-none group-hover:opacity-15 sm:text-3xl dark:text-white"
                            set:html={rocketEquationHtml}
                        />
                        <div class="relative z-10">
                            <h2
                                class="mb-4 flex items-center gap-2 text-2xl font-bold text-slate-900 text-balance tracking-tight dark:text-white"
                            >
                                <svg
                                    class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)"
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
                                    ></path><path
                                        d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
                                    ></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"
                                    ></path><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"
                                    ></path></svg
                                >
                                <span class="cypher-text" data-original="What I'm Learning"
                                    >What I'm Learning</span
                                >
                            </h2>
                            <p class="leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                My curiosity pulls me toward the intricacies of reality. Right now,
                                that means diving deep into the math of rocket engineering, the
                                weirdness of quantum mechanics, and the fascinating depths of human
                                psychology.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="relative mb-20 max-w-5xl">
                <h2 class="mb-6 text-2xl font-bold text-slate-900 text-balance tracking-tight dark:text-white">
                    Current Trajectory
                </h2>

                <div class="bento-card group relative overflow-hidden p-0">
                    {/* Background abstract radar pattern */}
                    <div
                        class="pointer-events-none absolute inset-0 opacity-20 transition-opacity duration-500 group-hover:opacity-40"
                        style="background-image: radial-gradient(circle at 100% 0%, var(--accent-glow) 0%, transparent 50%);"
                    >
                    </div>

                    <div class="relative z-10 grid grid-cols-1 md:grid-cols-[1fr_2.5fr]">
                        {/* Left sidebar - Telemetry/Status */}
                        <div
                            class="flex flex-col justify-between border-b border-slate-100 bg-slate-50/50 p-6 md:border-r md:border-b-0 md:p-8 dark:border-white/5 dark:bg-black/20"
                        >
                            <div>
                                <div
                                    class="mb-6 inline-flex items-center gap-2 rounded-full border border-(--accent)/20 bg-(--accent)/10 px-3 py-1 font-mono text-[10px] font-bold tracking-widest text-(--accent) uppercase shadow-sm"
                                >
                                    <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-(--accent)"
                                    ></span>
                                    Telemetry Active
                                </div>
                                <h3
                                    class="mb-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-white"
                                >
                                    Q1 2025
                                </h3>
                                <p class="font-mono text-xs text-slate-500 dark:text-slate-400">
                                    STATUS: Post-Flight Analysis
                                </p>
                            </div>

                            <div class="mt-12 hidden md:block">
                                <div
                                    class="mb-2 text-[10px] font-bold tracking-widest text-slate-400 uppercase"
                                >
                                    Focus Node
                                </div>
                                <div class="font-mono text-lg font-bold text-(--accent)">FuelDrop</div>
                                <div class="mt-1 text-xs text-slate-500">Logistics / Ag-Tech</div>
                            </div>
                        </div>

                        {/* Right content - Mission Log */}
                        <div class="flex flex-col justify-center p-6 md:p-8">
                            <div class="mb-6 flex items-start justify-between">
                                <h4
                                    class="flex items-center gap-2 text-xl font-bold text-slate-900 dark:text-white"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-slate-400"
                                        ><path
                                            d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                        ></path></svg
                                    >
                                    A Note on the Journey
                                </h4>
                                <span
                                    class="rounded border border-(--accent)/20 bg-(--accent)/10 px-2 py-1 font-mono text-[10px] text-(--accent) shadow-sm"
                                    >LOG_ENTRY: 402</span
                                >
                            </div>

                            <div
                                class="space-y-5 text-sm leading-relaxed text-slate-600 md:text-base dark:text-(--text-secondary)"
                            >
                                <p>
                                    <strong class="font-medium text-slate-900 dark:text-white"
                                        >FuelDrop</strong
                                    > was more than just a codebase; it was my primary startup focus during
                                    the first quarter of 2025. I'll soon be sharing a comprehensive deep-dive
                                    article detailing the entire lifecycle of this venture.
                                </p>
                                <div class="my-4 border-l-2 border-(--accent) py-1 pl-4">
                                    <p
                                        class="font-medium text-slate-700 italic dark:text-slate-300"
                                    >
                                        "Knowledge kept secret is knowledge wasted."
                                    </p>
                                </div>
                                <p>
                                    I'll be pulling back the curtain on the raw reality of building
                                    an on-demand logistics startup, the "hard-knock" lessons
                                    learned, and the technical breakdowns.
                                    <span
                                        class="cypher-text ml-1 cursor-crosshair font-bold text-(--accent) underline decoration-dashed underline-offset-4"
                                        data-original="Stay tuned.">Stay tuned.</span
                                    >
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-20 max-w-5xl">
                <h2 class="mb-6 text-2xl font-bold text-slate-900 text-balance tracking-tight dark:text-white">
                    Signal & Metrics
                </h2>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    {/* 1. The "52-Book Trajectory" Library Card */}
                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div class="relative z-10">
                            <div class="mb-4 flex items-start justify-between">
                                <h3
                                    class="flex items-center gap-2 font-bold text-slate-900 dark:text-white"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-(--accent)"
                                        ><path
                                            d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
                                        ></path></svg
                                    >
                                    Library Trajectory
                                </h3>
                                <span class="font-mono text-xs text-(--text-secondary)">2026 Goal</span>
                            </div>
                            <div class="mb-6">
                                <div class="mb-3 flex justify-between text-sm">
                                    <span class="text-slate-600 dark:text-slate-400"
                                        >Books Read</span
                                    >
                                    <span class="font-mono text-(--accent)"
                                        >{booksRead} / {booksGoal}</span
                                    >
                                </div>
                                <div class="grid grid-cols-[repeat(13,_minmax(0,_1fr))] gap-1.5 w-full max-w-xs">
                                    {
                                        Array.from({ length: booksGoal }).map((_, index) => {
                                            const isRead = index < booksRead;
                                            return (
                                                <div
                                                    class={`aspect-square w-full rounded-[2px] transition-all duration-500 ${
                                                        isRead
                                                            ? 'bg-(--accent) shadow-[0_0_8px_var(--accent)] border border-(--accent)'
                                                            : 'border border-slate-200 dark:border-white/5 bg-transparent'
                                                    }`}
                                                    title={`Book ${index + 1}: ${isRead ? 'Completed' : 'Pending'}`}
                                                />
                                            );
                                        })
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="relative z-10 mt-4 space-y-3">
                            <div
                                class="rounded-lg border border-slate-100 bg-slate-50 p-3 transition-colors group-hover:border-(--accent)/30 dark:border-white/5 dark:bg-black/20"
                            >
                                <span
                                    class="mb-1 block text-xs tracking-wider text-slate-500 uppercase dark:text-slate-400"
                                    >Currently Reading</span
                                >
                                <div class="flex items-center justify-between gap-4">
                                    <span
                                        class="truncate text-sm font-medium text-slate-900 dark:text-white"
                                        >Elon Musk - Ashlee Vance</span
                                    >
                                    <a
                                        aria-label="Buy Elon Musk - Ashlee Vance (opens in a new tab)"
                                        href="https://www.amazon.in/Elon-Musk-Billionaire-SpaceX-Shaping-ebook/dp/B00SIDCSWY"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="magnetic-target shrink-0 rounded bg-(--accent) px-3 py-1 text-[10px] font-bold text-white uppercase shadow-sm transition-all hover:bg-blue-600 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:focus-visible:ring-offset-(--bg-main)"
                                        >Buy</a
                                    >
                                </div>
                            </div>
                            <button
                                onclick="document.getElementById('books-modal').showModal()"
                                class="magnetic-target w-full rounded-lg bg-slate-900 py-2 text-sm font-bold text-white shadow-sm transition-all hover:bg-slate-800 hover:shadow-[0_0_15px_var(--accent-glow)] focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200 dark:focus-visible:ring-offset-(--bg-main) flex items-center justify-center text-center"
                            >
                                Recommended Books
                            </button>
                        </div>
                    </div>

                    {/* 6. Monthly Insights Terminal Snippet */}
                    <div
                        class="bento-card flex h-full flex-col overflow-hidden border-[#333] bg-[#1e1e1e] p-0 text-left dark:border-[#333] dark:bg-[#1e1e1e]"
                    >
                        <div
                            class="flex items-center gap-2 border-b border-[#111] bg-[#2d2d2d] px-4 py-2"
                        >
                            <div class="flex gap-1.5">
                                <div class="h-3 w-3 rounded-full bg-[#ff5f56]"></div>
                                <div class="h-3 w-3 rounded-full bg-[#ffbd2e]"></div>
                                <div class="h-3 w-3 rounded-full bg-[#27c93f]"></div>
                            </div>
                            <span class="ml-2 font-mono text-xs text-[#888]">bash</span>
                        </div>
                        <div class="grow p-4 font-mono text-sm">
                            <div class="mb-2 text-[#50fa7b]">$ cat /logs/may-reflection.txt</div>
                            <div
                                id="terminal-snippet"
                                class="leading-relaxed text-[#f8f8f2]"
                                data-text="Optimization is a trap if you haven't nailed the fundamentals first. Build robust, scale later."
                            >
                                <span class="text-[#bd93f9]">"</span><span class="animate-pulse">█</span>
                            </div>
                            <div class="mt-2 animate-pulse text-[#50fa7b]">_</div>
                        </div>
                    </div>
                </div>
            </section>

            {/* 8. Interactive Terminal Contact CTA */}
            <section class="mb-12 max-w-5xl">
                <div
                    class="bento-card group relative flex flex-col items-center overflow-hidden border-slate-200 bg-slate-50 p-8 text-center md:p-12 dark:border-[#30363d] dark:bg-[#0d1117]"
                >
                    <div class="bg-grid-motif pointer-events-none absolute inset-0 opacity-10">
                    </div>
                    <div class="relative z-10 w-full max-w-2xl">
                        <h2
                            class="mb-4 font-mono text-3xl font-bold text-slate-900 md:text-4xl text-balance tracking-tight dark:text-white"
                        >
                            &gt; Let's Connect
                        </h2>
                        <p
                            class="mb-8 font-mono text-sm leading-relaxed text-slate-600 md:text-base dark:text-slate-400"
                        >
                            Want to discuss multi-agent orchestration, rocket kinematics, or the
                            future of ag-tech?
                        </p>

                        <div class="mt-4 flex justify-center">
                            <a
                                href={SOCIAL_LINKS.twitter}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="Connect on X (opens in a new tab)"
                                class="magnetic-target group relative inline-flex items-center justify-center gap-2 rounded-lg bg-(--accent) px-8 py-3 font-mono font-bold text-white transition-all hover:-translate-y-1 hover:bg-blue-600 hover:shadow-[0_8px_30px_var(--accent-glow)] focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:focus-visible:ring-offset-(--bg-main)"
                            >
                                <span aria-hidden="true">~ $ connect --x</span>
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="transition-transform group-hover:translate-x-1"
                                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
                                >
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="max-w-5xl content-visibility-auto-tech-stack">
                <h2 class="mb-2 text-3xl font-bold text-slate-900 text-balance tracking-tight dark:text-white">
                    My Tech Stack
                </h2>
                <p class="mb-8 font-mono text-[10px] tracking-tight text-slate-500 dark:text-slate-400 max-w-3xl leading-relaxed uppercase">
                    // SYSTEM_INVENTORY: TECHNICAL ASSETS REGISTERED FOR TARGETED SYSTEM ARCHITECTURE AND HIGH-VELOCITY DEPLOYMENT. UTILITY PRIORITIZED OVER SYNTAX MEMORIZATION.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    {/* MODULE 01: Frontend */}
                    <div class="relative border border-slate-200 dark:border-white/10 bg-slate-50/50 dark:bg-black/20 p-6 pt-10 pb-8 rounded-lg overflow-hidden flex flex-col justify-between min-h-[200px]">
                        <!-- Corner Labels -->
                        <span class="absolute top-2 left-3 font-mono text-[8px] text-slate-400 dark:text-slate-500 uppercase tracking-wider">// MODULE_01 // FE_SYS</span>
                        <span class="absolute top-2 right-3 font-mono text-[8px] text-(--accent) uppercase tracking-wider">[SYS.ACTIVE]</span>
                        
                        <div>
                            <h3 class="cypher-text mb-4 font-mono text-xs font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wide" data-original="Frontend Subsystem">Frontend Subsystem</h3>
                            <div class="flex flex-wrap gap-2.5">
                                {techGroups.Frontend.map((tech) => (
                                    <div class="group/tech relative flex items-center gap-2 border border-slate-200 dark:border-white/10 bg-white/50 dark:bg-black/30 px-3 py-1 rounded-full text-[11px] font-medium text-slate-800 dark:text-slate-200 hover:border-(--accent) hover:shadow-[0_0_10px_var(--accent-glow)] transition-all duration-300">
                                        <span>{tech.name}</span>
                                        {tech.deployment && (
