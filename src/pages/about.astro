---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TechMarquee from '../components/TechMarquee.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';

import { techGroups } from '../data/techStack';

// Library Tracking Data
const booksRead = 7;
const booksGoal = 52;
const readingProgress = Math.min(Math.round((booksRead / booksGoal) * 100), 100);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`About | ${SITE_TITLE}`}
            description="Learn more about Dhaatrik's journey and tech stack."
        />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <Header />
        <main
            id="main-content"
            tabindex="-1"
            class="layout-container relative grow space-y-20 py-8"
        >
            <div
                class="pointer-events-none absolute top-32 right-0 -z-10 text-slate-900 opacity-5 dark:text-white"
            >
                <svg
                    width="400"
                    height="400"
                    viewBox="0 0 200 200"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        d="M100 100 m-80,0 a80,80 0 1,0 160,0 a80,80 0 1,0 -160,0 M100 100 m-60,0 a60,60 0 1,0 120,0 a60,60 0 1,0 -120,0 M100 100 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 M20 100 h160 M100 20 v160"
                    ></path>
                </svg>
            </div>

            <section class="max-w-4xl">
                <div class="mb-16 flex flex-col items-center gap-8 md:flex-row md:items-start">
                    <div class="w-full shrink-0 md:w-1/3">
                        <img
                            src="/me.jpeg"
                            alt="Dhaatrik"
                            loading="eager"
                            fetchpriority="high"
                            class="aspect-square w-full rounded-2xl border border-slate-200 object-cover shadow-xl grayscale transition-all duration-500 hover:grayscale-0 dark:border-white/10"
                        />
                    </div>
                    <div class="w-full md:w-2/3">
                        <h1
                            class="mb-2 text-4xl leading-tight font-bold text-slate-900 md:text-5xl dark:text-white"
                        >
                            About Me
                        </h1>
                        <span class="mb-6 block font-mono text-sm text-(--accent)"
                            >Current Status: Q2 2026</span
                        >

                        <div
                            class="space-y-6 text-lg leading-relaxed text-slate-600 dark:text-(--text-secondary)"
                        >
                            <p>
                                I’m Dhaatrik, an engineer and entrepreneur driven by a relentless
                                curiosity for how the universe operates. I build robust,
                                data-sovereign systems by stripping complex problems down to their
                                fundamental truths.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="relative z-10 mb-20 max-w-5xl">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div class="relative z-10">
                            <h2
                                class="mb-4 flex items-center gap-2 text-2xl font-bold text-slate-900 dark:text-white"
                            >
                                <svg
                                    class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)"
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><rect x="4" y="4" width="16" height="16" rx="2" ry="2"
                                    ></rect><rect x="9" y="9" width="6" height="6"></rect><line
                                        x1="9"
                                        y1="1"
                                        x2="9"
                                        y2="4"></line><line x1="15" y1="1" x2="15" y2="4"
                                    ></line><line x1="9" y1="20" x2="9" y2="23"></line><line
                                        x1="15"
                                        y1="20"
                                        x2="15"
                                        y2="23"></line><line x1="20" y1="9" x2="23" y2="9"
                                    ></line><line x1="20" y1="14" x2="23" y2="14"></line><line
                                        x1="1"
                                        y1="9"
                                        x2="4"
                                        y2="9"></line><line x1="1" y1="14" x2="4" y2="14"
                                    ></line></svg
                                >
                                <span class="cypher-text" data-original="What I'm Building"
                                    >What I'm Building</span
                                >
                            </h2>
                            <p class="leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                I'm currently focused on the agriculture domain, working to
                                integrate AI into the core fundamentals of farming to solve
                                real-world problems. I also love building tools for the community,
                                like <a
                                    href="https://github.com/dhaatrik"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-(--accent) decoration-dashed underline-offset-4 hover:underline"
                                    >Vellor</a
                                >, an offline-first tool for independent educators.
                            </p>
                        </div>
                    </div>

                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div
                            class="pointer-events-none absolute bottom-4 left-1/2 -translate-x-1/2 font-serif text-4xl whitespace-nowrap text-slate-900 opacity-5 blur-[1px] transition-opacity duration-500 select-none group-hover:opacity-10 sm:text-5xl dark:text-white"
                        >
                            Δv = v<sub>e</sub> ln(m<sub>0</sub> / m<sub>f</sub>)
                        </div>
                        <div class="relative z-10">
                            <h2
                                class="mb-4 flex items-center gap-2 text-2xl font-bold text-slate-900 dark:text-white"
                            >
                                <svg
                                    class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)"
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
                                    ></path><path
                                        d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
                                    ></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"
                                    ></path><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"
                                    ></path></svg
                                >
                                <span class="cypher-text" data-original="What I'm Learning"
                                    >What I'm Learning</span
                                >
                            </h2>
                            <p class="leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                My curiosity pulls me toward the intricacies of reality. Right now,
                                that means diving deep into the math of rocket engineering, the
                                weirdness of quantum mechanics, and the fascinating depths of human
                                psychology.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="relative mb-20 max-w-5xl">
                <h2 class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">
                    Current Trajectory
                </h2>

                <div class="bento-card group relative overflow-hidden p-0">
                    {/* Background abstract radar pattern */}
                    <div
                        class="pointer-events-none absolute inset-0 opacity-20 transition-opacity duration-500 group-hover:opacity-40"
                        style="background-image: radial-gradient(circle at 100% 0%, var(--accent-glow) 0%, transparent 50%);"
                    >
                    </div>

                    <div class="relative z-10 grid grid-cols-1 md:grid-cols-[1fr_2.5fr]">
                        {/* Left sidebar - Telemetry/Status */}
                        <div
                            class="flex flex-col justify-between border-b border-slate-100 bg-slate-50/50 p-6 md:border-r md:border-b-0 md:p-8 dark:border-white/5 dark:bg-black/20"
                        >
                            <div>
                                <div
                                    class="mb-6 inline-flex items-center gap-2 rounded-full border border-(--accent)/20 bg-(--accent)/10 px-3 py-1 font-mono text-[10px] font-bold tracking-widest text-(--accent) uppercase shadow-sm"
                                >
                                    <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-(--accent)"
                                    ></span>
                                    Telemetry Active
                                </div>
                                <h3
                                    class="mb-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-white"
                                >
                                    Q1 2025
                                </h3>
                                <p class="font-mono text-xs text-slate-500 dark:text-slate-400">
                                    STATUS: Post-Flight Analysis
                                </p>
                            </div>

                            <div class="mt-12 hidden md:block">
                                <div
                                    class="mb-2 text-[10px] font-bold tracking-widest text-slate-400 uppercase"
                                >
                                    Focus Node
                                </div>
                                <div class="font-mono text-lg font-bold text-(--accent)">FuelDrop</div>
                                <div class="mt-1 text-xs text-slate-500">Logistics / Ag-Tech</div>
                            </div>
                        </div>

                        {/* Right content - Mission Log */}
                        <div class="flex flex-col justify-center p-6 md:p-8">
                            <div class="mb-6 flex items-start justify-between">
                                <h4
                                    class="flex items-center gap-2 text-xl font-bold text-slate-900 dark:text-white"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-slate-400"
                                        ><path
                                            d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                        ></path></svg
                                    >
                                    A Note on the Journey
                                </h4>
                                <span
                                    class="rounded border border-(--accent)/20 bg-(--accent)/10 px-2 py-1 font-mono text-[10px] text-(--accent) shadow-sm"
                                    >LOG_ENTRY: 402</span
                                >
                            </div>

                            <div
                                class="space-y-5 text-sm leading-relaxed text-slate-600 md:text-base dark:text-(--text-secondary)"
                            >
                                <p>
                                    <strong class="font-medium text-slate-900 dark:text-white"
                                        >FuelDrop</strong
                                    > was more than just a codebase; it was my primary startup focus during
                                    the first quarter of 2025. I'll soon be sharing a comprehensive deep-dive
                                    article detailing the entire lifecycle of this venture.
                                </p>
                                <div class="my-4 border-l-2 border-(--accent) py-1 pl-4">
                                    <p
                                        class="font-medium text-slate-700 italic dark:text-slate-300"
                                    >
                                        "Knowledge kept secret is knowledge wasted."
                                    </p>
                                </div>
                                <p>
                                    I'll be pulling back the curtain on the raw reality of building
                                    an on-demand logistics startup, the "hard-knock" lessons
                                    learned, and the technical breakdowns.
                                    <span
                                        class="cypher-text ml-1 cursor-crosshair font-bold text-(--accent) underline decoration-dashed underline-offset-4"
                                        data-original="Stay tuned.">Stay tuned.</span
                                    >
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-20 max-w-5xl">
                <h2 class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">
                    Signal & Metrics
                </h2>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    {/* 1. The "52-Book Trajectory" Library Card */}
                    <div
                        class="bento-card group relative flex flex-col justify-between overflow-hidden p-6"
                    >
                        <div class="relative z-10">
                            <div class="mb-4 flex items-start justify-between">
                                <h3
                                    class="flex items-center gap-2 font-bold text-slate-900 dark:text-white"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-(--accent)"
                                        ><path
                                            d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
                                        ></path></svg
                                    >
                                    Library Trajectory
                                </h3>
                                <span class="font-mono text-xs text-(--text-secondary)">2026 Goal</span>
                            </div>
                            <div class="mb-4">
                                <div class="mb-1 flex justify-between text-sm">
                                    <span class="text-slate-600 dark:text-slate-400"
                                        >Books Read</span
                                    >
                                    <span class="font-mono text-(--accent)"
                                        >{booksRead} / {booksGoal}</span
                                    >
                                </div>
                                <div
                                    class="h-2 w-full overflow-hidden rounded-full bg-slate-200 dark:bg-white/5"
                                >
                                    <div
                                        class="h-full rounded-full bg-(--accent)"
                                        style={`width: ${readingProgress}%`}
                                    >
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="relative z-10 mt-4 space-y-3">
                            <div
                                class="rounded-lg border border-slate-100 bg-slate-50 p-3 transition-colors group-hover:border-(--accent)/30 dark:border-white/5 dark:bg-black/20"
                            >
                                <span
                                    class="mb-1 block text-xs tracking-wider text-slate-500 uppercase dark:text-slate-400"
                                    >Currently Reading</span
                                >
                                <div class="flex items-center justify-between gap-4">
                                    <span
                                        class="truncate text-sm font-medium text-slate-900 dark:text-white"
                                        >Elon Musk - Ashlee Vance</span
                                    >
                                    <a
                                        aria-label="Buy Elon Musk - Ashlee Vance (opens in a new tab)"
                                        href="https://www.amazon.in/Elon-Musk-Billionaire-SpaceX-Shaping-ebook/dp/B00SIDCSWY"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="shrink-0 rounded bg-(--accent) px-3 py-1 text-[10px] font-bold text-white uppercase shadow-sm transition-all hover:bg-blue-600 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:focus-visible:ring-offset-(--bg-main)"
                                        >Buy</a
                                    >
                                </div>
                            </div>
                            <button
                                onclick="document.getElementById('books-modal').showModal()"
                                class="w-full rounded-lg bg-slate-900 py-2 text-sm font-bold text-white shadow-sm transition-all hover:bg-slate-800 hover:shadow-[0_0_15px_var(--accent-glow)] focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200 dark:focus-visible:ring-offset-(--bg-main)"
                            >
                                Recommended Books
                            </button>
                        </div>
                    </div>

                    {/* 6. Monthly Insights Terminal Snippet */}
                    <div
                        class="bento-card flex h-full flex-col overflow-hidden border-[#333] bg-[#1e1e1e] p-0 text-left dark:border-[#333] dark:bg-[#1e1e1e]"
                    >
                        <div
                            class="flex items-center gap-2 border-b border-[#111] bg-[#2d2d2d] px-4 py-2"
                        >
                            <div class="flex gap-1.5">
                                <div class="h-3 w-3 rounded-full bg-[#ff5f56]"></div>
                                <div class="h-3 w-3 rounded-full bg-[#ffbd2e]"></div>
                                <div class="h-3 w-3 rounded-full bg-[#27c93f]"></div>
                            </div>
                            <span class="ml-2 font-mono text-xs text-[#888]">bash</span>
                        </div>
                        <div class="grow p-4 font-mono text-sm">
                            <div class="mb-2 text-[#50fa7b]">$ cat /logs/may-reflection.txt</div>
                            <div class="leading-relaxed text-[#f8f8f2]">
                                <span class="text-[#bd93f9]">"</span>Optimization is a trap if you
                                haven't nailed the fundamentals first. Build robust, scale later.<span
                                    class="text-[#bd93f9]">"</span
                                >
                            </div>
                            <div class="mt-2 animate-pulse text-[#50fa7b]">_</div>
                        </div>
                    </div>
                </div>
            </section>

            {/* 8. Interactive Terminal Contact CTA */}
            <section class="mb-12 max-w-5xl">
                <div
                    class="bento-card group relative flex flex-col items-center overflow-hidden border-slate-200 bg-slate-50 p-8 text-center md:p-12 dark:border-[#30363d] dark:bg-[#0d1117]"
                >
                    <div class="bg-grid-motif pointer-events-none absolute inset-0 opacity-10">
                    </div>
                    <div class="relative z-10 w-full max-w-2xl">
                        <h2
                            class="mb-4 font-mono text-3xl font-bold text-slate-900 md:text-4xl dark:text-white"
                        >
                            &gt; Let's Connect
                        </h2>
                        <p
                            class="mb-8 font-mono text-sm leading-relaxed text-slate-600 md:text-base dark:text-slate-400"
                        >
                            Want to discuss multi-agent orchestration, rocket kinematics, or the
                            future of ag-tech?
                        </p>

                        <div class="mt-4 flex justify-center">
                            <a
                                href={SOCIAL_LINKS.twitter}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="Connect on X (opens in a new tab)"
                                class="group relative inline-flex items-center justify-center gap-2 rounded-lg bg-(--accent) px-8 py-3 font-mono font-bold text-white transition-all hover:-translate-y-1 hover:bg-blue-600 hover:shadow-[0_8px_30px_var(--accent-glow)] focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:focus-visible:ring-offset-(--bg-main)"
                            >
                                <span aria-hidden="true">~ $ connect --x</span>
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="transition-transform group-hover:translate-x-1"
                                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
                                >
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="max-w-5xl content-visibility-auto-tech-stack">
                <h2 class="mb-8 text-3xl font-bold text-slate-900 dark:text-white">
                    My Tech Stack
                </h2>
                <TechMarquee techGroups={techGroups} />
            </section>

            {/* Recommended Books Modal */}
            <dialog
                id="books-modal"
                aria-labelledby="books-modal-title"
                onclick="event.target === this && this.close()"
                class="m-auto w-full max-w-lg rounded-2xl border border-slate-200 bg-white p-0 shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm dark:border-white/10 dark:bg-[#0b0e14]"
            >
                <div
                    class="flex items-center justify-between border-b border-slate-100 p-6 dark:border-white/5"
                >
                    <h3
                        id="books-modal-title"
                        class="flex items-center gap-3 text-xl font-bold text-slate-900 dark:text-white"
                    >
                        Recommended Books
                        <span
                            class="rounded-full border border-(--accent) px-2 py-0.5 text-[10px] font-bold tracking-wider text-(--accent) uppercase opacity-80"
                            >Not Sponsored</span
                        >
                    </h3>
                    <button
                        aria-label="Close recommended books modal"
                        onclick="document.getElementById('books-modal').close()"
                        class="cursor-pointer rounded-sm p-1 text-slate-500 transition-colors hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:hover:text-white dark:focus-visible:ring-offset-(--bg-main)"
                    >
                        <svg
                            width="24"
                            height="24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"><path d="M18 6L6 18M6 6l12 12"></path></svg
                        >
                    </button>
                </div>
                <div class="max-h-[60vh] space-y-4 overflow-y-auto p-6">
                    {
                        [
                            {
                                title: 'As a Man Thinketh',
                                author: 'James Allen',
                                link: 'https://www.amazon.in/As-Man-Thinketh-James-Allen/dp/9386538172',
                            },
                            {
                                title: 'How to Win Friends and Influence People',
                                author: 'Dale Carnegie',
                                link: 'https://www.amazon.in/How-Win-Friends-Influence-People/dp/0671027034?s=bazaar',
                            },
                            {
                                title: 'Marketing Management',
                                author: 'Philip Kotler',
                                link: 'https://www.amazon.in/Marketing-Management-17th-Philip-Kotler/dp/9367138199/ref=sr_1_1_sspa?crid=3LXWM7OV5BGZC&dib=eyJ2IjoiMSJ9.sLFz-n94M3czJDqJ9PP_32HJu72s7iE60M-ItoJp6vdG_i_luKRHC5qjtvFvbwdbhaDQcAcqREZdFZ0Ed0tq4MvMlFxqTsTgReZYC_jjnP86oxfOhad4BxPUlGEJKdmeDfCW7VZbG3SKTxzuPh-YvA4b-NlscmOi4It-IP8RT0okW55U_hkkSUZ4gnB6BNKsQFpR4PmxOjdhLWS8dOlLIbyIG8aAQeS7EB0glkLcZRw.TSj1dE0pcTX9PnG4fTof_JbQM04mjr9Rv2TPs-ne3zg&dib_tag=se&keywords=marketing+management+by+philip+kotler&qid=1778389155&sprefix=Marketing%2Caps%2C567&sr=8-1-spons&aref=WM64g7r717&sp_csd=d2lkZ2V0TmFtZT1zcF9hdGY&psc=1',
                            },
                            {
                                title: 'Zero to One',
                                author: 'Peter Thiel',
                                link: 'https://www.amazon.in/Zero-One-Notes-Startups-Future/dp/0804139296',
                            },
                            {
                                title: 'The Pragmatic Programmer',
                                author: 'Andrew Hunt & David Thomas',
                                link: 'https://www.amazon.in/Pragmatic-Programmer-journey-mastery-20th/dp/0135957052',
                            },
                            {
                                title: 'Deep Work',
                                author: 'Cal Newport',
                                link: 'https://www.amazon.in/Deep-Work-Rules-Focused-Success/dp/0349411905',
                            },
                            {
                                title: 'Atomic Habits',
                                author: 'James Clear',
                                link: 'https://www.amazon.in/Atomic-Habits-James-Clear/dp/1847941834',
                            },
                            {
                                title: 'Clean Code',
                                author: 'Robert C. Martin',
                                link: 'https://www.amazon.in/Clean-Code-Handbook-Software-Craftsmanship/dp/0132350882',
                            },
                            {
                                title: 'The Lean Startup',
                                author: 'Eric Ries',
                                link: 'https://www.amazon.in/Lean-Startup-Eric-Ries/dp/0307887898',
                            },
                            {
                                title: 'The Alchemist',
                                author: 'Paulo Coelho',
                                link: 'https://www.amazon.in/Alchemist-Paulo-Coelho/dp/8172234988',
                            },
                        ].map((book) => (
                            <div class="flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50 p-3 transition-colors hover:border-slate-300 dark:border-white/5 dark:bg-white/5 dark:hover:border-white/20">
                                <div>
                                    <h4 class="text-sm font-bold text-slate-900 dark:text-white">
                                        {book.title}
                                    </h4>
                                    <p class="mt-0.5 text-xs text-slate-500">{book.author}</p>
                                </div>
                                <a
                                    aria-label={`Buy ${book.title} (opens in a new tab)`}
                                    href={book.link}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="rounded-md bg-(--accent) px-4 py-1.5 text-xs font-bold text-white shadow-sm transition-all hover:bg-blue-600 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:focus-visible:ring-offset-(--bg-main)"
                                >
                                    Buy
                                </a>
                            </div>
                        ))
                    }
                </div>
            </dialog>
        </main>
        <Footer />
        <script>
            document.addEventListener('astro:page-load', () => {
                // Scramble / Cypher Text Hover Effects
                const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*';
                const cypherElements = document.querySelectorAll('.cypher-text');
                const activeIntervals = new Map<HTMLElement, ReturnType<typeof setInterval>>();

                cypherElements.forEach((el) => {
                    const element = el as HTMLElement;
                    const originalText = element.dataset.original || '';
                    const length = originalText.length;

                    const startScramble = () => {
                        let iterations = 0;
                        if (activeIntervals.has(element)) {
                            clearInterval(activeIntervals.get(element)!);
                        }

                        const interval = setInterval(() => {
                            element.innerText = originalText
                                .split('')
                                .map((letter: string, index: number) => {
                                    if (index < iterations) return originalText[index];
                                    return letters[Math.floor(Math.random() * letters.length)];
                                })
                                .join('');

                            if (iterations >= length) {
                                clearInterval(interval);
                                activeIntervals.delete(element);
                            }
                            iterations += 1 / 3;
                        }, 30);

                        activeIntervals.set(element, interval);
                    };

                    element.addEventListener('mouseenter', startScramble);
                });

                // The "Offline-First" Easter Egg
                const handleOffline = () => {
                    const toast = document.createElement('div');
                    toast.className =
                        'fixed bottom-6 right-6 bg-slate-900 border border-(--accent) text-white p-4 rounded-lg shadow-2xl z-50 font-mono text-sm max-w-sm translate-y-10 opacity-0 transition-all duration-300';
                    toast.innerHTML = `<span class="text-(--accent) font-bold">Vellor Protocol Engaged:</span> You are offline, but this data remains accessible.`;
                    document.body.appendChild(toast);

                    // Animate in
                    setTimeout(() => {
                        toast.classList.remove('translate-y-10', 'opacity-0');
                    }, 100);

                    // Remove after 6 seconds
                    setTimeout(() => {
                        toast.classList.add('translate-y-10', 'opacity-0');
                        setTimeout(() => toast.remove(), 300);
                    }, 6000);
                };

                window.addEventListener('offline', handleOffline);

                // Cleanup Event Listeners on Page Transition
                document.addEventListener('astro:before-preparation', () => {
                    // Clear all active cypher intervals
                    activeIntervals.forEach((interval) => clearInterval(interval));
                    activeIntervals.clear();

                    // Remove offline event listener
                    window.removeEventListener('offline', handleOffline);
                }, { once: true });
            });
        </script>
    </body>
</html>
