        <script>
            document.addEventListener('astro:page-load', () => {
                // 1. Coordinated parallel decode animation on load
                const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*';
                const cypherElements = Array.from(
                    document.querySelectorAll('.cypher-text')
                ) as HTMLElement[];
                const activeIntervals = new Map<HTMLElement, ReturnType<typeof setInterval>>();

                const decodeElement = (element: HTMLElement): Promise<void> => {
                    return new Promise((resolve) => {
                        const originalText = element.dataset.original || '';
                        const length = originalText.length;
                        let iterations = 0;

                        if (activeIntervals.has(element)) {
                            clearInterval(activeIntervals.get(element)!);
                        }

                        const interval = setInterval(() => {
                            element.innerText = originalText
                                .split('')
                                .map((letter: string, index: number) => {
                                    if (index < iterations) return originalText[index];
                                    return letters[Math.floor(Math.random() * letters.length)];
                                })
                                .join('');

                            if (iterations >= length) {
                                clearInterval(interval);
                                activeIntervals.delete(element);
                                resolve();
                            }
                            iterations += 1 / 3;
                        }, 30);

                        activeIntervals.set(element, interval);
                    });
                };

                const runParallelDecode = () => {
                    cypherElements.forEach((el) => decodeElement(el));
                };

                runParallelDecode();

                // 2. Scroll-triggered IntersectionObserver Typewriter for Terminal
                const terminalSnippet = document.getElementById('terminal-snippet');
                let typewriterTimeout: ReturnType<typeof setTimeout> | null = null;

                if (terminalSnippet) {
                    const rawText = terminalSnippet.dataset.text || '';
                    let index = 0;
                    let isTyping = false;

                    const typeWriter = () => {
                        if (index <= rawText.length) {
                            let displayed = '<span class="text-[#bd93f9]">"</span>';
                            displayed += rawText.substring(0, index);
                            if (index < rawText.length) {
                                displayed += '<span class="animate-pulse">█</span>';
                            } else {
                                displayed += '<span class="text-[#bd93f9]">"</span>';
                            }
                            terminalSnippet.innerHTML = displayed;
                            index++;
                            typewriterTimeout = setTimeout(typeWriter, 45);
                        }
                    };

                    const observer = new IntersectionObserver(
                        (entries) => {
                            entries.forEach((entry) => {
                                if (entry.isIntersecting && !isTyping) {
                                    isTyping = true;
                                    typeWriter();
                                    observer.unobserve(entry.target);
                                }
                            });
                        },
                        { threshold: 0.1 }
                    );

                    observer.observe(terminalSnippet);
                }

                // 4. Kinetic Reticle Mouse Tracking Parallax
                const reticle = document.getElementById('reticle-bg');
                let reticleRafId: number | null = null;
                let mouseX = 0;
                let mouseY = 0;

                const updateReticleParallax = () => {
                    const x = (mouseX - window.innerWidth / 2) / (window.innerWidth / 2);
                    const y = (mouseY - window.innerHeight / 2) / (window.innerHeight / 2);

                    const moveX = x * 8; // max 8px
                    const moveY = y * 8; // max 8px
                    const rotate = x * 5; // max 5deg

                    if (reticle) {
                        reticle.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) rotate(${rotate}deg)`;
                    }
                    reticleRafId = null;
                };

                const handleReticleParallax = (e: MouseEvent) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;
                    if (!reticleRafId) {
                        reticleRafId = window.requestAnimationFrame(updateReticleParallax);
                    }
                };

                window.addEventListener('mousemove', handleReticleParallax);

                // 5. The "Offline-First" Easter Egg
                const handleOffline = () => {
                    const toast = document.createElement('div');
                    toast.className =
                        'fixed bottom-6 right-6 bg-slate-900 border border-(--accent) text-white p-4 rounded-lg shadow-2xl z-50 font-mono text-sm max-w-sm translate-y-10 opacity-0 transition-all duration-300';
                    toast.innerHTML = `<span class="text-(--accent) font-bold">Vellor Protocol Engaged:</span> You are offline, but this data remains accessible.`;
                    document.body.appendChild(toast);

                    // Animate in
                    setTimeout(() => {
                        toast.classList.remove('translate-y-10', 'opacity-0');
                    }, 100);

                    // Remove after 6 seconds
                    setTimeout(() => {
                        toast.classList.add('translate-y-10', 'opacity-0');
                        setTimeout(() => toast.remove(), 300);
                    }, 6000);
                };

                window.addEventListener('offline', handleOffline);

                // Cleanup Event Listeners on Page Transition
                document.addEventListener(
                    'astro:before-preparation',
                    () => {
                        // Clear cypher intervals
                        activeIntervals.forEach((interval) => clearInterval(interval));
                        activeIntervals.clear();

                        // Clear typewriter timeout
                        if (typewriterTimeout) {
                            clearTimeout(typewriterTimeout);
                        }

                        // Remove mousemove listener
                        window.removeEventListener('mousemove', handleReticleParallax);
                        if (reticleRafId) {
                            window.cancelAnimationFrame(reticleRafId);
                        }

                        // Remove offline event listener
                        window.removeEventListener('offline', handleOffline);
                    },
                    { once: true }
                );
            });
        </script>
