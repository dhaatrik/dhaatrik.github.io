---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects')).sort(
    (a, b) => a.data.order - b.data.order
);

const getProjectTelemetry = (id: string) => {
    const rawId = id.replace(/\.md$/, '');
    switch (rawId) {
        case 'vellor':
            return 'STATUS: V4_IN_DEV // DB: OFF_LINE_FIRST // SYNC: LOCAL';
        case 'deltav-lab':
            return 'STATUS: VERIFIED // ITERATION: RK4_50HZ // R&D: ACTIVE';
        case 'fueldrop':
            return 'STATUS: COMPLETED // ARCH: HIGH_CONCURRENCY // React 19';
        case 'the-infinite-intelligence':
            return 'STATUS: STABLE // INFRA: GEMINI_API // MULTI_AGENT: OK';
        case 'instant-app-opener':
            return 'STATUS: STABLE // ARCH: ELECTRON_LOCAL // LATENCY: SUB_150MS';
        case 'glassbox':
            return 'STATUS: STABLE // SECURITY: SANDBOX_ISOLATED // ENGINE: VM2';
        case 'expense-vs-investment-tracker':
            return 'STATUS: COMPLETED // VISUALS: CHART_JS // PERSISTENCE: LOCAL';
        case 'seamless-qr-dining':
            return 'STATUS: PROTOTYPE // R&D: COMPLETED // SOCKETS: REAL_TIME';
        case 'vireo-wellness':
            return 'STATUS: COMPLETED // DB: INDEXED_DB // PRIVATE: 100%';
        case 'bill-express':
            return 'STATUS: OPERATIONAL // VIS: PRINT_GRIDS // PDF: CLIENT_SIDE';
        case 'free-markdown-to-pdf-converter':
            return 'STATUS: STABLE // COMPILER: REMARK // FORMATS: KATEX_LA_TEX';
        case 'readaloud_chromeextension':
            return 'STATUS: STABLE // ENGINE: WEB_SPEECH_API // COMPLIANCE: MV3';
        default:
            return 'STATUS: OPERATIONAL // COMPILED: OK';
    }
};

// Generate WebPage & ItemList JSON-LD Schema
const webpageSchema = {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: `Projects Archive | ${SITE_TITLE}`,
    description: "My project workbench — things I've shipped, shelved, or am still patching at 2 AM.",
    url: new URL(Astro.url.pathname, Astro.site).href,
    mainEntity: {
        '@type': 'ItemList',
        itemListElement: projects.map((project, idx) => ({
            '@type': 'ListItem',
            position: idx + 1,
            url: new URL(`/projects/${project.id.replace(/\.md$/, '')}/`, Astro.site).href,
            name: project.data.title,
            description: project.data.description,
        })),
    },
};
const jsonLd = JSON.stringify(webpageSchema);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Projects | ${SITE_TITLE}`}
            description="My project workbench — things I've shipped, shelved, or am still patching at 2 AM."
        />
        <script type="application/ld+json" set:html={jsonLd} />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <!-- Flashlight Spotlight Background -->
        <div id="flashlight-bg" class="pointer-events-none fixed inset-0 z-0"></div>

        <Header />
        
        <main
            id="main-content"
            tabindex="-1"
            class="relative grow overflow-x-hidden py-12 md:py-20"
        >
            <div
                id="reticle-bg"
                class="pointer-events-none absolute top-32 right-0 -z-10 text-slate-900 opacity-5 transition-transform duration-300 ease-out dark:text-white"
            >
                <svg
                    width="400"
                    height="400"
                    viewBox="0 0 200 200"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M 20 20 L 20 180 L 180 180 L 180 20 Z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 19"
                        opacity="0.3"
                    ></path>
                    <path
                        d="M 40 20 L 40 180 M 60 20 L 60 180 M 80 20 L 80 180 M 120 20 L 120 180 M 140 20 L 140 180 M 160 20 L 160 180"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 9"
                        opacity="0.15"
                    ></path>
                    <path
                        d="M 20 40 L 180 40 M 20 60 L 180 60 M 20 80 L 180 80 M 20 120 L 180 120 M 20 140 L 180 140 M 20 160 L 180 160"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 9"
                        opacity="0.15"
                    ></path>
                    <circle
                        cx="100"
                        cy="100"
                        r="90"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="2 8"
                        opacity="0.4"
                    ></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="80"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="3 3"
                    ></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="60"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="6 6"
                    ></circle>
                    <line
                        x1="10"
                        y1="100"
                        x2="190"
                        y2="100"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="2 4"
                    ></line>
                    <line
                        x1="100"
                        y1="10"
                        x2="100"
                        y2="190"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="2 4"
                    ></line>
                </svg>
            </div>

            <section class="layout-container">
                <div class="mb-12 border-b border-slate-200/60 pb-8 dark:border-white/5">
                    <div class="mb-2 font-mono text-xs tracking-widest text-(--accent)">
                        // projects_archive.db
                    </div>
                    <h1
                        class="mb-4 text-4xl leading-tight font-bold tracking-tight text-slate-900 md:text-5xl dark:text-white"
                    >
                        Project Workbench <span class="text-slate-400 dark:text-slate-600">& Archive</span>
                    </h1>
                    <p class="max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                        Things I've shipped, abandoned, or am still fixing. Web apps, offline tools,
                        browser extensions, and sandbox experiments — each with an honest mission log.
                    </p>
                </div>

                <!-- Bento-like grid listing all 12 projects -->
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                    {
                        projects.map((project) => {
                            const telemetryStr = getProjectTelemetry(project.id);
                            const projectIdClean = project.id.replace(/\.md$/, '');
                            return (
                                <article
                                    class="bento-card group relative flex min-h-[320px] flex-col justify-between overflow-hidden p-6 transition-all duration-300 focus-within:shadow-[0_0_20px_var(--accent-glow)] hover:-translate-y-1 hover:shadow-[0_0_20px_var(--accent-glow)]"
                                >
                                    <div class="hologram-overlay" />
                                    
                                    <div
                                        class="relative z-10 flex h-full flex-col justify-between"
                                        data-tilt-z
                                    >
                                        <div>
                                            <div class="mb-4 flex min-w-0 items-center justify-between gap-4 border-b border-slate-200/50 pb-2 font-mono text-[9px] text-slate-400 dark:border-white/5 dark:text-slate-500">
                                                <div class="flex min-w-0 items-center gap-1.5">
                                                    <span class="h-1.5 w-1.5 shrink-0 animate-pulse rounded-full bg-green-500" />
                                                    <span class="truncate">{telemetryStr}</span>
                                                </div>
                                                <span class="shrink-0 font-bold text-(--accent)">
                                                    [ OK ]
                                                </span>
                                            </div>

                                            <div class="mb-4 flex items-start justify-between gap-4">
                                                <h3 class="text-2xl font-bold leading-tight text-slate-900 transition-colors dark:text-white">
                                                    <a
                                                        href={`/projects/${projectIdClean}`}
                                                        data-astro-prefetch="hover"
                                                        class="after:absolute after:inset-0 after:z-10 focus:outline-none"
                                                    >
                                                        {project.data.title}
                                                    </a>
                                                </h3>
                                                {project.data.githubUrl && (
                                                    <a
                                                        href={project.data.githubUrl}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        aria-label={`View ${project.data.title} on GitHub (opens in a new tab)`}
                                                        title={`View ${project.data.title} on GitHub`}
                                                        class="github-link relative z-20 text-slate-500 transition-colors hover:text-slate-900 focus-visible:text-slate-900 dark:text-(--text-secondary) dark:hover:text-white dark:focus-visible:text-white"
                                                    >
                                                        <svg
                                                            viewBox="0 0 16 16"
                                                            aria-hidden="true"
                                                            width="22"
                                                            height="22"
                                                        >
                                                            <path
                                                                fill="currentColor"
                                                                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                                                            />
                                                        </svg>
                                                    </a>
                                                )}
                                            </div>
                                            <p class="mb-6 text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                                {project.data.description}
                                            </p>
                                        </div>

                                        <div class="space-y-4">
                                            {project.data.tags && project.data.tags.length > 0 && (
                                                <div class="flex flex-wrap gap-1.5 font-mono text-[9px]">
                                                    {project.data.tags.map((tag) => (
                                                        <span class="rounded bg-slate-100 px-2 py-0.5 text-slate-600 dark:bg-white/5 dark:text-slate-400">
                                                            #{tag.toUpperCase()}
                                                        </span>
                                                    ))}
                                                </div>
                                            )}
                                            <div class="flex items-center justify-between border-t border-slate-200/50 pt-3 font-mono text-[9px] text-slate-400 dark:border-white/5 dark:text-slate-500">
                                                <span class="truncate">
                                                    PROGRESS: {project.data.progress}
                                                </span>
                                                <span class="text-xs transition-transform group-hover:translate-x-1">
                                                    →
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </section>
        </main>
        
        <Footer />
    </body>
</html>
