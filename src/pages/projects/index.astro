---
import { getCollection, type CollectionEntry } from 'astro:content';
import { getPainLevelLabel, parseTelemetry } from '../../data/status';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

type ProjectEntry = CollectionEntry<'projects'>;

const projects = (await getCollection('projects')).sort(
    (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) => a.data.order - b.data.order
);





// Generate WebPage & ItemList JSON-LD Schema
const webpageSchema = {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: `Projects Archive | ${SITE_TITLE}`,
    description: "My project workbench — things I've shipped, shelved, or am still patching at 2 AM.",
    url: new URL(Astro.url.pathname, Astro.site).href,
    mainEntity: {
        '@type': 'ItemList',
        itemListElement: projects.map((project: CollectionEntry<'projects'>, idx: number) => ({
            '@type': 'ListItem',
            position: idx + 1,
            url: new URL(`/projects/${project.id.replace(/\.md$/, '')}/`, Astro.site).href,
            name: project.data.title,
            description: project.data.description,
        })),
    },
};
const jsonLd = JSON.stringify(webpageSchema);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Projects | ${SITE_TITLE}`}
            description="My project workbench — things I've shipped, shelved, or am still patching at 2 AM."
        />
        <script is:inline type="application/ld+json" set:html={jsonLd} />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <!-- Flashlight Spotlight Background -->
        <div id="flashlight-bg" class="pointer-events-none fixed inset-0 z-0"></div>

        <Header />
        
        <main
            id="main-content"
            tabindex="-1"
            class="relative flex grow flex-col gap-(--section-gap-mobile) overflow-x-hidden py-(--section-gap-mobile) md:gap-(--section-gap-desktop) md:py-(--section-gap-desktop)"
        >
            <div
                id="reticle-bg"
                class="pointer-events-none absolute top-32 right-0 -z-10 text-slate-900 opacity-5 transition-transform duration-300 ease-out dark:text-white"
            >
                <svg
                    width="400"
                    height="400"
                    viewBox="0 0 200 200"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M 20 20 L 20 180 L 180 180 L 180 20 Z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 19"
                        opacity="0.3"
                    ></path>
                    <path
                        d="M 40 20 L 40 180 M 60 20 L 60 180 M 80 20 L 80 180 M 120 20 L 120 180 M 140 20 L 140 180 M 160 20 L 160 180"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 9"
                        opacity="0.15"
                    ></path>
                    <path
                        d="M 20 40 L 180 40 M 20 60 L 180 60 M 20 80 L 180 80 M 20 120 L 180 120 M 20 140 L 180 140 M 20 160 L 180 160"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="1 9"
                        opacity="0.15"
                    ></path>
                    <circle
                        cx="100"
                        cy="100"
                        r="90"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.3"
                        stroke-dasharray="2 8"
                        opacity="0.4"
                    ></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="80"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="3 3"
                    ></circle>
                    <circle
                        cx="100"
                        cy="100"
                        r="60"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="6 6"
                    ></circle>
                    <line
                        x1="10"
                        y1="100"
                        x2="190"
                        y2="100"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="2 4"
                    ></line>
                    <line
                        x1="100"
                        y1="10"
                        x2="100"
                        y2="190"
                        stroke="currentColor"
                        stroke-width="0.5"
                        stroke-dasharray="2 4"
                    ></line>
                </svg>
            </div>

            <section class="layout-container">
                <div class="mb-12 border-b border-slate-200/60 pb-8 dark:border-white/5 reveal-on-scroll">
                    <div class="mb-2 font-mono text-xs tracking-widest text-(--accent)">
                        // projects_archive.db
                    </div>
                    <h1
                        class="type-page-title mb-4 text-slate-900 dark:text-white"
                    >
                        Project Workbench <span class="text-slate-400 dark:text-slate-600">& Archive</span>
                    </h1>
                    <p class="type-body-lg max-w-2xl text-slate-600 dark:text-(--text-secondary)">
                        Hey buddy — these are things I've shipped, abandoned, or am still patching at
                        2 AM. If your repo looks like this too, you're in good company. Each one
                        ships with an honest mission log: what broke, what I learned.
                    </p>
                </div>

                <!-- Bento-like grid listing all 12 projects -->
                <div class="bento-grid reveal-stagger">
                    {
                        projects.map((project: ProjectEntry) => {
                            const telemetryStr = project.data.telemetry;
                            const [telemetryFirst, ...telemetryRestParts] = telemetryStr.split('//');
                            const telemetryRest = telemetryRestParts.join(' // ');
                            const projectIdClean = project.id.replace(/\.md$/, '');
                            const parsed = parseTelemetry(telemetryStr);
                            return (
                                <article
                                    class="bento-card mission-report-card group relative flex flex-col justify-between overflow-hidden transition-all duration-300 focus-within:shadow-[0_0_20px_var(--accent-glow)] hover:-translate-y-1 hover:shadow-[0_0_20px_var(--accent-glow)]"
                                >
                                    <div class="hologram-overlay" />
                                    
                                    <div
                                        class="relative z-10 flex h-full flex-col justify-between"
                                        data-tilt-z
                                    >
                                        <div class="mission-report-body">
                                            <div class="mission-report-telemetry type-telemetry flex min-w-0 items-center justify-between gap-4 text-slate-500 dark:text-slate-400">
                                                <div class="flex min-w-0 items-center gap-1.5">
                                                    <span class={`h-1.5 w-1.5 shrink-0 rounded-full ${parsed.colorClass}`} />
                                                    <span class="truncate">
                                                        <span class="telemetry-keyword">{telemetryFirst.trim()}</span>{telemetryRest && ` // ${telemetryRest.trim()}`}
                                                    </span>
                                                </div>
                                                <span class={`shrink-0 font-bold whitespace-nowrap ${parsed.textClass}`}>
                                                    {parsed.badgeText}
                                                </span>
                                            </div>

                                            <div class="mb-4 flex items-start justify-between gap-4">
                                                <h3 class="text-2xl font-bold leading-tight text-slate-900 transition-colors dark:text-white">
                                                    <a
                                                        href={`/projects/${projectIdClean}`}
                                                        data-astro-prefetch="hover"
                                                        class="after:absolute after:inset-0 after:z-10 focus:outline-none"
                                                    >
                                                        {project.data.title}
                                                    </a>
                                                </h3>
                                                {project.data.githubUrl && (
                                                    <a
                                                        href={project.data.githubUrl}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        aria-label={`View ${project.data.title} on GitHub (opens in a new tab)`}
                                                        title={`View ${project.data.title} on GitHub`}
                                                        class="github-link relative z-20 text-slate-500 transition-colors hover:text-slate-900 focus-visible:text-slate-900 dark:text-(--text-secondary) dark:hover:text-white dark:focus-visible:text-white"
                                                    >
                                                        <svg
                                                            viewBox="0 0 16 16"
                                                            aria-hidden="true"
                                                            width="22"
                                                            height="22"
                                                        >
                                                            <path
                                                                fill="currentColor"
                                                                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                                                            />
                                                        </svg>
                                                    </a>
                                                )}
                                            </div>
                                            <p class="line-clamp-3 mb-4 text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                                {project.data.description}
                                            </p>

                                            {/* Pain Level Indicator */}
                                            {project.data.pain_level && (
                                                <div class="mb-3 space-y-1.5">
                                                    <span class="block font-mono text-[9px] text-slate-400 dark:text-slate-600">
                                                        // IMPACT.LOG
                                                    </span>
                                                    <div
                                                        class="flex items-center gap-1"
                                                        role="meter"
                                                        aria-label={`Impact level: ${project.data.pain_level} out of 5`}
                                                        aria-valuetext={getPainLevelLabel(project.data.pain_level)}
                                                        aria-valuenow={project.data.pain_level}
                                                        aria-valuemin={1}
                                                        aria-valuemax={5}
                                                    >
                                                        {[1, 2, 3, 4, 5].map((i) => {
                                                            const colors: {[key: number]: string} = {
                                                                1: 'bg-[#8b5cf6] shadow-[0_0_6px_rgba(139,92,246,0.5)]', // Violet
                                                                2: 'bg-[#10b981] shadow-[0_0_6px_rgba(16,185,129,0.5)]', // Green
                                                                3: 'bg-[#eab308] shadow-[0_0_6px_rgba(234,179,8,0.5)]',  // Yellow
                                                                4: 'bg-[#f97316] shadow-[0_0_6px_rgba(249,115,22,0.5)]',  // Orange
                                                                5: 'bg-[#ef4444] shadow-[0_0_6px_rgba(239,68,68,0.5)]',  // Red
                                                            };
                                                            const activeColor = colors[project.data.pain_level ?? 1] ?? 'bg-(--accent)';
                                                            return (
                                                                <span
                                                                    aria-hidden="true"
                                                                    class={`h-1 w-5 rounded-sm transition-all duration-300 ${
                                                                        i <= (project.data.pain_level ?? 0)
                                                                            ? `${activeColor} opacity-90`
                                                                            : 'bg-slate-200 opacity-20 dark:bg-white/5'
                                                                    }`}
                                                                />
                                                            );
                                                        })}
                                                        <span class="ml-1 font-mono text-[9px] text-slate-400 dark:text-slate-600">
                                                            {project.data.pain_level}/5
                                                        </span>
                                                    </div>
                                                </div>
                                            )}

                                            {/* Fuckup Teaser */}
                                            {project.data.fuckup_teaser && (
                                                <div class="mb-4">
                                                    <div class="flex items-center gap-1.5 mb-1.5">
                                                        <span class="h-1.5 w-1.5 rounded-full bg-red-500 dark:bg-red-400 animate-pulse" />
                                                        <span class="block font-mono text-[9px] font-bold uppercase tracking-widest text-red-500 dark:text-red-400/90">
                                                            // FUCKUP.LOG
                                                        </span>
                                                    </div>
                                                    <div class="mission-fuckup-teaser">
                                                        <div class="mission-fuckup-teaser-inner">
                                                            {project.data.fuckup_teaser}
                                                        </div>
                                                    </div>
                                                </div>
                                            )}
                                         </div>

                                        <div class="space-y-4">
                                            {project.data.tags && project.data.tags.length > 0 && (
                                                <div class="flex flex-wrap gap-1.5 font-mono text-[9px]">
                                                    {project.data.tags.map((tag: string) => (
                                                        <span class="rounded bg-slate-100 px-2 py-0.5 text-slate-600 dark:bg-white/5 dark:text-slate-400">
                                                            #{tag.toUpperCase()}
                                                        </span>
                                                    ))}
                                                </div>
                                            )}
                                            <div class="mission-report-footer type-telemetry flex items-center justify-between text-slate-500 dark:text-slate-400">
                                                <span class="truncate">
                                                    PROGRESS: {project.data.progress}
                                                </span>
                                                <a
                                                    href={`/projects/${projectIdClean}`}
                                                    class="relative z-20 shrink-0 font-mono text-[9px] font-bold tracking-wider text-(--accent) transition-all hover:opacity-80 group-hover:translate-x-0.5"
                                                    aria-label={`Read the full ${project.data.title} mission log`}
                                                >
                                                    Read the full story&nbsp;→
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </section>
        </main>
        
        <Footer />
    </body>
</html>
