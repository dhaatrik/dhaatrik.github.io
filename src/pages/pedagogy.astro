                        </h2>
                        <p class="font-mono text-[10px] text-slate-500 uppercase mt-1">
                            // TOTAL_RECORDS: 20 // SUBJECT_FILTER: PHYSICS & MATHEMATICS
                        </p>
                    </div>
                    
                    <div id="video-announcer" class="sr-only" aria-live="polite"></div>

                    <!-- Subject Filtering Buttons -->
                    <div class="flex gap-2 font-mono text-xs select-none">
                        <button
                            data-subject="all"
                            aria-pressed="true"
                            class="subject-tab active cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)]"
                        >
                            [ ALL ]
                        </button>
                        <button
                            data-subject="physics"
                            aria-pressed="false"
                            class="subject-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)]"
                        >
                            [ PHYSICS ]
                        </button>
                        <button
                            data-subject="maths"
                            aria-pressed="false"
                            class="subject-tab cursor-pointer rounded-md border border-slate-300 bg-slate-100/80 px-3 py-1.5 text-slate-600 transition-all hover:border-slate-400 hover:bg-slate-200/50 dark:border-slate-800 dark:bg-[#151a22]/80 dark:text-slate-400 dark:hover:border-slate-700 [&.active]:border-(--accent) [&.active]:bg-(--accent)/10 [&.active]:text-(--accent) [&.active]:shadow-[0_0_12px_var(--accent-glow)]"
                        >
                            [ MATHEMATICS ]
                        </button>
