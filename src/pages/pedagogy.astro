                <!-- Bento-style Grid of YouTube Video Cards -->
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="video-grid">
                    {
                        youtubeVideos.map((video, idx) => (
                            <a
                                href={video.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                data-subject={video.subject}
                                class="bento-card video-card group relative flex flex-col overflow-hidden transition-all active:scale-[0.99] border-slate-200/80 dark:border-white/5"
