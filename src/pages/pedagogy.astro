                <!-- Empty State -->
                <div id="video-empty-state" class="hidden py-20 text-center" aria-hidden="true">
                    <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-slate-100 text-slate-400 dark:bg-slate-800 dark:text-slate-500">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    </div>
                    <h3 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">
                        No videos found in this category.
                    </h3>
                    <p class="mx-auto max-w-sm text-sm text-slate-500 dark:text-slate-400">
                        Looks like I haven't uploaded any videos for this subject yet.
                    </p>
                    <button
                        id="video-clear-filters-btn"
                        aria-label="Clear video filters"
                        class="mt-4 cursor-pointer rounded-md bg-(--accent) px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-600 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:focus-visible:ring-offset-(--bg-main)"
                    >
                        Clear Filters
                    </button>
                </div>
            </section>
        </main>
        <Footer />

        <script>
            // Client-side subject filtering for videos
            const setupVideoFilters = () => {
                // ⚡ Bolt: Replace querySelectorAll with getElementsByClassName for faster DOM traversal
                const tabs = Array.from(document.getElementsByClassName('subject-tab'));
                const cards = Array.from(document.getElementsByClassName('video-card'));

                if (tabs.length === 0) return;

                const applyFilter = (subject: string) => {
                    // Update active styles on tabs
                    tabs.forEach((t) => {
                        const htmlT = t as HTMLElement;
                        if (htmlT.dataset.subject === subject) {
                            htmlT.classList.add('active');
                            htmlT.setAttribute('aria-pressed', 'true');
                        } else {
                            htmlT.classList.remove('active');
                            htmlT.setAttribute('aria-pressed', 'false');
                        }
                    });

                    let visibleCount = 0;
                    // Filter videos
                    cards.forEach((card) => {
                        const htmlCard = card as HTMLElement;
                        const cardSubject = htmlCard.dataset.subject;

                        if (subject === 'all' || cardSubject === subject || (subject === 'maths' && cardSubject === 'maths') || (subject === 'physics' && cardSubject === 'physics')) {
                            htmlCard.style.display = '';
                            visibleCount++;
                        } else {
                            htmlCard.style.display = 'none';
                        }
                    });

                    if (emptyState) {
                        if (visibleCount === 0) {
                            emptyState.classList.remove('hidden');
                            emptyState.setAttribute('aria-hidden', 'false');
                        } else {
                            emptyState.classList.add('hidden');
                            emptyState.setAttribute('aria-hidden', 'true');
                        }
                    }

                    if (announcer) {
                        announcer.textContent = `Found ${visibleCount} video${visibleCount === 1 ? '' : 's'}.`;
                    }
                };

                tabs.forEach((tab) => {
                    tab.addEventListener('click', (e) => {
                        const target = e.currentTarget as HTMLElement;
                        const subject = target.dataset.subject || 'all';
                        applyFilter(subject);
                    });
                });

                if (clearFiltersBtn) {
                    clearFiltersBtn.addEventListener('click', () => {
                        applyFilter('all');
                        const allTab = Array.from(tabs).find((t) => (t as HTMLElement).dataset.subject === 'all') as HTMLElement;
                        if (allTab) {
                            allTab.focus();
                        }
                    });
                }
            };

            // Kinetic Reticle Mouse Tracking Parallax
            let reticleRafId: number | null = null;
            let mouseX = 0;
            let mouseY = 0;

            const setupReticleParallax = () => {
                const reticle = document.getElementById('reticle-bg');
                if (!reticle) return null;

                const updateReticleParallax = () => {
                    const x = (mouseX - window.innerWidth / 2) / (window.innerWidth / 2);
                    const y = (mouseY - window.innerHeight / 2) / (window.innerHeight / 2);

                    const moveX = x * 8; // max 8px
                    const moveY = y * 8; // max 8px
                    const rotate = x * 5; // max 5deg

                    reticle.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) rotate(${rotate}deg)`;
                    reticleRafId = null;
                };

                const handleReticleParallax = (e: MouseEvent) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;
                    if (!reticleRafId) {
                        reticleRafId = window.requestAnimationFrame(updateReticleParallax);
                    }
                };

                window.addEventListener('mousemove', handleReticleParallax);

                // Return cleanup function
                return () => {
                    window.removeEventListener('mousemove', handleReticleParallax);
                    if (reticleRafId) {
                        window.cancelAnimationFrame(reticleRafId);
                    }
                };
            };

            let cleanupParallax: (() => void) | null = null;

            // Run strictly on Astro page navigation / page load
            document.addEventListener('astro:page-load', () => {
                setupVideoFilters();
                if (cleanupParallax) cleanupParallax();
                cleanupParallax = setupReticleParallax();
            });

            document.addEventListener('astro:before-preparation', () => {
                if (cleanupParallax) {
                    cleanupParallax();
                    cleanupParallax = null;
                }
            });
        </script>
    </body>
