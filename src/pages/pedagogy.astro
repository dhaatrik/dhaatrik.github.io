---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { youtubeVideos } from '../data/videos';
import { Picture } from 'astro:assets';
import dbImage from '../assets/DB.jpeg';

// Pre-render a math symbol or formula using KaTeX if desired, or use standard text
// Since we want this to load fast, we can render normal HTML and styled math
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Pedagogy | ${SITE_TITLE}`}
            description="Nine years of teaching experiments — bus wheels, kitchen demos, DBS Classes, and what I learned when I stopped."
        />
    </head>
    <body class="bg-grid-motif relative flex min-h-screen flex-col pt-24">
        <Header />
        <main
            id="main-content"
            tabindex="-1"
            class="relative flex grow flex-col gap-(--section-gap-mobile) py-(--section-gap-mobile) overflow-x-hidden md:gap-(--section-gap-desktop) md:py-(--section-gap-desktop)"
        >
            <!-- Background Reticle Grid -->
            <div
                id="reticle-bg"
                class="pointer-events-none absolute top-32 right-0 -z-10 text-slate-900 opacity-5 transition-transform duration-300 ease-out dark:text-white"
            >
                <svg
                    width="400"
                    height="400"
                    viewBox="0 0 200 200"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <!-- Background Grid Dots (Blueprint style) -->
                    <path d="M 20 20 L 20 180 L 180 180 L 180 20 Z" fill="none" stroke="currentColor" stroke-width="0.3" stroke-dasharray="1 19" opacity="0.3" />
                    <path d="M 40 20 L 40 180 M 60 20 L 60 180 M 80 20 L 80 180 M 120 20 L 120 180 M 140 20 L 140 180 M 160 20 L 160 180" fill="none" stroke="currentColor" stroke-width="0.3" stroke-dasharray="1 9" opacity="0.15" />
                    <path d="M 20 40 L 180 40 M 20 60 L 180 60 M 20 80 L 180 80 M 20 120 L 180 120 M 20 140 L 180 140 M 20 160 L 180 160" fill="none" stroke="currentColor" stroke-width="0.3" stroke-dasharray="1 9" opacity="0.15" />

                    <!-- Concentric dashed calibration circles -->
                    <circle cx="100" cy="100" r="90" fill="none" stroke="currentColor" stroke-width="0.3" stroke-dasharray="2 8" opacity="0.4" />
                    <circle cx="100" cy="100" r="80" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="3 3" />
                    <circle cx="100" cy="100" r="60" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="6 6" />
                    <circle cx="100" cy="100" r="30" fill="none" stroke="currentColor" stroke-width="0.3" stroke-dasharray="1 3" opacity="0.5" />
                    
                    <!-- Calibration axes -->
                    <line x1="10" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 4" />
                    <line x1="100" y1="10" x2="100" y2="190" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 4" />
                    
                    <!-- Compass Ticks -->
                    <line x1="100" y1="10" x2="100" y2="15" stroke="currentColor" stroke-width="1" />
                    <line x1="100" y1="185" x2="100" y2="190" stroke="currentColor" stroke-width="1" />
                    <line x1="10" y1="100" x2="15" y2="100" stroke="currentColor" stroke-width="1" />
                    <line x1="185" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="1" />
                    
                    <!-- Outer diamond projection bounds -->
                    <path d="M 100 20 L 180 100 L 100 180 L 20 100 Z" fill="none" stroke="currentColor" stroke-width="0.3" stroke-dasharray="1 5" />
                    
                    <!-- Diagonal Projection Rays to Cap Corners -->
                    <line x1="100" y1="20" x2="100" y2="45" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.5" />
                    <line x1="180" y1="100" x2="175" y2="85" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.5" />
                    <line x1="20" y1="100" x2="25" y2="85" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.5" />
                    
                    <!-- Wireframe Diagonals of Cap Top -->
                    <line x1="100" y1="45" x2="100" y2="125" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 2" opacity="0.6" />
                    <line x1="25" y1="85" x2="175" y2="85" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 2" opacity="0.6" />
                    
                    <!-- Mortarboard Cap Top (Diamond double layered for depth) -->
                    <polygon points="100,45 175,85 100,125 25,85" fill="none" stroke="currentColor" stroke-width="1.5" />
                    <polygon points="100,48 175,88 100,128 25,88" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.7" />
                    <!-- Connecting edges for diamond depth -->
                    <line x1="25" y1="85" x2="25" y2="88" stroke="currentColor" stroke-width="1" />
                    <line x1="175" y1="85" x2="175" y2="88" stroke="currentColor" stroke-width="1" />
                    <line x1="100" y1="125" x2="100" y2="128" stroke="currentColor" stroke-width="1" />
                    
                    <!-- Cap Underneath (Skullcap with contour details) -->
                    <path d="M 60,103 C 60,135 140,135 140,103" fill="none" stroke="currentColor" stroke-width="1.2" />
                    <path d="M 60,115 C 60,145 140,145 140,115" fill="none" stroke="currentColor" stroke-width="1.2" />
                    <path d="M 65,109 C 65,135 135,135 135,109" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.7" />
                    
                    <!-- Skullcap side borders -->
                    <path d="M 60,103 L 60,115" fill="none" stroke="currentColor" stroke-width="1.2" />
                    <path d="M 140,103 L 140,115" fill="none" stroke="currentColor" stroke-width="1.2" />
                    
                    <!-- Button on top -->
                    <circle cx="100" cy="85" r="3" fill="none" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="100" cy="85" r="1" fill="currentColor" />
                    
                    <!-- Tassel -->
                    <path d="M 100,85 C 75,90 55,100 50,115" fill="none" stroke="currentColor" stroke-width="1" />
                    <polygon points="50,115 47,135 53,135" fill="none" stroke="currentColor" stroke-width="1.2" />
                    <!-- Tassel cords/threads lines -->
                    <line x1="48" y1="120" x2="48" y2="135" stroke="currentColor" stroke-width="0.4" opacity="0.7" />
                    <line x1="52" y1="120" x2="52" y2="135" stroke="currentColor" stroke-width="0.4" opacity="0.7" />
                    
                    <!-- Technical Callout Pointer -->
                    <line x1="100" y1="85" x2="135" y2="65" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 1" opacity="0.7" />
                    <circle cx="135" cy="65" r="1" fill="currentColor" />
                    <text x="139" y="67" font-family="monospace" font-size="5" fill="currentColor" opacity="0.6">APEX: (100,85)</text>
                    
                    <!-- Blueprint labels -->
                    <text x="110" y="30" font-family="monospace" font-size="6" fill="currentColor" opacity="0.6">MODEL: MORTARBOARD_CAP</text>
                    <text x="110" y="38" font-family="monospace" font-size="6" fill="currentColor" opacity="0.6">Z-PLANE: ISO_PRJ</text>
                    <text x="110" y="46" font-family="monospace" font-size="6" fill="currentColor" opacity="0.6">TILT_ANG: 14.50°</text>
                    <text x="25" y="170" font-family="monospace" font-size="6" fill="currentColor" opacity="0.6">SYS.PEDAGOGICAL_RECON // V2.0</text>
                    <text x="25" y="178" font-family="monospace" font-size="5" fill="currentColor" opacity="0.4">DBS_CLASSES.ARCHIVE</text>
                </svg>
            </div>

            <!-- Page Hero -->
            <section class="layout-container">
                <div
                    class="mb-12 flex flex-col items-center gap-8 md:flex-row-reverse md:items-start"
                >
                    <div
                        class="relative mx-auto w-full max-w-[260px] shrink-0 p-3 sm:max-w-[320px] md:mx-0 md:w-[320px]"
                    >
                        {/* Clinical blueprint borders and target marks */}
                        <div
                            class="pointer-events-none absolute inset-0 border border-dashed border-slate-200 dark:border-white/10"
                        >
                            {/* Corner target marks '+' */}
                            <span
                                class="absolute -top-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >
                            <span
                                class="absolute -top-1.5 -right-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >
                            <span
                                class="absolute -bottom-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >
                            <span
                                class="absolute -right-1.5 -bottom-1.5 font-mono text-[10px] font-bold text-(--accent)"
                                >+</span
                            >

                            {/* Absolute layout text arrays along borders */}
                            <span
                                class="absolute top-1 left-2 font-mono text-[9px] font-bold tracking-widest text-slate-400 uppercase dark:text-slate-500"
                                >SOURCE: DBS_CLASSES</span
                            >
                            <span
                                class="absolute right-2 bottom-1 font-mono text-[9px] font-bold tracking-widest text-slate-400 uppercase dark:text-slate-500"
                                >SPECIMEN: 02 // JPG</span
                            >
                        </div>

                        <div
                            class="relative overflow-hidden rounded-lg bg-slate-100 dark:bg-black/40"
                        >
                            {/* Technical grid overlay */}
                            <div
                                class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(rgba(0,0,0,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.08)_1px,transparent_1px)] bg-size-[10px_10px] opacity-50 dark:bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)]"
                            >
                            </div>

                            <Picture
                                src={dbImage}
                                alt="DBS Classes Logo"
                                loading="eager"
                                fetchpriority="high"
                                widths={[260, 320, 520, 640]}
                                sizes="(max-width: 640px) 260px, (max-width: 768px) 320px, 320px"
                                formats={['avif', 'webp']}
                                fallbackFormat="jpeg"
                                class="aspect-square w-full object-cover grayscale transition-all duration-500 hover:grayscale-0"
                            />
                        </div>
                    </div>
                    
                    <div class="w-full md:w-[calc(100%-352px)]">
                        <div class="mb-2 font-mono text-xs tracking-widest text-(--accent)">
                            // pedagogical_experiments.log
                        </div>
                        <h1
                            class="type-page-title mb-4 text-slate-900 dark:text-white"
                        >
                            Pedagogy <span class="text-slate-400 dark:text-slate-600">& Teaching</span>
                        </h1>
                        <p class="text-lg leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                            This is the raw log from nine years of teaching physics and math to kids who wanted to understand, not just pass. From explaining kinematics using bus wheels on the streets to modeling thermodynamics in my kitchen, this is the story of DBS Classes, what worked, and why I eventually stopped.
                        </p>

                        <!-- Philosophical Axiom Callout -->
                        <div class="mt-8 relative overflow-hidden border border-dashed border-slate-200 p-6 dark:border-white/10 bg-slate-50/50 dark:bg-black/20 rounded-lg">
                            {/* Bounding box marks */}
                            <span class="absolute -top-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            <span class="absolute -top-1.5 -right-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            <span class="absolute -bottom-1.5 -left-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            <span class="absolute -right-1.5 -bottom-1.5 font-mono text-[10px] font-bold text-(--accent)">+</span>
                            
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                                <div class="space-y-2">
                                    <div class="font-mono text-[9px] font-bold tracking-widest text-slate-500 dark:text-slate-400 uppercase">// CORE_PHILOSOPHY</div>
                                    <blockquote class="text-lg md:text-xl font-bold tracking-tight text-slate-900 dark:text-white leading-tight">
                                        "Education Is Not Free BUT KNOWLEDGE IS FREE"
                                    </blockquote>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">
                                        ...and must be shared with <span class="font-mono text-xs font-bold text-(--accent)">"ZERO TERMS AND CONDITIONS"</span>.
                                    </p>
                                </div>
                                <div class="shrink-0 self-start sm:self-center font-mono text-[9px] text-slate-500 dark:text-slate-400 border border-slate-200/50 dark:border-white/5 px-2.5 py-1.5 rounded uppercase">
                                    Distribution: Unconditional
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Experience & Philosophy Grid -->
            <section class="layout-container relative z-10 reveal-on-scroll">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
                    
                    <!-- Card 1: Experience Overview -->
                    <div class="bento-card group relative flex flex-col justify-between overflow-hidden p-6 md:col-span-2">
                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div>
                                <h2 class="mb-4 flex items-center gap-2 text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
                                    <svg class="h-6 w-6 text-slate-500 dark:text-(--text-secondary)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                    </svg>
                                    Teaching Trajectory
                                </h2>
                                <p class="leading-relaxed text-slate-600 dark:text-(--text-secondary) mb-4">
                                    I spent 9 years (wrapping up in March 2025) figuring out how to make physics and maths actually click. Roughly 200 students across school classrooms, coaching batches, 1:1 sessions, and online groups — each one taught me something I didn't expect.
                                </p>
                                <ul class="space-y-2 font-mono text-xs text-slate-600 dark:text-slate-400">
                                    <li class="flex items-center gap-2">
                                        <span class="text-(--accent)">&gt;</span> Classrooms of 30-40 students in school environments.
                                    </li>
                                    <li class="flex items-center gap-2">
                                        <span class="text-(--accent)">&gt;</span> Batches of 20-25 students at various offline centers.
                                    </li>
                                    <li class="flex items-center gap-2">
                                        <span class="text-(--accent)">&gt;</span> 1:1 private tutoring tailored to individual learning speeds.
                                    </li>
                                    <li class="flex items-center gap-2">
                                        <span class="text-(--accent)">&gt;</span> Online classes for international and NRI students across global time zones.
                                    </li>
                                </ul>
                            </div>
                            <div class="mt-6 border-t border-slate-200/50 pt-4 dark:border-white/5">
                                <span class="font-mono text-[9px] text-slate-400 uppercase">// TARGET DEMOGRAPHICS</span>
                                <div class="mt-2 flex flex-wrap gap-2">
                                    <span class="rounded bg-slate-100 px-2 py-0.5 font-mono text-[10px] text-slate-600 dark:bg-white/5 dark:text-slate-400">Class 9–12</span>
                                    <span class="rounded bg-slate-100 px-2 py-0.5 font-mono text-[10px] text-slate-600 dark:bg-white/5 dark:text-slate-400">B.Sc</span>
                                    <span class="rounded bg-slate-100 px-2 py-0.5 font-mono text-[10px] text-slate-600 dark:bg-white/5 dark:text-slate-400">B.Tech</span>
                                    <span class="rounded bg-slate-100 px-2 py-0.5 font-mono text-[10px] text-slate-600 dark:bg-white/5 dark:text-slate-400">JEE/NEET Prep</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2: Subject Domains -->
                    <div class="bento-card group relative flex flex-col justify-between overflow-hidden p-6">
                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div>
                                <h3 class="mb-4 flex items-center gap-2 text-xl font-bold tracking-tight text-slate-900 dark:text-white">
                                    <svg class="h-5.5 w-5.5 text-slate-500 dark:text-(--text-secondary)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                                    </svg>
                                    Curriculum Range
                                </h3>
                                <p class="text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary) mb-4">
                                    Physics and maths were my home turf. But when a student needed chemistry or biology for an exam, I'd dive in — because teaching isn't about staying in your lane, it's about getting them unstuck.
                                </p>
                            </div>
                            <div class="space-y-2.5 font-mono text-[10px]">
                                <div class="flex items-center justify-between border-b border-slate-200/50 pb-1.5 dark:border-white/5">
                                    <span class="text-slate-400 uppercase">// MATHEMATICS</span>
                                    <span class="font-bold text-(--accent)">CORE</span>
                                </div>
                                <div class="flex items-center justify-between border-b border-slate-200/50 pb-1.5 dark:border-white/5">
                                    <span class="text-slate-400 uppercase">// PHYSICS</span>
                                    <span class="font-bold text-(--accent)">CORE</span>
                                </div>
                                <div class="flex items-center justify-between border-b border-slate-200/50 pb-1.5 dark:border-white/5">
                                    <span class="text-slate-400 uppercase">// CHEMISTRY</span>
                                    <span class="font-bold text-slate-500 dark:text-slate-400">SUPPORTING</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span class="text-slate-400 uppercase">// BIOLOGY</span>
                                    <span class="font-bold text-slate-500 dark:text-slate-400">SUPPORTING</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3: Creative Pedagogy -->
                    <div class="bento-card group relative flex flex-col justify-between overflow-hidden p-6 md:col-span-2">
                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div>
                                <h3 class="mb-4 flex items-center gap-2 text-xl font-bold tracking-tight text-slate-900 dark:text-white">
                                    <svg class="h-5.5 w-5.5 text-slate-500 dark:text-(--text-secondary)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                                    </svg>
                                    Creative Pedagogy
                                </h3>
                                <p class="leading-relaxed text-slate-600 dark:text-(--text-secondary) mb-4">
                                    I treated my students like younger siblings — not passive listeners. No rote memorization sermons. Just curiosity, real-world demos, and the occasional bus-wheel kinematics lecture:
                                </p>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div class="rounded-lg border border-slate-100 bg-slate-50/50 p-3 dark:border-white/5 dark:bg-black/20">
                                        <div class="font-mono text-[10px] font-bold text-(--accent) mb-1">// OUT-OF-TEXTBOOK DEMOS</div>
                                        <p class="text-xs text-slate-500 dark:text-slate-400">
                                            Conducting thermodynamic experiments while cooking, and holding classes under the open sky to connect equations directly to natural events.
                                        </p>
                                    </div>
                                    <div class="rounded-lg border border-slate-100 bg-slate-50/50 p-3 dark:border-white/5 dark:bg-black/20">
                                        <div class="font-mono text-[10px] font-bold text-(--accent) mb-1">// REAL-LIFE OBSERVERS</div>
                                        <p class="text-xs text-slate-500 dark:text-slate-400">
                                            Explaining rotation, velocity, and force kinematics using bus wheels, moving trains, and the flight paths of footballs and cricket balls.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 4: Psychology Node -->
                    <div class="bento-card group relative flex flex-col justify-between overflow-hidden p-6">
                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div>
                                <h3 class="mb-4 flex items-center gap-2 text-xl font-bold tracking-tight text-slate-900 dark:text-white">
                                    <svg class="h-5.5 w-5.5 text-slate-500 dark:text-(--text-secondary)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    Psychology Node
                                </h3>
                                <p class="text-sm leading-relaxed text-slate-600 dark:text-(--text-secondary)">
                                    Teaching taught me psychology I never signed up for — how we actually learn, what makes eyes light up, and what makes someone zone out mid-derivation. That knowledge still shapes how I build software.
                                </p>
                            </div>
                            <div class="mt-4 font-mono text-[10px] text-slate-500 dark:text-slate-400 border-t border-slate-200/50 pt-3 dark:border-white/5">
                                [ OBSERVATION_LOG: 98% ENGAGEMENT ACHIEVED VIA COGNITIVE ALIGNMENT ]
                            </div>
                        </div>
                    </div>

                </div>
            </section>

            <!-- The YouTube Experiment & Failure Reflection -->
            <section class="layout-container relative reveal-on-scroll">
                <div class="bento-card group relative overflow-hidden p-0">
                    <!-- Parallax Background Gradient -->
                    <div
                        class="pointer-events-none absolute inset-0 opacity-20 transition-opacity duration-500 group-hover:opacity-40"
                        style="background-image: radial-gradient(circle at 100% 0%, var(--accent-glow) 0%, transparent 60%);"
                    >
                    </div>

                    <div class="relative z-10 grid grid-cols-1 md:grid-cols-[1fr_2.2fr]">
                        
                        <!-- Left Panel: The Reality of Failure -->
                        <div class="flex flex-col justify-between border-b border-slate-100 bg-slate-50/50 p-6 md:border-r md:border-b-0 md:p-8 dark:border-white/5 dark:bg-black/25">
                            <div>
                                <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-3 py-1 font-mono text-[9px] font-bold tracking-widest text-red-600 uppercase shadow-sm dark:border-red-400/20 dark:bg-red-400/10 dark:text-red-400">
                                    <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                                    Experiment Halted
                                </div>
                                <h3 class="mb-2 text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
                                    DBS Classes
