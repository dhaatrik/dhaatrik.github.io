                                </div>

                                <!-- Text Content -->
                                <div class="flex grow flex-col justify-between p-4">
                                    <div>
                                        <div class="mb-2 flex items-center justify-between font-mono text-[9px]">
                                            <span class="text-slate-400">{video.date}</span>
                                            <span class="rounded bg-(--accent)/10 px-1.5 py-0.2 font-bold tracking-widest text-(--accent) uppercase">
                                                {video.subject}
                                            </span>
                                        </div>
                                        <h3 class="line-clamp-2 text-sm font-bold leading-snug text-slate-800 transition-colors group-hover:text-(--accent) dark:text-slate-200">
                                            {video.title}
