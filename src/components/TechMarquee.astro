---
interface TechIcon {
    name: string;
    src: string;
}

interface Props {
    techGroups: Record<string, TechIcon[]>;
}

const { techGroups } = Astro.props;
---

<div class="space-y-8">
    {
        Object.entries(techGroups).map(([groupName, icons]) => (
            <div class="space-y-3">
                <h3 class="text-sm font-semibold tracking-wider text-slate-500 uppercase dark:text-[var(--text-secondary)]">
                    {groupName.replace('_', ' & ')}
                </h3>
                <div
                    class="group relative flex overflow-x-hidden rounded-[var(--bento-radius-inner)] border border-slate-200 bg-slate-100 py-4 focus-visible:ring-2 focus-visible:ring-[var(--accent)] dark:border-white/5 dark:bg-[var(--bg-card)]"
                    tabindex="0"
                    role="region"
                    aria-label={`${groupName.replace('_', ' & ')} technologies`}
                >
                    <div class="animate-marquee flex gap-6 px-6 whitespace-nowrap">
                        {icons.map((icon) => (
                            <img
                                src={icon.src}
                                alt={icon.name}
                                title={icon.name}
                                loading="lazy"
                                decoding="async"
                                width="120"
                                height="40"
                                class="h-8 rounded shadow-md md:h-10"
                            />
                        ))}
                        {/* Duplicate set for seamless infinite looping */}
                        <div aria-hidden="true" class="flex gap-6">
                            {icons.map((icon) => (
                                <img
                                    src={icon.src}
                                    alt=""
                                    title={icon.name}
                                    loading="lazy"
                                    decoding="async"
                                    width="120"
                                    height="40"
                                    class="h-8 rounded shadow-md md:h-10"
                                />
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        ))
    }
</div>
