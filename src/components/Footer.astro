---
import { getCollection, type CollectionEntry } from 'astro:content';
import { SOCIAL_LINKS } from '../consts';
import FormattedDate from './FormattedDate.astro';
import { execSync } from 'child_process';
import { recommendedBooks } from '../data/readingList';

const bookTelemetry: Record<string, { status: string; focus: string }> = {
    'As a Man Thinketh': { status: 'COMPLETED', focus: 'MINDSET' },
    'How to Win Friends and Influence People': { status: 'COMPLETED', focus: 'RELATIONS' },
    'Marketing Management': { status: 'COMPLETED', focus: 'MARKETING' },
    'Zero to One': { status: 'COMPLETED', focus: 'STARTUPS' },
    'The Pragmatic Programmer': { status: 'COMPLETED', focus: 'CRAFTS' },
    'Deep Work': { status: 'COMPLETED', focus: 'PRODUCTIVITY' },
    'Atomic Habits': { status: 'COMPLETED', focus: 'HABITS' },
    'Clean Code': { status: 'COMPLETED', focus: 'CRAFTS' },
    'The Lean Startup': { status: 'COMPLETED', focus: 'STARTUPS' },
    'The Alchemist': { status: 'COMPLETED', focus: 'PHILOSOPHY' },
};

// Fetch the 4 most recent blog posts for "Transmissions"
const posts: CollectionEntry<'blog'>[] = (await getCollection('blog'))
    .sort(
        (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
            b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
    )
    .slice(0, 4);

const today = new Date();

let gitSha = '';
if ((import.meta.env as any).DEV) {
    gitSha = 'DEV';
} else {
    try {
        gitSha = execSync('git rev-parse --short HEAD').toString().trim().toUpperCase();
    } catch (e) {
        gitSha = 'UNKNOWN';
    }
}

const formatMarqueeDate = (date: Date) => {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}.${m}.${d}`;
};
---

<footer
    class="relative mt-12 w-full overflow-hidden border-t border-slate-200 bg-slate-50/50 pt-12 pb-12 text-slate-500 dark:border-white/5 dark:bg-[#0b0e14] dark:text-slate-400"
>
    <!-- Subtle Grid Background -->
    <div class="bg-grid-motif pointer-events-none absolute inset-0 opacity-5"></div>

    <div class="layout-container relative z-10 grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
        <!-- Column 1: Base Ops -->
        <div class="flex flex-col space-y-4">
            <h3
                class="mb-2 flex items-center gap-2 font-mono text-[10px] tracking-widest text-slate-900 uppercase dark:text-white"
            >
                <span class="h-1.5 w-1.5 rounded-full bg-(--accent)"></span>
                Base Ops
            </h3>
            <ul class="flex flex-col space-y-3 text-sm">
                <li>
                    <a
                        href="/"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Home</a
                    >
                </li>
                <li>
                    <a
                        href="/personnel"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Personnel</a
                    >
                </li>
                <li>
                    <a
                        href="/pedagogy"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Pedagogy</a
                    >
                </li>
                <li>
                    <a
                        href="/transmissions"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Transmissions</a
                    >
                </li>
                <li>
                    <button
                        popovertarget="books-popover"
                        aria-expanded="false"
                        aria-controls="books-popover"
                        class="group inline-flex cursor-pointer items-center gap-2 border-none bg-transparent p-0 font-sans text-sm text-slate-500 transition-colors hover:text-(--accent) focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none dark:text-slate-400 dark:focus-visible:ring-offset-(--bg-main)"
                    >
                        <span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Recommended Books
                    </button>
                </li>
                <li>
                    <a
                        href="/rss.xml"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >RSS Feed</a
                    >
                </li>
            </ul>
        </div>

        <!-- Column 2: Recent Transmissions -->
        <div class="flex flex-col space-y-4">
            <h3
                class="mb-2 flex items-center gap-2 font-mono text-[10px] tracking-widest text-slate-900 uppercase dark:text-white"
            >
                <span class="h-1.5 w-1.5 rounded-full bg-(--accent)"></span>
                Recent Transmissions
            </h3>
            <ul class="flex flex-col space-y-3">
                {
                    posts.map((post) => (
                        <li>
                            <a
                                href={`/transmissions/${post.id}/`}
                                class="group flex flex-col space-y-0.5 transition-colors"
                            >
                                <div class="flex items-center gap-1.5 font-mono text-[10px] text-slate-400 transition-colors group-hover:text-(--accent) dark:text-slate-500">
                                    <span class="text-(--accent)">
                                        [ {formatMarqueeDate(post.data.pubDate)} ]
                                    </span>
                                    <span
                                        class="relative-time-indicator opacity-80"
                                        data-timestamp={post.data.pubDate.toISOString()}
                                    >
                                        --
                                    </span>
                                </div>
                                <span class="line-clamp-1 text-sm text-slate-500 transition-colors group-hover:text-(--accent) dark:text-slate-400">
                                    {post.data.title}
                                </span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>

        <!-- Column 3: System Diagnostics -->
        <div class="flex flex-col space-y-6">
            <div class="flex flex-col space-y-4">
                <h3
                    class="mb-2 flex items-center gap-2 font-mono text-[10px] tracking-widest text-slate-900 uppercase dark:text-white"
                >
                    <span class="h-1.5 w-1.5 rounded-full bg-(--accent)"></span>
                    System Diagnostics
                </h3>
                <div
                    class="space-y-1.5 rounded-lg border border-slate-200 bg-white p-4 font-mono text-[11px] leading-relaxed text-slate-500 shadow-sm select-none dark:border-white/5 dark:bg-[#151a22] dark:text-slate-400"
                >
                    <div>SYS_CORE: ASTRO v6.1.7</div>
                    <div>STYLE_SYS: TAILWIND CSS v4.0</div>
                    <div>RENDER_MODE: STATIC (SSG)</div>
                    <div>HOST: GITHUB PAGES</div>
                    <div>INTEGRITY: SECURE (HTTPS)</div>
                </div>
            </div>

            <!-- Support CTA -->
            <button
                popovertarget="support-popover"
                aria-expanded="false"
                aria-controls="support-popover"
                class="magnetic-target group flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-(--accent)/30 bg-(--accent)/10 py-3 font-mono text-xs tracking-widest text-(--accent) uppercase transition-all hover:bg-(--accent)/20 hover:shadow-[0_0_15px_var(--accent-glow)]"
            >
