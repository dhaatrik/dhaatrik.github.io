                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 transition-all hover:-translate-y-1 hover:border-[#00457C]/50 hover:bg-white hover:shadow-[0_8px_20px_rgba(0,69,124,0.3)] dark:border-white/5 dark:bg-black/20 dark:hover:border-[#0079C1]/50 dark:hover:bg-white/10 dark:hover:shadow-[0_8px_20px_rgba(0,121,193,0.3)]"
