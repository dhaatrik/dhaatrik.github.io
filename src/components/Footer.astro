            <button
                aria-label="Close recommended books list"
                popovertarget="books-popover"
                popovertargetaction="hide"
                class="mt-0.5 shrink-0 cursor-pointer rounded-sm p-1 text-slate-500 transition-colors hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none sm:mt-1 dark:hover:text-white dark:focus-visible:ring-offset-(--bg-main)"
            >
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"
                    ><path d="M18 6L6 18M6 6l12 12"></path></svg
