---
import { getCollection, type CollectionEntry } from 'astro:content';
import { SOCIAL_LINKS } from '../consts';
import FormattedDate from './FormattedDate.astro';
import { execSync } from 'child_process';

// Fetch the 3 most recent blog posts for "Transmissions"
const posts: CollectionEntry<'blog'>[] = (await getCollection('blog'))
    .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const today = new Date();

let gitSha = '';
try {
    gitSha = execSync('git rev-parse --short HEAD').toString().trim().toUpperCase();
} catch (e) {
    gitSha = btoa(Date.now().toString()).substring(0, 7).toUpperCase();
}

const formatMarqueeDate = (date: Date) => {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}.${m}.${d}`;
};
---

<footer
    class="relative mt-20 w-full overflow-hidden border-t border-slate-200 bg-slate-50/50 pb-12 pt-0 text-slate-500 dark:border-white/5 dark:bg-[#0b0e14] dark:text-slate-400"
>
    <!-- Subtle Grid Background -->
    <div class="bg-grid-motif pointer-events-none absolute inset-0 opacity-5"></div>

    <!-- Real-Time Transmission Horizon Marquee -->
    <div class="border-b border-slate-200/80 bg-slate-100/50 py-2.5 dark:border-white/5 dark:bg-black/20 overflow-hidden select-none mb-12">
        <div class="animate-marquee flex whitespace-nowrap w-max text-[10px] font-mono tracking-widest text-slate-500 dark:text-slate-400">
            <div class="flex gap-16 px-4 shrink-0">
                <span>ALERT // LATEST LOGS OVER THE HORIZON:</span>
                {posts.map((post) => (
                    <span class="flex gap-2">
                        <span class="text-(--accent)">[{formatMarqueeDate(post.data.pubDate)}]</span>
                        <span>{post.data.title.toUpperCase()}</span>
                    </span>
                ))}
            </div>
            <div aria-hidden="true" class="flex gap-16 px-4 shrink-0">
                <span>ALERT // LATEST LOGS OVER THE HORIZON:</span>
                {posts.map((post) => (
                    <span class="flex gap-2">
                        <span class="text-(--accent)">[{formatMarqueeDate(post.data.pubDate)}]</span>
                        <span>{post.data.title.toUpperCase()}</span>
                    </span>
                ))}
            </div>
        </div>
    </div>

    <div class="layout-container relative z-10 grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
        <!-- Column 1: Base Ops -->
        <div class="flex flex-col space-y-4">
            <h3
                class="mb-2 flex items-center gap-2 font-mono text-[10px] tracking-widest text-slate-900 uppercase dark:text-white"
            >
                <span class="h-1.5 w-1.5 rounded-full bg-(--accent)"></span>
                Base Ops
            </h3>
            <ul class="flex flex-col space-y-3 text-sm">
                <li>
                    <a
                        href="/"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Home</a>
                </li>
                <li>
                    <a
                        href="/about"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Personnel</a>
                </li>
                <li>
                    <a
                        href="/blog"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >Transmissions</a>
                </li>
                <li>
                    <a
                        href="/rss.xml"
                        class="group inline-flex items-center gap-2 transition-colors hover:text-(--accent)"
                        ><span
                            class="font-mono text-[10px] opacity-50 transition-opacity group-hover:opacity-100"
                            >/</span
                        >RSS Feed</a>
                </li>
            </ul>
            <div class="font-mono text-[9px] tracking-widest text-slate-400 dark:text-slate-600 uppercase pt-3 border-t border-slate-200/50 dark:border-white/5">
                COORD: 22.5726° N, 88.3639° E
            </div>
        </div>

        <!-- Column 2: System Diagnostics -->
        <div class="flex flex-col space-y-4">
            <h3
                class="mb-2 flex items-center gap-2 font-mono text-[10px] tracking-widest text-slate-900 uppercase dark:text-white"
            >
                <span class="h-1.5 w-1.5 rounded-full bg-(--accent)"></span>
                System Diagnostics
            </h3>
            <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/5 dark:bg-[#151a22] font-mono text-[11px] leading-relaxed text-slate-500 dark:text-slate-400 space-y-1.5 select-none">
                <div>SYS_CORE: ASTRO v6.1.7</div>
                <div>STYLE_SYS: TAILWIND CSS v4.0</div>
                <div>RENDER_MODE: STATIC (SSG)</div>
                <div>HOST: GITHUB PAGES</div>
                <div>INTEGRITY: SECURE (HTTPS)</div>
            </div>
        </div>

        <!-- Column 3: Technical Status -->
        <div class="flex flex-col space-y-6">
            <div
                class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/5 dark:bg-[#151a22]"
            >
                <div class="mb-4 flex items-start justify-between">
                    <div>
                        <div
                            class="mb-1 font-mono text-[10px] tracking-widest text-slate-400 uppercase"
                        >
                            Local Time (IST)
                        </div>
                        <div
                            id="ist-clock"
                            class="rounded bg-slate-100 px-2 py-0.5 font-mono text-lg font-bold tracking-tight text-slate-900 dark:bg-black/30 dark:text-white"
                        >
                            --:--:--
                        </div>
                    </div>
                    <div class="text-right">
                        <div
                            class="mb-1 font-mono text-[10px] tracking-widest text-slate-400 uppercase"
                        >
                            Build ID
                        </div>
                        <div
                            class="rounded bg-(--accent)/10 px-2 py-1 font-mono text-xs font-bold text-(--accent)"
                        >
                            {gitSha}
                        </div>
                    </div>
                </div>
                <div
                    class="flex items-center gap-2 font-mono text-[10px] tracking-widest text-green-600 uppercase dark:text-green-400"
                >
                    <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-green-500"></span>
                    STATUS: OPERATIONAL
                </div>
            </div>

            <!-- Support CTA -->
            <button
                popovertarget="support-popover"
                class="magnetic-target group flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-(--accent)/30 bg-(--accent)/10 py-3 font-mono text-xs tracking-widest text-(--accent) uppercase transition-all hover:bg-(--accent)/20 hover:shadow-[0_0_15px_var(--accent-glow)]"
            >
