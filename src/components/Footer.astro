    >
        <p class="font-mono text-xs">
            &copy; {today.getFullYear()} Dhaatrik Chowdhury. All rights reserved.
        </p>

        <!-- Social Icons with Cyber Micro-interaction -->
        <div class="flex items-center gap-4">
            <a
