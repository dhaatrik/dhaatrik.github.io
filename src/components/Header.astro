---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const cleanPath = pathname.replace(/\/$/, '');
const displayPath = cleanPath === '' ? '~/home' : `~/home${cleanPath}`;
---

<style>
    @keyframes sonar {
        0% {
            transform: scale(1);
            opacity: 0.6;
        }
        100% {
            transform: scale(2.5);
            opacity: 0;
        }
    }
    .sonar-icon {
        position: relative;
    }
    .sonar-icon::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 50%;
        background-color: var(--accent);
        opacity: 0;
        z-index: -1;
        pointer-events: none;
    }
    .sonar-trigger:hover .sonar-icon::after {
        animation: sonar 1s cubic-bezier(0, 0.2, 0.8, 1) forwards;
    }

    /* Ensure the header transition is smooth for the hide/show effect and promoted to GPU */
    #main-header {
        will-change: transform;
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            background-color 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    /* Hamburger Line Animations */
    #mobile-nav-toggle.open .hamburger-line:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
    }
    #mobile-nav-toggle.open .hamburger-line:nth-child(2) {
        opacity: 0;
        transform: scale(0);
    }
    #mobile-nav-toggle.open .hamburger-line:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
    }

    @supports (anchor-name: --x) {
        .desktop-nav-links {
            position: relative;
        }
        .desktop-nav-links a {
            position: relative;
            z-index: 10;
        }
        .desktop-nav-links a:hover,
        .desktop-nav-links a:focus-visible {
            anchor-name: --nav-active;
        }
        .desktop-nav-links::before {
            content: '';
            position: absolute;
            position-anchor: --nav-active;
            top: anchor(top);
            bottom: anchor(bottom);
            left: anchor(left);
            right: anchor(right);

            margin: -0.25rem -0.5rem;

            border-radius: 0.375rem;
            background-color: color-mix(in srgb, var(--accent) 8%, transparent);

            opacity: 0;
            pointer-events: none;
            z-index: 0;

            @media (prefers-reduced-motion: no-preference) {
                transition:
                    top 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                    bottom 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                    left 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                    right 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.2s ease;
            }
            @media (prefers-reduced-motion: reduce) {
                transition: opacity 0.2s ease;
            }
        }
        .desktop-nav-links:has(a:hover)::before,
        .desktop-nav-links:has(a:focus-visible)::before {
            opacity: 1;
        }
    }
</style>

<!-- Subtle Noise Texture -->
<div
    class="pointer-events-none fixed inset-0 z-100 h-full w-full opacity-[0.03] mix-blend-overlay"
    style="background-image: url('data:image/svg+xml;base64,');"
>
</div>
<!-- Ambient Background Glows -->
<div
    class="pointer-events-none fixed -top-[20%] -left-[10%] -z-10 h-[50vw] w-[50vw] rounded-full bg-(--accent)/20 mix-blend-multiply blur-[120px] dark:bg-(--accent)/10 dark:mix-blend-screen"
>
</div>
<div
    class="pointer-events-none fixed -right-[10%] -bottom-[20%] -z-10 h-[50vw] w-[50vw] rounded-full bg-purple-500/20 mix-blend-multiply blur-[120px] dark:bg-purple-500/10 dark:mix-blend-screen"
>
</div>

<a
    href="#main-content"
    aria-label="Skip to main content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-100 focus:bg-(--accent) focus:px-4 focus:py-2 focus:font-bold focus:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 dark:focus-visible:ring-offset-(--bg-main)"
>
    Skip to content
</a>

<header
    id="main-header"
    class="glass-surface glass-chrome fixed top-0 z-50 w-full"
>
    <nav
        id="main-nav"
        class="layout-container flex items-center justify-between py-4 transition-colors duration-300 ease-in-out"
    >
        {
            /* ⚡ Bolt: Enable hover prefetching for isolated internal links to provide instant page transitions */
        }
        <a
            href="/"
            data-astro-prefetch="hover"
            class="sonar-trigger group flex items-center transition-opacity hover:opacity-80 focus-visible:opacity-80"
            aria-label="Dhaatrik — Home"
        >
            <div class="sonar-icon rounded-full">
                <img
                    src="/logo_dark.svg"
                    alt="Dhaatrik Logo"
                    class="relative z-10 h-10 w-10 sm:h-12 sm:w-12 dark:hidden"
                    width="48"
                    height="48"
                />
                <img
                    src="/logo_light.svg"
                    alt="Dhaatrik Logo"
                    class="relative z-10 hidden h-10 w-10 sm:h-12 sm:w-12 dark:block"
                    width="48"
                    height="48"
                />
            </div>

            <div class="flex items-center">
                <div
                    class="mx-3 h-6 border-l border-slate-300 transition-colors group-hover:border-(--accent)/50 dark:border-white/20"
                >
                </div>
                <div class="flex flex-col justify-center">
                    <span
                        class="flex items-center gap-1.5 leading-none font-bold tracking-tight text-slate-900 dark:text-white"
                    >
                        DHAATRIK
                        <span class="relative flex h-1.5 w-1.5">
                            <span class="absolute inline-flex h-full w-full animate-pulse-emerald rounded-full bg-emerald-500 opacity-75"></span>
                            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                        </span>
                    </span>
                    <span
                        class="mt-1 hidden font-mono text-[10px] leading-none tracking-widest text-(--accent) opacity-80 sm:block"
                        >{displayPath}</span
                    >
                </div>
            </div>
        </a>
        <div class="flex items-center gap-2.5 sm:gap-4 md:gap-6">
            <div class="desktop-nav-links hidden items-center gap-6 md:flex">
                <HeaderLink
                    href="/"
                    class="group/link flex items-center text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary)"
                >
                    <span
                        aria-hidden="true"
                        class="mr-2 font-mono text-[10px] text-slate-400 opacity-70 transition-colors group-hover/link:text-(--accent) dark:text-slate-500"
                        >[ 01 ]</span
                    >Home
                </HeaderLink>
                <HeaderLink
                    href="/personnel"
                    class="group/link flex items-center text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary)"
                >
                    <span
                        aria-hidden="true"
                        class="mr-2 font-mono text-[10px] text-slate-400 opacity-70 transition-colors group-hover/link:text-(--accent) dark:text-slate-500"
                        >[ 02 ]</span
                    >Personnel
                </HeaderLink>
                <HeaderLink
                    href="/projects"
                    class="group/link flex items-center text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary)"
                >
                    <span
                        aria-hidden="true"
                        class="mr-2 font-mono text-[10px] text-slate-400 opacity-70 transition-colors group-hover/link:text-(--accent) dark:text-slate-500"
                        >[ 03 ]</span
                    >Projects
                </HeaderLink>
                <HeaderLink
                    href="/pedagogy"
                    class="group/link flex items-center text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary)"
                >
                    <span
                        aria-hidden="true"
                        class="mr-2 font-mono text-[10px] text-slate-400 opacity-70 transition-colors group-hover/link:text-(--accent) dark:text-slate-500"
                        >[ 04 ]</span
                    >Pedagogy
                </HeaderLink>
                <HeaderLink
                    href="/transmissions"
                    class="group/link flex items-center text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary)"
                >
                    <span
                        aria-hidden="true"
                        class="mr-2 font-mono text-[10px] text-slate-400 opacity-70 transition-colors group-hover/link:text-(--accent) dark:text-slate-500"
                        >[ 05 ]</span
                    >Transmissions
                </HeaderLink>
            </div>
            <ThemeToggle />
            <button
                id="mobile-nav-toggle"
                aria-label="Toggle navigation menu"
                aria-expanded="false"
                aria-controls="mobile-nav-drawer"
                class="magnetic-target relative z-50 flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-1.5 rounded-full border border-transparent transition-colors hover:bg-slate-200/60 hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 md:hidden dark:hover:bg-white/10 dark:hover:text-white dark:focus-visible:ring-offset-(--bg-main)"
            >
                <span class="hamburger-line h-0.5 w-5 bg-current transition-all duration-300"
                ></span>
                <span class="hamburger-line h-0.5 w-5 bg-current transition-all duration-300"
                ></span>
                <span class="hamburger-line h-0.5 w-5 bg-current transition-all duration-300"
                ></span>
            </button>
        </div>
    </nav>
</header>

<div
    id="mobile-nav-backdrop"
    class="pointer-events-none fixed inset-0 z-40 bg-slate-950/40 opacity-0 backdrop-blur-md transition-opacity duration-300 md:hidden"
>
</div>

<nav
    id="mobile-nav-drawer"
    class="glass-surface glass-drawer fixed top-0 right-0 z-40 flex h-full w-72 translate-x-full flex-col gap-6 p-6 pt-24 transition-transform duration-300 md:hidden"
    aria-label="Mobile navigation"
>
    <!-- Decorative Grid Motif -->
    <div
        class="bg-grid-motif pointer-events-none absolute inset-0 opacity-[0.02] dark:opacity-[0.04]"
    >
    </div>

    <div class="relative z-10 flex flex-col gap-3 font-mono">
        <div
            class="mb-2 border-b border-slate-200/50 pb-2 text-[9px] tracking-widest text-slate-400 uppercase dark:border-white/5 dark:text-slate-500"
        >
            // DIRECTORY_INDEX
        </div>

        {
            [
                {
                    href: '/',
                    label: 'Home',
                    index: '[ 01 ]',
                    isActive: cleanPath === '' || cleanPath === '/',
                },
                {
                    href: '/personnel',
                    label: 'Personnel',
                    index: '[ 02 ]',
                    isActive: cleanPath.startsWith('/personnel'),
                },
                {
                    href: '/projects',
                    label: 'Projects',
                    index: '[ 03 ]',
                    isActive: cleanPath.startsWith('/projects'),
                },
                {
                    href: '/pedagogy',
                    label: 'Pedagogy',
                    index: '[ 04 ]',
                    isActive: cleanPath.startsWith('/pedagogy'),
                },
                {
                    href: '/transmissions',
                    label: 'Transmissions',
                    index: '[ 05 ]',
                    isActive: cleanPath.startsWith('/transmissions'),
                },
            ].map((item) => (
                <a
                    href={item.href}
                    data-astro-prefetch="hover"
                    class:list={[
                        'group/link relative flex items-center justify-between rounded-lg px-3.5 py-2.5 text-sm transition-all duration-300 outline-none focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 dark:focus-visible:ring-offset-[#0b0e14]',
                        item.isActive
                            ? 'bg-(--accent)/10 font-semibold text-(--accent) dark:bg-(--accent)/15'
                            : 'text-slate-700 hover:bg-slate-100/50 hover:text-(--accent) focus-visible:bg-slate-100/50 focus-visible:text-(--accent) dark:text-slate-300 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white',
                    ]}
                >
                    {item.isActive && (
                        <span class="absolute top-2 bottom-2 left-0 w-1 rounded-r-md bg-(--accent) shadow-[0_0_8px_var(--accent)]" />
                    )}
                    <div class="flex items-center gap-3 group-hover/link:translate-x-1 group-focus-visible/link:translate-x-1 transition-transform duration-300">
                        <span
                            class:list={[
                                'text-[10px] transition-colors',
                                item.isActive
                                    ? 'text-(--accent)'
                                    : 'text-slate-400 group-hover/link:text-(--accent) group-focus-visible/link:text-(--accent) dark:text-slate-500',
                            ]}
                        >
                            {item.index}
                        </span>
                        <span class="tracking-wide">{item.label}</span>
                    </div>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class:list={[
                            'transition-transform duration-300',
                            item.isActive
                                ? 'translate-x-0 text-(--accent)'
                                : '-translate-x-2 text-slate-400 opacity-0 group-hover/link:translate-x-0 group-hover/link:opacity-100 group-focus-visible/link:translate-x-0 group-focus-visible/link:opacity-100 dark:text-slate-600',
                        ]}
                    >
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </a>
            ))
        }
    </div>

    <!-- Telemetry sci-fi panel in footer -->
    <div
        class="relative z-10 mt-auto flex flex-col gap-4 border-t border-slate-200/60 pt-5 font-mono text-[10px] text-slate-500 dark:border-white/10 dark:text-slate-400"
    >
        <div class="flex items-center justify-between">
            <span class="text-[9px] tracking-wider text-slate-400 uppercase dark:text-slate-500"
                >SYS.STATUS</span
            >
            <div class="flex items-center gap-1.5 font-semibold text-emerald-600 dark:text-emerald-400">
                <span class="relative flex h-1.5 w-1.5">
                    <span
                        class="absolute inline-flex h-full w-full animate-pulse-emerald rounded-full bg-emerald-500 opacity-75"
                    ></span>
                    <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                </span>
                <span class="text-[9px] tracking-widest uppercase">ACTIVE</span>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-2 border-t border-dashed border-slate-200/60 pt-3 dark:border-white/5">
            <div class="flex flex-col gap-0.5">
                <span class="text-[8px] tracking-wider text-slate-400 uppercase dark:text-slate-500">SYS.CORES</span>
                <span id="drawer-sys-cores" class="font-semibold text-slate-700 dark:text-slate-300">—</span>
            </div>
            <div class="flex flex-col gap-0.5">
                <span class="text-[8px] tracking-wider text-slate-400 uppercase dark:text-slate-500">SYS.RTT</span>
                <span id="drawer-sys-rtt" class="font-semibold text-slate-700 dark:text-slate-300">—</span>
            </div>
        </div>

        <div
            class="flex flex-col gap-1 border-t border-dashed border-slate-200/60 pt-3 dark:border-white/5"
        >
            <span class="text-[9px] tracking-wider text-slate-400 uppercase dark:text-slate-500"
                >SYS.LOCATION</span
            >
            <span
                id="mobile-telemetry-path"
                class="truncate leading-none font-semibold tracking-wide text-(--accent) lowercase"
            >
                {displayPath}
            </span>
        </div>

        <div
            class="flex items-center justify-between border-t border-slate-200/60 pt-3 text-[9px] tracking-wider text-slate-400 dark:border-white/10 dark:text-slate-500"
        >
            <span>SWIPE RIGHT TO CLOSE</span>
            <span>[ ESC ]</span>
        </div>
    </div>
</nav>

<script>
    let headerAbortController: AbortController | null = null;
    let headerScrollTicking = false;

    const setupHeader = () => {
        if (headerAbortController) {
            headerAbortController.abort();
        }
        headerAbortController = new AbortController();
        const { signal } = headerAbortController;

        let lastScroll = window.scrollY;
        const header = document.getElementById('main-header');
        const nav = document.getElementById('main-nav');
        const toggleBtn = document.getElementById('mobile-nav-toggle');
        const drawer = document.getElementById('mobile-nav-drawer');
        const backdrop = document.getElementById('mobile-nav-backdrop');

        if (!header || !nav) return;

        const hasScrollTimeline = CSS.supports(
            '(animation-timeline: scroll()) and (animation-range: 0% 100%)'
        );

        const updateHeader = () => {
            if (signal.aborted) return;
            const currentScroll = window.scrollY;

            // Shrink header and add subtle shadow on scroll (JS fallback only)
                if (!hasScrollTimeline) {
                if (currentScroll > 50) {
                    nav.classList.remove('py-4');
                    nav.classList.add('py-2');
                    header.classList.add('is-scrolled', 'shadow-md', 'dark:shadow-black/50');
                } else {
                    nav.classList.add('py-4');
                    nav.classList.remove('py-2');
                    header.classList.remove('is-scrolled', 'shadow-md', 'dark:shadow-black/50');
                }
            }

            // Hide on scroll down, show on scroll up - more deliberate threshold
            const isDrawerOpen = toggleBtn && toggleBtn.classList.contains('open');
            if (!isDrawerOpen) {
                if (currentScroll <= 0) {
                    header.style.transform = 'translateY(0)';
                } else if (currentScroll > lastScroll && currentScroll > 150) {
                    // Scrolling down past threshold
                    header.style.transform = 'translateY(-100%)';
                } else if (
                    currentScroll < lastScroll &&
                    (lastScroll - currentScroll > 10 || currentScroll < 50)
                ) {
                    // Scrolling up (with a small buffer to prevent jitter)
                    header.style.transform = 'translateY(0)';
                }
            }

            lastScroll = currentScroll <= 0 ? 0 : currentScroll;
            headerScrollTicking = false;
        };

        const onScroll = () => {
            if (!headerScrollTicking) {
                window.requestAnimationFrame(updateHeader);
                headerScrollTicking = true;
            }
        };

        window.addEventListener('scroll', onScroll, { passive: true, signal });
        updateHeader();

        // Hamburger Drawer Control
        if (toggleBtn && drawer && backdrop) {
            let startX = 0;
            let currentX = 0;
            let isSwiping = false;

            const getFocusableElements = () => {
                return drawer.querySelectorAll('a, button');
            };

            const handleFocusTrap = (e: KeyboardEvent) => {
                if (e.key !== 'Tab') return;
                const focusables = getFocusableElements();
                if (focusables.length === 0) return;
                const first = focusables[0] as HTMLElement;
                const last = focusables[focusables.length - 1] as HTMLElement;

                if (e.shiftKey) {
                    if (document.activeElement === first) {
                        last.focus();
                        e.preventDefault();
                    }
                } else {
                    if (document.activeElement === last) {
                        first.focus();
                        e.preventDefault();
                    }
                }
            };

            const openMenu = () => {
                drawer.classList.remove('translate-x-full');
                drawer.classList.add('translate-x-0');
                backdrop.classList.remove('opacity-0', 'pointer-events-none');
                backdrop.classList.add('opacity-100', 'pointer-events-auto');
                toggleBtn.classList.add('open');
                toggleBtn.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';

                // Clear inline style overrides
                drawer.style.transform = '';
                backdrop.style.opacity = '';

                const focusables = getFocusableElements();
                if (focusables.length > 0) {
                    (focusables[0] as HTMLElement).focus();
                }
                document.addEventListener('keydown', handleFocusTrap, { signal });
            };

            const closeMenu = () => {
                drawer.classList.remove('translate-x-0');
                drawer.classList.add('translate-x-full');
                backdrop.classList.remove('opacity-100', 'pointer-events-auto');
                backdrop.classList.add('opacity-0', 'pointer-events-none');
                toggleBtn.classList.remove('open');
                toggleBtn.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
                
                // Clear inline style overrides after transition finishes
                setTimeout(() => {
                    drawer.style.transform = '';
                    backdrop.style.opacity = '';
                }, 300);

                document.removeEventListener('keydown', handleFocusTrap);
                toggleBtn.focus();
            };

            toggleBtn.addEventListener(
                'click',
                () => {
                    const isOpen = toggleBtn.classList.contains('open');
                    if (isOpen) {
                        closeMenu();
                    } else {
                        openMenu();
                    }
                },
                { signal }
            );

            backdrop.addEventListener('click', closeMenu, { signal });

            // Swipe Right to Close Drawer Gestures
            let startTime = 0;
            drawer.addEventListener(
                'touchstart',
                (e) => {
                    startX = e.touches[0].clientX;
                    currentX = startX;
                    startTime = Date.now();
                    isSwiping = true;
                    drawer.style.transition = 'none';
                    backdrop.style.transition = 'none';
                },
                { passive: true, signal }
            );

            drawer.addEventListener(
                'touchmove',
                (e) => {
                    if (!isSwiping) return;
                    currentX = e.touches[0].clientX;
                    const diffX = currentX - startX;
                    if (diffX > 0) {
                        const width = drawer.offsetWidth;
                        const progress = Math.min(1, Math.max(0, diffX / width));
                        // Exponential friction curve for luxurious damping
                        const easedProgress = (1 - Math.exp(-3 * progress)) / (1 - Math.exp(-3));
                        const translateX = easedProgress * width;
                        drawer.style.transform = `translateX(${translateX}px)`;
                        backdrop.style.opacity = (1 - easedProgress).toString();
                    }
                },
                { passive: true, signal }
            );

            drawer.addEventListener(
                'touchend',
                () => {
                    if (!isSwiping) return;
                    isSwiping = false;
                    drawer.style.transition = '';
                    backdrop.style.transition = '';
                    const diffX = currentX - startX;
                    const elapsed = Date.now() - startTime;
                    const velocity = diffX / elapsed; // px per ms

                    if (diffX > 75 || (velocity > 0.3 && diffX > 25)) {
                        closeMenu();
                    } else {
                        drawer.style.transform = '';
                        backdrop.style.opacity = '';
                    }
                    startX = 0;
                    currentX = 0;
                },
                { signal }
            );

            // ESC key to close drawer
            const handleKeyDown = (e: KeyboardEvent) => {
                if (e.key === 'Escape' && toggleBtn.classList.contains('open')) {
                    closeMenu();
                }
            };
            document.addEventListener('keydown', handleKeyDown, { signal });

            // Synchronize SPA path name in the telemetry log
            const updateTelemetryPath = () => {
                const telemetryPathEl = document.getElementById('mobile-telemetry-path');
                if (telemetryPathEl) {
                    const pathname = window.location.pathname;
                    const cleanPath = pathname.replace(/\/$/, '');
                    telemetryPathEl.textContent =
                        cleanPath === '' ? '~/home' : `~/home${cleanPath}`;
                }
            };
            updateTelemetryPath();

            // Populate live SYS.LOAD and SYS.LATENCY from the Performance Navigation Timing API
            const updateDrawerTelemetry = () => {
                const coresEl = document.getElementById('drawer-sys-cores');
                const rttEl = document.getElementById('drawer-sys-rtt');

                if (coresEl) {
                    const cores = navigator.hardwareConcurrency ?? null;
                    coresEl.textContent = cores ? `${cores}` : '—';
                }

                if (rttEl) {
                    try {
                        const entries = performance.getEntriesByType(
                            'navigation'
                        ) as PerformanceNavigationTiming[];
                        const navEntry = entries[0];
                        if (navEntry && navEntry.responseStart > 0) {
                            const latencyMs = Math.round(
                                navEntry.responseStart - navEntry.requestStart
                            );
                            const label =
                                latencyMs < 50
                                    ? 'FAST'
                                    : latencyMs < 200
                                      ? 'STABLE'
                                      : 'SLOW';
                            rttEl.textContent = `${latencyMs}ms // ${label}`;
                        } else {
                            rttEl.textContent = '—';
                        }
                    } catch {
                        rttEl.textContent = '—';
                    }
                }
            };
            updateDrawerTelemetry();
        }
    };

    document.addEventListener('astro:page-load', setupHeader);

    document.addEventListener('astro:before-preparation', () => {
        // Ensure menu is closed when initiating transition to prevent overflow lock
        const toggleBtn = document.getElementById('mobile-nav-toggle');
        const drawer = document.getElementById('mobile-nav-drawer');
        const backdrop = document.getElementById('mobile-nav-backdrop');
        if (toggleBtn && toggleBtn.classList.contains('open')) {
            drawer?.classList.add('translate-x-full');
            backdrop?.classList.add('opacity-0', 'pointer-events-none');
            toggleBtn.classList.remove('open');
            document.body.style.overflow = '';
        }

        if (headerAbortController) {
            headerAbortController.abort();
            headerAbortController = null;
        }
    });
</script>
