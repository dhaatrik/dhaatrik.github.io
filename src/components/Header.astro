---
import HeaderLink from './HeaderLink.astro';
---

<a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[100] focus:bg-[var(--accent)] focus:px-4 focus:py-2 focus:font-bold focus:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-[var(--bg-main)]"
>
    Skip to content
</a>

<header
    class="fixed top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md dark:border-white/5 dark:bg-[var(--bg-main)]/80"
>
    <nav class="layout-container flex items-center justify-between py-4">
        <a
            href="/"
            class="font-heading text-xl font-bold text-slate-900 transition-colors hover:text-slate-700 focus-visible:text-slate-700 dark:text-[var(--text-primary)] dark:hover:text-white dark:focus-visible:text-white"
        >
            {'Dhaatrik.'}
        </a>
        <div class="flex items-center gap-6">
            <HeaderLink
                href="/"
                class="text-slate-500 transition-colors hover:text-[var(--accent)] focus-visible:text-[var(--accent)] dark:text-[var(--text-secondary)]"
                >Home</HeaderLink
            >
            <HeaderLink
                href="/about"
                class="text-slate-500 transition-colors hover:text-[var(--accent)] focus-visible:text-[var(--accent)] dark:text-[var(--text-secondary)]"
                >About</HeaderLink
            >
            <HeaderLink
                href="/blog"
                class="text-slate-500 transition-colors hover:text-[var(--accent)] focus-visible:text-[var(--accent)] dark:text-[var(--text-secondary)]"
                >Blog</HeaderLink
            >
        </div>
    </nav>
</header>
