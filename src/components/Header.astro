---
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-0 w-full z-50 bg-white/80 dark:bg-[var(--bg-main)]/80 backdrop-blur-md border-b border-slate-200 dark:border-white/5">
	<nav class="layout-container flex items-center justify-between py-4">
		<a href="/" class="text-xl font-heading font-bold text-slate-900 dark:text-[var(--text-primary)] hover:text-slate-700 dark:hover:text-white transition-colors">
			{ "Dhaatrik." }
		</a>
		<div class="flex items-center gap-6">
			<HeaderLink href="/" class="text-slate-500 dark:text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Home</HeaderLink>
			<HeaderLink href="/about" class="text-slate-500 dark:text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">About</HeaderLink>
			<HeaderLink href="/blog" class="text-slate-500 dark:text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Blog</HeaderLink>
		</div>
	</nav>
</header>

