---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<!-- Subtle Noise Texture -->
<div class="pointer-events-none fixed inset-0 z-[100] h-full w-full opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml;base64,');"></div>
<!-- Ambient Background Glows -->
<div class="pointer-events-none fixed -top-[20%] -left-[10%] -z-10 h-[50vw] w-[50vw] rounded-full bg-[var(--accent)]/20 mix-blend-multiply blur-[120px] dark:bg-[var(--accent)]/10 dark:mix-blend-screen"></div>
<div class="pointer-events-none fixed -bottom-[20%] -right-[10%] -z-10 h-[50vw] w-[50vw] rounded-full bg-purple-500/20 mix-blend-multiply blur-[120px] dark:bg-purple-500/10 dark:mix-blend-screen"></div>

<a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[100] focus:bg-[var(--accent)] focus:px-4 focus:py-2 focus:font-bold focus:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-[var(--bg-main)]"
>
    Skip to content
</a>

<header
    class="fixed top-0 z-50 w-full backdrop-blur-lg bg-white/70 dark:bg-[#0b0e14]/70 border-b border-slate-200/50 dark:border-white/10"
>
    <nav class="layout-container flex items-center justify-between py-4">
        {
            /* ⚡ Bolt: Enable hover prefetching for isolated internal links to provide instant page transitions */
        }
        <a
            href="/"
            data-astro-prefetch="hover"
            class="flex items-center transition-opacity hover:opacity-80 focus-visible:opacity-80"
            aria-label="Dhaatrik — Home"
        >
            <img
                src="/logo_dark.svg"
                alt="Dhaatrik Logo"
                class="h-12 w-auto dark:hidden"
                width="48"
                height="48"
            />
            <img
                src="/logo_light.svg"
                alt="Dhaatrik Logo"
                class="hidden h-12 w-auto dark:block"
                width="48"
                height="48"
            />
        </a>
        <div class="flex items-center gap-6">
            <HeaderLink
                href="/"
                class="text-slate-500 transition-colors hover:text-[var(--accent)] focus-visible:text-[var(--accent)] dark:text-[var(--text-secondary)]"
                >Home</HeaderLink
            >
            <HeaderLink
                href="/about"
                class="text-slate-500 transition-colors hover:text-[var(--accent)] focus-visible:text-[var(--accent)] dark:text-[var(--text-secondary)]"
                >About</HeaderLink
            >
            <HeaderLink
                href="/blog"
                class="text-slate-500 transition-colors hover:text-[var(--accent)] focus-visible:text-[var(--accent)] dark:text-[var(--text-secondary)]"
                >Blog</HeaderLink
            >
            <div class="h-5 w-px bg-slate-200 dark:bg-white/10"></div>
            <ThemeToggle />
        </div>
    </nav>
</header>
