---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const cleanPath = pathname.replace(/\/$/, "");
const displayPath = cleanPath === "" ? "~/home" : `~/home${cleanPath}`;
---

<style>
    @keyframes sonar {
        0% { transform: scale(1); opacity: 0.6; }
        100% { transform: scale(2.5); opacity: 0; }
    }
    .sonar-icon { position: relative; }
    .sonar-icon::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        border-radius: 50%;
        background-color: var(--accent);
        opacity: 0;
        z-index: -1;
        pointer-events: none;
    }
    .sonar-trigger:hover .sonar-icon::after {
        animation: sonar 1s cubic-bezier(0, 0.2, 0.8, 1) forwards;
    }
    
    /* Ensure the header transition is smooth for the hide/show effect and promoted to GPU */
    #main-header {
        will-change: transform;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

    /* Hamburger Line Animations */
    #mobile-nav-toggle.open .hamburger-line:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
    }
    #mobile-nav-toggle.open .hamburger-line:nth-child(2) {
        opacity: 0;
        transform: scale(0);
    }
    #mobile-nav-toggle.open .hamburger-line:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
    }
</style>

<!-- Subtle Noise Texture -->
<div class="pointer-events-none fixed inset-0 z-100 h-full w-full opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml;base64,');"></div>
<!-- Ambient Background Glows -->
<div class="pointer-events-none fixed -top-[20%] -left-[10%] -z-10 h-[50vw] w-[50vw] rounded-full bg-(--accent)/20 mix-blend-multiply blur-[120px] dark:bg-(--accent)/10 dark:mix-blend-screen"></div>
<div class="pointer-events-none fixed -bottom-[20%] -right-[10%] -z-10 h-[50vw] w-[50vw] rounded-full bg-purple-500/20 mix-blend-multiply blur-[120px] dark:bg-purple-500/10 dark:mix-blend-screen"></div>

<a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-100 focus:bg-(--accent) focus:px-4 focus:py-2 focus:font-bold focus:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 dark:focus-visible:ring-offset-(--bg-main)"
>
    Skip to content
</a>

<header
    id="main-header"
    class="fixed top-0 z-50 w-full backdrop-blur-lg bg-white/70 dark:bg-[#0b0e14]/70 border-b border-slate-200/50 dark:border-white/10"
>
    <nav id="main-nav" class="layout-container flex items-center justify-between py-4 transition-all duration-300 ease-in-out">
        {
            /* ⚡ Bolt: Enable hover prefetching for isolated internal links to provide instant page transitions */
        }
        <a
            href="/"
            data-astro-prefetch="hover"
            class="flex items-center transition-opacity hover:opacity-80 focus-visible:opacity-80 sonar-trigger group"
            aria-label="Dhaatrik — Home"
        >
            <div class="sonar-icon rounded-full">
                <img
                    src="/logo_dark.svg"
                    alt="Dhaatrik Logo"
                    class="h-10 w-10 sm:h-12 sm:w-12 dark:hidden relative z-10"
                    width="48"
                    height="48"
                />
                <img
                    src="/logo_light.svg"
                    alt="Dhaatrik Logo"
                    class="hidden h-10 w-10 sm:h-12 sm:w-12 dark:block relative z-10"
                    width="48"
                    height="48"
                />
            </div>
            
            <div class="hidden sm:flex items-center">
                <div class="border-l border-slate-300 dark:border-white/20 h-6 mx-3 transition-colors group-hover:border-(--accent)/50"></div>
                <div class="flex flex-col justify-center">
                    <span class="font-bold text-slate-900 dark:text-white leading-none tracking-tight">DHAATRIK</span>
                    <span class="font-mono text-[10px] text-(--accent) opacity-80 tracking-widest leading-none mt-1">{displayPath}</span>
                </div>
            </div>
        </a>
        <div class="flex items-center gap-2.5 sm:gap-4 md:gap-6">
            <div class="hidden md:flex items-center gap-6">
                <HeaderLink
                    href="/"
                    class="text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary) flex items-center group/link"
                >
                    <span aria-hidden="true" class="font-mono text-[10px] text-slate-400 dark:text-slate-500 mr-2 opacity-70 group-hover/link:text-(--accent) transition-colors">[ 01 ]</span>Home
                </HeaderLink>
                <HeaderLink
                    href="/about"
                    class="text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary) flex items-center group/link"
                >
                    <span aria-hidden="true" class="font-mono text-[10px] text-slate-400 dark:text-slate-500 mr-2 opacity-70 group-hover/link:text-(--accent) transition-colors">[ 02 ]</span>Personnel
                </HeaderLink>
                <HeaderLink
                    href="/blog"
                    class="text-slate-600 transition-colors hover:text-(--accent) focus-visible:text-(--accent) dark:text-(--text-secondary) flex items-center group/link"
                >
                    <span aria-hidden="true" class="font-mono text-[10px] text-slate-400 dark:text-slate-500 mr-2 opacity-70 group-hover/link:text-(--accent) transition-colors">[ 03 ]</span>Transmissions
                </HeaderLink>
            </div>
            <ThemeToggle />
            <button
                id="mobile-nav-toggle"
                aria-label="Toggle navigation menu"
                aria-expanded="false"
                class="magnetic-target flex flex-col justify-center items-center gap-1.5 h-9 w-9 border border-transparent rounded-full hover:bg-slate-200/60 hover:text-slate-900 dark:hover:bg-white/10 dark:hover:text-white transition-colors cursor-pointer relative z-50 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 dark:focus-visible:ring-offset-(--bg-main) md:hidden"
            >
                <span class="hamburger-line w-5 h-0.5 bg-current transition-all duration-300"></span>
                <span class="hamburger-line w-5 h-0.5 bg-current transition-all duration-300"></span>
                <span class="hamburger-line w-5 h-0.5 bg-current transition-all duration-300"></span>
            </button>
        </div>
    </nav>
    <div id="mobile-nav-backdrop" class="fixed inset-0 z-40 bg-black/50 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"></div>
    <nav id="mobile-nav-drawer" class="fixed top-0 right-0 z-40 h-full w-72 bg-white/95 dark:bg-[#151a22]/98 backdrop-blur-xl border-l border-slate-200/80 dark:border-white/10 p-6 pt-24 shadow-2xl transition-transform duration-300 translate-x-full flex flex-col gap-6 md:hidden" aria-label="Mobile navigation">
        <div class="flex flex-col gap-4 font-mono">
            <div class="text-[9px] text-slate-400 dark:text-slate-500 tracking-widest uppercase border-b border-slate-200/50 dark:border-white/5 pb-2 mb-2">// DIRECTORY_INDEX</div>
            <HeaderLink href="/" class="text-lg text-slate-600 hover:text-(--accent) dark:text-(--text-secondary) flex items-center py-2 border-b border-slate-100 dark:border-white/5">
                <span class="text-[10px] text-(--accent) mr-3">[ 01 ]</span>Home
            </HeaderLink>
            <HeaderLink href="/about" class="text-lg text-slate-600 hover:text-(--accent) dark:text-(--text-secondary) flex items-center py-2 border-b border-slate-100 dark:border-white/5">
                <span class="text-[10px] text-(--accent) mr-3">[ 02 ]</span>Personnel
            </HeaderLink>
            <HeaderLink href="/blog" class="text-lg text-slate-600 hover:text-(--accent) dark:text-(--text-secondary) flex items-center py-2 border-b border-slate-100 dark:border-white/5">
                <span class="text-[10px] text-(--accent) mr-3">[ 03 ]</span>Transmissions
            </HeaderLink>
        </div>
        
        <div class="mt-auto border-t border-slate-200/50 dark:border-white/5 pt-4 font-mono text-[9px] text-slate-400 dark:text-slate-500 leading-relaxed uppercase">
            SYS.LINK // ENCRYPTED<br/>
            SWIPE RIGHT TO CLOSE
        </div>
    </nav>
</header>

<script>
    let headerAbortController: AbortController | null = null;
    let headerScrollTicking = false;

    const setupHeader = () => {
        if (headerAbortController) {
            headerAbortController.abort();
        }
        headerAbortController = new AbortController();
        const { signal } = headerAbortController;

        let lastScroll = window.scrollY;
        const header = document.getElementById('main-header');
        const nav = document.getElementById('main-nav');
        const toggleBtn = document.getElementById('mobile-nav-toggle');
        const drawer = document.getElementById('mobile-nav-drawer');
        const backdrop = document.getElementById('mobile-nav-backdrop');
        
        if (!header || !nav) return;

        const updateHeader = () => {
            if (signal.aborted) return;
            const currentScroll = window.scrollY;
            
            // Shrink header and add subtle shadow on scroll
            if (currentScroll > 50) {
                nav.classList.remove('py-4');
                nav.classList.add('py-2');
                header.classList.add('shadow-md', 'dark:shadow-black/50', 'bg-white/80', 'dark:bg-[#0b0e14]/80');
                header.classList.remove('bg-white/70', 'dark:bg-[#0b0e14]/70');
            } else {
                nav.classList.add('py-4');
                nav.classList.remove('py-2');
                header.classList.remove('shadow-md', 'dark:shadow-black/50', 'bg-white/80', 'dark:bg-[#0b0e14]/80');
                header.classList.add('bg-white/70', 'dark:bg-[#0b0e14]/70');
            }

            // Hide on scroll down, show on scroll up - more deliberate threshold
            const isDrawerOpen = toggleBtn && toggleBtn.classList.contains('open');
            if (!isDrawerOpen) {
                if (currentScroll <= 0) {
                    header.style.transform = 'translateY(0)';
                } else if (currentScroll > lastScroll && currentScroll > 150) {
                    // Scrolling down past threshold
                    header.style.transform = 'translateY(-100%)';
                } else if (currentScroll < lastScroll && (lastScroll - currentScroll > 10 || currentScroll < 50)) {
                    // Scrolling up (with a small buffer to prevent jitter)
                    header.style.transform = 'translateY(0)';
                }
            }
            
            lastScroll = currentScroll <= 0 ? 0 : currentScroll;
            headerScrollTicking = false;
        };

        const onScroll = () => {
            if (!headerScrollTicking) {
                window.requestAnimationFrame(updateHeader);
                headerScrollTicking = true;
            }
        };

        window.addEventListener('scroll', onScroll, { passive: true, signal });
        updateHeader();

        // Hamburger Drawer Control
        if (toggleBtn && drawer && backdrop) {
            let startX = 0;
            let currentX = 0;
            let isSwiping = false;

            const openMenu = () => {
                drawer.classList.remove('translate-x-full');
                drawer.classList.add('translate-x-0');
                backdrop.classList.remove('opacity-0', 'pointer-events-none');
                backdrop.classList.add('opacity-100', 'pointer-events-auto');
                toggleBtn.classList.add('open');
                toggleBtn.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            };

            const closeMenu = () => {
                drawer.classList.remove('translate-x-0');
                drawer.classList.add('translate-x-full');
                backdrop.classList.remove('opacity-100', 'pointer-events-auto');
                backdrop.classList.add('opacity-0', 'pointer-events-none');
                toggleBtn.classList.remove('open');
                toggleBtn.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
                drawer.style.transform = '';
            };

            toggleBtn.addEventListener('click', () => {
                const isOpen = toggleBtn.classList.contains('open');
                if (isOpen) {
                    closeMenu();
                } else {
                    openMenu();
                }
            }, { signal });

            backdrop.addEventListener('click', closeMenu, { signal });

            // Swipe Right to Close Drawer Gestures
            drawer.addEventListener('touchstart', (e) => {
                startX = e.touches[0].clientX;
                currentX = startX;
                isSwiping = true;
                drawer.style.transition = 'none';
            }, { passive: true, signal });

            drawer.addEventListener('touchmove', (e) => {
                if (!isSwiping) return;
                currentX = e.touches[0].clientX;
                const diffX = currentX - startX;
                if (diffX > 0) {
                    drawer.style.transform = `translateX(${diffX}px)`;
                }
            }, { passive: true, signal });

            drawer.addEventListener('touchend', () => {
                if (!isSwiping) return;
                isSwiping = false;
                drawer.style.transition = '';
                const diffX = currentX - startX;
                if (diffX > 60) {
                    closeMenu();
                } else {
                    drawer.style.transform = '';
                }
                startX = 0;
                currentX = 0;
            }, { signal });
        }
    };

    document.addEventListener('astro:page-load', setupHeader);

    document.addEventListener('astro:before-preparation', () => {
        // Ensure menu is closed when initiating transition to prevent overflow lock
        const toggleBtn = document.getElementById('mobile-nav-toggle');
        const drawer = document.getElementById('mobile-nav-drawer');
        const backdrop = document.getElementById('mobile-nav-backdrop');
        if (toggleBtn && toggleBtn.classList.contains('open')) {
            drawer?.classList.add('translate-x-full');
            backdrop?.classList.add('opacity-0', 'pointer-events-none');
            toggleBtn.classList.remove('open');
            document.body.style.overflow = '';
        }

        if (headerAbortController) {
            headerAbortController.abort();
            headerAbortController = null;
        }
    });
</script>
