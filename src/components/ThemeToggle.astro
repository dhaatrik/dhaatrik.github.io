---
// ThemeToggle.astro — A polished sun/moon toggle for light & dark mode.
// Reads from localStorage('theme') and syncs with the `dark` class on <html>.
---

<button
    id="theme-toggle"
    type="button"
    aria-label="Toggle theme"
    title="Toggle theme"
    class="magnetic-target relative flex h-9 w-9 items-center justify-center rounded-full text-slate-500 transition-all duration-300 hover:bg-slate-200/60 hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-(--accent) focus-visible:ring-offset-2 focus-visible:outline-none active:scale-95 dark:text-(--text-secondary) dark:hover:bg-white/10 dark:hover:text-white dark:focus-visible:ring-offset-(--bg-main)"
>
    <!-- Sun icon -->
    <svg
        id="theme-icon-sun"
        class="absolute h-5 w-5 transform transition-all duration-500 ease-out"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>

    <!-- Moon icon -->
    <svg
        id="theme-icon-moon"
        class="absolute h-5 w-5 transform transition-all duration-500 ease-out"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
</button>

<script is:inline>
    // Theme toggle logic — runs inline to avoid FOUC on page transitions.
    // Guard: only initialize once across SPA navigations to prevent listener stacking.
    (function () {
        if (window.__themeToggleInit) return;
        window.__themeToggleInit = true;

        function syncIcons() {
            var isDark = document.documentElement.classList.contains('dark');
            var sun = document.getElementById('theme-icon-sun');
            var moon = document.getElementById('theme-icon-moon');
            var btn = document.getElementById('theme-toggle');
            if (sun && moon) {
                if (isDark) {
                    sun.style.transform = 'scale(1) rotate(0deg)';
                    sun.style.opacity = '1';
                    moon.style.transform = 'scale(0) rotate(90deg)';
                    moon.style.opacity = '0';
                } else {
                    sun.style.transform = 'scale(0) rotate(-90deg)';
                    sun.style.opacity = '0';
                    moon.style.transform = 'scale(1) rotate(0deg)';
                    moon.style.opacity = '1';
                }
            }
            if (btn) {
                var label = isDark ? 'Switch to light mode' : 'Switch to dark mode';
                btn.setAttribute('aria-label', label);
                btn.setAttribute('title', label);
            }
        }

        function updateFavicon() {
            var isDark = document.documentElement.classList.contains('dark');
            var link = document.getElementById('favicon');
            if (link) {
                link.href = isDark ? '/logo_light.svg' : '/logo_dark.svg';
            }
        }

        function toggle(event) {
            var isDarkBefore = document.documentElement.classList.contains('dark');
            var prefersReducedMotion = window.matchMedia(
                '(prefers-reduced-motion: reduce)'
            ).matches;

            if (!document.startViewTransition || prefersReducedMotion) {
                document.documentElement.classList.toggle('dark');
                localStorage.setItem(
                    'theme',
                    document.documentElement.classList.contains('dark') ? 'dark' : 'light'
                );
                syncIcons();
                updateFavicon();
                return;
            }

            var x = event ? event.clientX : window.innerWidth / 2;
            var y = event ? event.clientY : window.innerHeight / 2;
            var endRadius = Math.hypot(
                Math.max(x, window.innerWidth - x),
                Math.max(y, window.innerHeight - y)
            );

            document.documentElement.classList.add('theme-transition');

            var transition = document.startViewTransition(function () {
                document.documentElement.classList.toggle('dark');
                localStorage.setItem(
                    'theme',
                    document.documentElement.classList.contains('dark') ? 'dark' : 'light'
                );
                syncIcons();
                updateFavicon();
            });

            transition.ready.then(function () {
                var clipPath = [
                    'circle(0px at ' + x + 'px ' + y + 'px)',
                    'circle(' + endRadius + 'px at ' + x + 'px ' + y + 'px)',
                ];
                document.documentElement.animate(
                    {
                        clipPath: clipPath,
                    },
                    {
                        duration: 400,
                        easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
                        pseudoElement: '::view-transition-new(root)',
                    }
                );
            });

            transition.finished.then(function () {
                document.documentElement.classList.remove('theme-transition');
            });
        }

        function bindToggle() {
            var btn = document.getElementById('theme-toggle');
            if (btn) {
                // Remove first to guarantee exactly one handler exists
                btn.removeEventListener('click', toggle);
                btn.addEventListener('click', toggle);
            }
            syncIcons();
        }

        // Initial bind
        bindToggle();

        // Re-bind after Astro client-side navigation (View Transitions).
        // Registered once; removeEventListener inside bindToggle prevents stacking.
        document.addEventListener('astro:after-swap', bindToggle);
    })();
</script>
