---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import '@fontsource/nunito';
// ⚡ Bolt: Explicitly import 700 weight CSS to utilize the preloaded font and avoid faux-bold synthesis
import '@fontsource/poppins/700.css';

// Import font files for preloading
import nunitoUrl from '@fontsource/nunito/files/nunito-latin-400-normal.woff2?url';
import poppinsUrl from '@fontsource/poppins/files/poppins-latin-700-normal.woff2?url';

import type { ImageMetadata } from 'astro';
import { ClientRouter } from 'astro:transitions';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
    title: string;
    description: string;
    image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;

// ⚡ Bolt: Cache image URL instantiation to avoid redundant parsing during SSG
const imageUrl = new URL(image.src, Astro.site);

const personSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Dhaatrik Chowdhury',
    url: Astro.site,
    sameAs: [
        'https://github.com/dhaatrik',
        'https://linkedin.com/in/dhaatrik',
        'https://x.com/dhaatrik',
        'https://medium.com/@dhaatrik',
    ],
    jobTitle: 'Entrepreneur & AI Engineer',
}).replace(/</g, '\\u003c');
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="google-site-verification" content="NPuW-RXuLzjTXSLXeUxcKVpFFvvOxJ3xzwuK-Vhbn3c" />

<!-- Security Meta Tags -->
<!-- Note: X-Frame-Options and X-Content-Type-Options are omitted as browsers ignore them in <meta> tags. -->
<!-- CSP tightened: added connect-src 'self' to limit exfiltration and form-action 'none' since site has no forms -->
<meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self'; worker-src 'self' blob:; form-action 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;"
/>
<meta name="referrer" content="strict-origin-when-cross-origin" />

<link id="favicon" rel="icon" type="image/svg+xml" href="/logo_dark.svg" />
<script is:inline>
    // Theme initializer — runs before paint to prevent FOUC.
    // Default to 'dark' if no stored preference.
    (function () {
        function applyTheme() {
            var stored = localStorage.getItem('theme');
            var isDark = stored ? stored === 'dark' : true;
            document.documentElement.classList.toggle('dark', isDark);
            // Sync favicon
            var link = document.getElementById('favicon');
            if (link) link.href = isDark ? '/logo_light.svg' : '/logo_dark.svg';
        }
        applyTheme();
        // Re-apply after Astro View Transitions swap
        document.addEventListener('astro:after-swap', applyTheme);
    })();
</script>
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Font Preloading -->
<link rel="preload" href={nunitoUrl} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={poppinsUrl} as="font" type="font/woff2" crossorigin />

<link
    rel="alternate"
    type="application/rss+xml"
    title={SITE_TITLE}
    href={new URL('rss.xml', Astro.site)}
/>


<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />

<!-- SPA-like Client Router for instant page transitions -->
<ClientRouter />

<!-- Schema.org Script -->
<script
    type="application/ld+json"
    set:html={personSchema}
/>

<script is:inline>
    // ⚡ Bolt: Global mouse spotlight and flashlight background tracking
    // Optimized using requestAnimationFrame and cached collections to prevent layout thrashing
    let spotlightRafId = null;
    let mouseX = 0;
    let mouseY = 0;
    let cardsCollection = null;
    let flashlightBg = null;
    let magneticTargets = [];

    const updateSpotlights = () => {
        // Read Phase: Get all current layouts first to prevent layout thrashing
        let cardsData = [];
        if (cardsCollection) {
            for (let i = 0; i < cardsCollection.length; i++) {
                const card = cardsCollection[i];
                cardsData.push({ card, rect: card.getBoundingClientRect() });
            }
        }

        let magnetData = [];
        for (let i = 0; i < magneticTargets.length; i++) {
            const el = magneticTargets[i];
            magnetData.push({ el, rect: el.getBoundingClientRect() });
        }

        // Write Phase: Apply CSS visual transitions on compositor thread
        cardsData.forEach(({ card, rect }) => {
            const x = mouseX - rect.left;
            const y = mouseY - rect.top;
            card.style.setProperty('--mouse-x', `${x}px`);
            card.style.setProperty('--mouse-y', `${y}px`);
        });

        if (flashlightBg) {
            flashlightBg.style.setProperty('--bg-mouse-x', `${mouseX}px`);
            flashlightBg.style.setProperty('--bg-mouse-y', `${mouseY}px`);
        }

        magnetData.forEach(({ el, rect }) => {
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            const dx = mouseX - centerX;
            const dy = mouseY - centerY;
            const distance = Math.hypot(dx, dy);

            // Proximity pull threshold: 80px
            const threshold = 80;

            if (distance < threshold) {
                const ratio = 1 - distance / threshold; // 0 at threshold, 1 at center
                const pullX = dx * 0.35 * ratio;
                const pullY = dy * 0.35 * ratio;
                const scale = 1 + ratio * 0.06;

                el.style.transition = 'none';
                el.style.transform = `translate(${pullX}px, ${pullY}px) scale(${scale})`;
                el.setAttribute('data-magnetic-active', 'true');
            } else if (el.getAttribute('data-magnetic-active') === 'true') {
                el.style.transform = 'translate(0px, 0px) scale(1)';
                if (el.classList.contains('transition-spring')) {
                    const supportsLinear = window.CSS && CSS.supports('animation-timing-function', 'linear(0, 1)');
                    if (supportsLinear) {
                        el.style.transition = 'transform 0.8s var(--ease-spring-bounce), box-shadow 0.3s ease, background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease';
                    } else {
                        el.style.transition = 'transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease';
                    }
                } else {
                    el.style.transition = 'transform 0.5s cubic-bezier(0.25, 1, 0.5, 1)';
                }
                el.setAttribute('data-magnetic-active', 'false');
            }
        });

        spotlightRafId = null;
    };

    const onMouseMove = (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        if (!spotlightRafId) {
            spotlightRafId = requestAnimationFrame(updateSpotlights);
        }
    };

    document.addEventListener('astro:page-load', () => {
        // Ensure flashlight background exists on the page
        flashlightBg = document.getElementById('flashlight-bg');
        if (!flashlightBg) {
            flashlightBg = document.createElement('div');
            flashlightBg.id = 'flashlight-bg';
            document.body.prepend(flashlightBg);
        }

        // Cache live collections and query targets
        cardsCollection = document.getElementsByClassName('bento-card');
        magneticTargets = Array.from(document.querySelectorAll('.magnetic-target'));
        document.addEventListener('mousemove', onMouseMove, { passive: true });

        // Bind 3D Bento Card Parallax Tilt
        const cards = document.querySelectorAll('.bento-card');
        cards.forEach(card => {
            const handleCardMove = (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                const xc = rect.width / 2;
                const yc = rect.height / 2;

                const tiltX = (yc - y) / 30;
                const tiltY = (x - xc) / 30;

                card.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale3d(1.01, 1.01, 1.01)`;
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);

                // Push inner elements outwards
                const tilts = card.querySelectorAll('[data-tilt-z]');
                tilts.forEach(target => {
                    target.style.transform = 'translateZ(10px)';
                });
            };

            const handleCardLeave = () => {
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
                const tilts = card.querySelectorAll('[data-tilt-z]');
                tilts.forEach(target => {
                    target.style.transform = 'translateZ(0px)';
                });
            };

            card.addEventListener('mousemove', handleCardMove);
            card.addEventListener('mouseleave', handleCardLeave);
        });

        // Programmatic Accessibility Routing: Focus header or main container on page load/transition
        const focusTarget = document.querySelector('main h1, h1, #main-content, main');
        if (focusTarget) {
            if (!focusTarget.hasAttribute('tabindex')) {
                focusTarget.setAttribute('tabindex', '-1');
            }
            focusTarget.focus({ preventScroll: true });
        }

        // Clean up temporary transition names on the newly loaded page
        const activeTitle = document.querySelector('h1[style*="view-transition-name"]');
        const activeImg = document.querySelector('img[style*="view-transition-name"], div[style*="view-transition-name"]');
        if (activeTitle) activeTitle.style.removeProperty('view-transition-name');
        if (activeImg) activeImg.style.removeProperty('view-transition-name');
    });

    document.addEventListener('astro:before-preparation', () => {
        document.removeEventListener('mousemove', onMouseMove);
        if (spotlightRafId) {
            cancelAnimationFrame(spotlightRafId);
            spotlightRafId = null;
        }
        cardsCollection = null;
        flashlightBg = null;
        magneticTargets = [];
    });
</script>
