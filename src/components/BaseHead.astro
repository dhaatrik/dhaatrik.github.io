---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import '@fontsource/nunito';
// ⚡ Bolt: Explicitly import 700 weight CSS to utilize the preloaded font and avoid faux-bold synthesis
import '@fontsource/poppins/700.css';

// Import font files for preloading
import nunitoUrl from '@fontsource/nunito/files/nunito-latin-400-normal.woff2?url';
import poppinsUrl from '@fontsource/poppins/files/poppins-latin-700-normal.woff2?url';

import type { ImageMetadata } from 'astro';
import { ClientRouter } from 'astro:transitions';
import FallbackImage from '../assets/blog-placeholder-4.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
    title: string;
    description: string;
    image?: ImageMetadata;
    type?: 'website' | 'article';
    keywords?: string[];
    pubDate?: Date;
    updatedDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, type = 'website', keywords, pubDate, updatedDate } = Astro.props;

// ⚡ Bolt: Cache image URL instantiation to avoid redundant parsing during SSG
const imageUrl = new URL(image.src, Astro.site);

const personSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Dhaatrik Chowdhury',
    url: Astro.site,
    sameAs: [
        'https://github.com/dhaatrik',
        'https://linkedin.com/in/dhaatrik',
        'https://x.com/dhaatrik',
        'https://medium.com/@dhaatrik',
    ],
    jobTitle: 'Entrepreneur & AI Engineer',
}).replace(/</g, '\\u003c');
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="google-site-verification" content="NPuW-RXuLzjTXSLXeUxcKVpFFvvOxJ3xzwuK-Vhbn3c" />

<!-- Security Meta Tags -->
<!-- Note: X-Frame-Options and X-Content-Type-Options are omitted as browsers ignore them in <meta> tags. -->
<!-- CSP tightened: added connect-src 'self' to limit exfiltration and form-action 'none' since site has no forms -->
<meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self'; worker-src 'self' blob:; form-action 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;"
/>
<meta name="referrer" content="strict-origin-when-cross-origin" />

<link id="favicon" rel="icon" type="image/svg+xml" href="/logo_dark.svg" />
<script is:inline>
    // Theme initializer — runs before paint to prevent FOUC.
    // Default to 'dark' if no stored preference.
    (function () {
        function applyTheme() {
            var stored = localStorage.getItem('theme');
            var isDark = stored ? stored === 'dark' : true;
            document.documentElement.classList.toggle('dark', isDark);
            // Sync favicon
            var link = document.getElementById('favicon');
            if (link) link.href = isDark ? '/logo_light.svg' : '/logo_dark.svg';
        }
        applyTheme();
        // Re-apply after Astro View Transitions swap
        document.addEventListener('astro:after-swap', applyTheme);
    })();
</script>
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Font Preloading -->
<link rel="preload" href={nunitoUrl} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={poppinsUrl} as="font" type="font/woff2" crossorigin />

<link
    rel="alternate"
    type="application/rss+xml"
    title={SITE_TITLE}
    href={new URL('rss.xml', Astro.site)}
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Dhaatrik Chowdhury" />
{keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content="en_US" />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
{type === 'article' && <meta property="article:author" content="Dhaatrik Chowdhury" />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />
<meta name="twitter:site" content="@dhaatrik" />
<meta name="twitter:creator" content="@dhaatrik" />

<!-- SPA-like Client Router for instant page transitions -->
<ClientRouter />

<!-- Schema.org Script -->
<script type="application/ld+json" set:html={personSchema} />

<script>
    import '../scripts/mouseTracker.ts';

    // Programmatic Accessibility Routing: Focus header or main container on page load/transition
    document.addEventListener('astro:page-load', () => {
        const focusTarget = document.querySelector('main h1, h1, #main-content, main') as HTMLElement | null;
        if (focusTarget) {
            if (!focusTarget.hasAttribute('tabindex')) {
                focusTarget.setAttribute('tabindex', '-1');
            }
            focusTarget.focus({ preventScroll: true });
        }

        // Clean up temporary transition names on the newly loaded page
        const activeTitle = document.querySelector('h1[style*="view-transition-name"]') as HTMLElement | null;
        const activeImg = document.querySelector(
            'img[style*="view-transition-name"], div[style*="view-transition-name"]'
        ) as HTMLElement | null;
        if (activeTitle) activeTitle.style.removeProperty('view-transition-name');
        if (activeImg) activeImg.style.removeProperty('view-transition-name');
    });
</script>
