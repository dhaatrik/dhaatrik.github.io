---
import { dateFormatter } from '../utils/dateFormatter';

interface Props {
    date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()}>
    {
        /* ⚡ Bolt: Cache Intl.DateTimeFormat to avoid repeated object creation during SSG */
        dateFormatter.format(date)
    }
</time>
